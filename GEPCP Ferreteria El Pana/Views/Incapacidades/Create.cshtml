@model GEPCP_Ferreteria_El_Pana.Models.Incapacidad
@{
    ViewData["Title"] = "Nueva Incapacidad - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-hospital"></i> Registrar Incapacidad</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-2">

        <!-- MENSAJE DE ERRORES GLOBAL -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger mb-2" style="font-size: 0.75rem;">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <strong>No se pudo registrar la incapacidad:</strong>
                <ul class="mb-0 mt-2">
                    @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@e.ErrorMessage</li>
                    }
                </ul>
            </div>
        }

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="row g-1">

                <!-- Buscador de Empleado -->
                <div class="col-12">
                    <label class="form-label fw-bold small">
                        <i class="bi bi-person-search"></i> Empleado <span class="text-danger">*</span>
                    </label>
                    <input type="hidden" asp-for="EmpleadoId" id="EmpleadoId" />
                    <div class="input-group input-group-sm mb-1">
                        <span class="input-group-text bg-white">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        <input type="text" id="buscarEmpleado"
                               class="form-control form-control-sm border-start-0"
                               placeholder="Buscar por nombre, apellido o cédula..." autocomplete="off" />
                        <button type="button" class="btn btn-outline-secondary btn-sm" id="btnTodos">
                            <i class="bi bi-list-ul"></i> Todos
                        </button>
                    </div>
                    <div id="empleadoSeleccionado" class="d-none alert alert-success py-1 d-flex justify-content-between align-items-center" style="font-size: 0.85rem;">
                        <div>
                            <i class="bi bi-person-check-fill"></i>
                            <strong id="empNombre"></strong>
                            <span class="text-muted ms-2 small" id="empCedula"></span>
                        </div>
                        <button type="button" class="btn btn-sm btn-outline-danger" id="btnLimpiar">
                            <i class="bi bi-x"></i>
                        </button>
                    </div>
                    <div id="resultados" class="border rounded shadow-sm"
                         style="display:none; max-height:200px; overflow-y:auto; background:#fff; z-index:100; position:relative;font-size:0.85rem;">
                    </div>
                    <span asp-validation-for="EmpleadoId" class="text-danger" style="font-size: 0.7rem;"></span>
                </div>

                <!-- Entidad -->
                <div class="col-md-4">
                    <label asp-for="Entidad" class="form-label fw-bold small">Entidad <span class="text-danger">*</span></label>
                    <select asp-for="Entidad" class="form-select form-select-sm" id="selectEntidad">
                        <option value="1">CCSS</option>
                        <option value="2">INS</option>
                    </select>
                    <span asp-validation-for="Entidad" class="text-danger" style="font-size: 0.7rem;"></span>
                </div>

                <!-- Tipo de Incapacidad -->
                <div class="col-md-8">
                    <label asp-for="TipoIncapacidad" class="form-label fw-bold small">Tipo de Incapacidad <span class="text-danger">*</span></label>
                    <select asp-for="TipoIncapacidad" class="form-select form-select-sm">
                        <option value="Enfermedad común">Enfermedad común</option>
                        <option value="Accidente de tránsito">Accidente de tránsito</option>
                        <option value="Accidente laboral">Accidente laboral</option>
                        <option value="Licencia de maternidad">Licencia de maternidad</option>
                        <option value="Licencia de paternidad">Licencia de paternidad</option>
                        <option value="Recuperación">Recuperación</option>
                        <option value="Otro">Otro</option>
                    </select>
                    <span asp-validation-for="TipoIncapacidad" class="text-danger" style="font-size: 0.7rem;"></span>
                </div>

                <!-- Fechas -->
                <div class="col-md-5">
                    <label asp-for="FechaInicio" class="form-label fw-bold small">Fecha Inicio <span class="text-danger">*</span></label>
                    <input asp-for="FechaInicio" type="date" id="inputFechaInicio" class="form-control form-control-sm" />
                    <span asp-validation-for="FechaInicio" class="text-danger" style="font-size: 0.7rem;"></span>
                </div>

                <div class="col-md-5">
                    <label asp-for="FechaFin" class="form-label fw-bold small">Fecha Fin <span class="text-danger">*</span></label>
                    <input asp-for="FechaFin" type="date" id="inputFechaFin" class="form-control form-control-sm" />
                    <span asp-validation-for="FechaFin" class="text-danger" style="font-size: 0.7rem;"></span>
                </div>

                <div class="col-md-2">
                    <label class="form-label fw-bold small text-muted">Días</label>
                    <div class="form-control form-control-sm bg-light text-center fw-bold text-primary" id="totalDiasRef">—</div>
                </div>

                <!-- Tiquete CCSS -->
                <div class="col-md-6" id="divTiquete">
                    <label asp-for="TiqueteCCSS" class="form-label fw-bold small">Tiquete CCSS <span class="text-danger">*</span></label>
                    <input asp-for="TiqueteCCSS" class="form-control form-control-sm" maxlength="50" placeholder="Ej: A00270125022436" />
                    <span asp-validation-for="TiqueteCCSS" class="text-danger" style="font-size: 0.7rem;"></span>
                </div>

                <!-- Porcentaje de Pago -->
                <div class="col-md-3">
                    <label asp-for="PorcentajePago" class="form-label fw-bold small">% Pago <span class="text-danger">*</span></label>
                    <select asp-for="PorcentajePago" class="form-select form-select-sm" id="selectPorcentaje">
                        <option value="50">50%</option>
                        <option value="60">60%</option>
                        <option value="100">100%</option>
                    </select>
                    <span asp-validation-for="PorcentajePago" class="text-danger" style="font-size: 0.7rem;"></span>
                </div>

                <!-- Responsable del Pago -->
                <div class="col-md-3">
                    <label asp-for="ResponsablePago" class="form-label fw-bold small">Responsable</label>
                    <select asp-for="ResponsablePago" class="form-select form-select-sm">
                        <option value="1">Patrono</option>
                        <option value="2">CCSS</option>
                        <option value="3">INS</option>
                    </select>
                </div>

                <!-- Observaciones -->
                <div class="col-12">
                    <label asp-for="Observaciones" class="form-label fw-bold small">Observaciones</label>
                    <input asp-for="Observaciones" class="form-control form-control-sm" maxlength="200" />
                    <span asp-validation-for="Observaciones" class="text-danger" style="font-size: 0.7rem;"></span>
                </div>

            </div>

            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-success btn-sm px-4" id="btnGuardar" disabled>
                    <i class="bi bi-check-circle"></i> Registrar Incapacidad
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-sm px-4">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Buscador de Empleado
        async function buscar(termino, todos = false) {
            var url = todos ? '/Incapacidades/TodosLosEmpleados' : '/Incapacidades/BuscarEmpleados?termino=' + encodeURIComponent(termino);
            var res = await fetch(url);
            var data = await res.json();
            var div = document.getElementById('resultados');

            if (!data.length) {
                div.innerHTML = '<div class="p-3 text-muted text-center small">Sin resultados.</div>';
                div.style.display = 'block';
                return;
            }

            div.innerHTML = data.map(e => `
                        <div class="p-2 border-bottom" style="cursor:pointer;"
                             onmouseover="this.style.background='#f8f8f8'"
                             onmouseout="this.style.background='#fff'"
                             onclick="seleccionar(${e.id}, '${e.nombre.replace(/'/g, "\\'")}', '${e.cedula}', '${e.puesto.replace(/'/g, "\\'")}')">
                            <div class="fw-bold small">${e.nombre}</div>
                            <div class="text-muted" style="font-size:0.78rem;">${e.cedula} — ${e.puesto}</div>
                        </div>`).join('');
            div.style.display = 'block';
        }

        function seleccionar(id, nombre, cedula, puesto) {
            document.getElementById('EmpleadoId').value = id;
            document.getElementById('empNombre').textContent = nombre;
            document.getElementById('empCedula').textContent = cedula;
            document.getElementById('empleadoSeleccionado').classList.remove('d-none');
            document.getElementById('resultados').style.display = 'none';
            document.getElementById('buscarEmpleado').value = '';
            document.getElementById('btnGuardar').disabled = false;
        }

        // Eventos del buscador
        document.getElementById('buscarEmpleado').addEventListener('input', function() {
            clearTimeout(window.timer);
            var val = this.value.trim();
            if (val.length < 2) {
                document.getElementById('resultados').style.display = 'none';
                return;
            }
            window.timer = setTimeout(() => buscar(val), 300);
        });

        document.getElementById('btnTodos').addEventListener('click', () => buscar('', true));

        document.getElementById('btnLimpiar').addEventListener('click', function() {
            document.getElementById('EmpleadoId').value = '';
            document.getElementById('empleadoSeleccionado').classList.add('d-none');
            document.getElementById('buscarEmpleado').value = '';
            document.getElementById('btnGuardar').disabled = true;
        });

        // Toggle Tiquete CCSS
        document.getElementById('selectEntidad').addEventListener('change', function() {
            document.getElementById('divTiquete').style.display = this.value == "1" ? 'block' : 'none';
        });

        // Calcular días automáticamente
        function calcularDias() {
            var fi = new Date(document.getElementById('inputFechaInicio').value);
            var ff = new Date(document.getElementById('inputFechaFin').value);
            var dias = Math.round((ff - fi) / (1000 * 60 * 60 * 24)) + 1;
            document.getElementById('totalDiasRef').textContent = dias > 0 ? dias : '—';
        }

        document.getElementById('inputFechaInicio').addEventListener('change', calcularDias);
        document.getElementById('inputFechaFin').addEventListener('change', calcularDias);

        // Inicializar
        document.getElementById('selectEntidad').dispatchEvent(new Event('change'));
    </script>
}