@model GEPCP_Ferreteria_El_Pana.Models.Vacacion
@{
    ViewData["Title"] = "Editar Vacación - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-pencil"></i> Editar Vacación</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-2">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="VacacionId" />
            <input type="hidden" asp-for="EmpleadoId" />
            <input type="hidden" asp-for="SalarioDiario" />
            <input type="hidden" asp-for="DiasDisponiblesAlRegistrar" />
            <input type="hidden" asp-for="RegistradoPor" />
            <input type="hidden" asp-for="FechaRegistro" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger mb-2" style="font-size: 0.75rem;">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <strong>No se pudo guardar:</strong>
                    <ul class="mb-0 mt-1">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@error.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }

            <div class="row g-1">

                @* Info del empleado — solo lectura *@
                <div class="col-12">
                    <label class="form-label fw-bold small">
                        <i class="bi bi-person"></i> Empleado
                    </label>
                    <div class="alert alert-info py-1 mb-0 d-flex justify-content-between align-items-center" style="font-size: 0.85rem;">
                        <div>
                            <i class="bi bi-person-check-fill"></i>
                            <strong>@ViewBag.EmpleadoNombre</strong>
                            <span class="text-muted ms-2 small">@ViewBag.EmpleadoCedula</span>
                        </div>
                        <div class="text-end small fw-bold">
                            <div>₡@(((decimal)(ViewBag.SalarioDiario ?? 0m)).ToString("N2"))/día</div>
                            <div class="text-primary">
                                @(((decimal)(ViewBag.DiasDisponibles ?? 0m)).ToString("N1")) días disponibles
                            </div>
                        </div>
                    </div>
                </div>

                @* Fechas *@
                <div class="col-md-6">
                    <label asp-for="FechaInicio" class="form-label fw-bold small">
                        <i class="bi bi-calendar-check"></i> Fecha Inicio <span class="text-danger">*</span>
                    </label>
                    <input asp-for="FechaInicio" type="date"
                           class="form-control form-control-sm" />
                    <span asp-validation-for="FechaInicio" class="text-danger" style="font-size: 0.7rem;"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="FechaFin" class="form-label fw-bold small">
                        <i class="bi bi-calendar-x"></i> Fecha Fin <span class="text-danger">*</span>
                    </label>
                    <input asp-for="FechaFin" type="date"
                           class="form-control form-control-sm" />
                    <span asp-validation-for="FechaFin" class="text-danger" style="font-size: 0.7rem;"></span>
                </div>

                @* Días hábiles *@
                <div class="col-md-4">
                    <label asp-for="DiasHabiles" class="form-label fw-bold small">
                        <i class="bi bi-calendar2-week"></i> Días Hábiles <span class="text-danger">*</span>
                    </label>
                    <input asp-for="DiasHabiles" type="number" step="0.5" min="0.5"
                           class="form-control form-control-sm" id="inputDias" />
                    <div class="form-text text-muted" style="font-size: 0.7rem;">Podés editar este número manualmente.</div>
                    <span asp-validation-for="DiasHabiles" class="text-danger" style="font-size: 0.7rem;"></span>
                </div>

                @* Tipo *@
                <div class="col-md-4">
                    <label asp-for="Tipo" class="form-label fw-bold small">
                        <i class="bi bi-toggle-on"></i> Tipo <span class="text-danger">*</span>
                    </label>
                    <select asp-for="Tipo" class="form-select form-select-sm" id="selectTipo">
                        <option value="1">Con Pago</option>
                        <option value="2">Sin Pago</option>
                    </select>
                    <span asp-validation-for="Tipo" class="text-danger" style="font-size: 0.7rem;"></span>
                </div>

                @* Estado *@
                <div class="col-md-4">
                    <label asp-for="Estado" class="form-label fw-bold small">
                        <i class="bi bi-check2-circle"></i> Estado <span class="text-danger">*</span>
                    </label>
                    <select asp-for="Estado" class="form-select form-select-sm">
                        <option value="1">Pendiente</option>
                        <option value="2">Aprobada</option>
                        <option value="3">Rechazada</option>
                    </select>
                    <span asp-validation-for="Estado" class="text-danger" style="font-size: 0.7rem;"></span>
                </div>

                @* Monto estimado *@
                <div class="col-md-6">
                    <label class="form-label fw-bold small text-muted">
                        <i class="bi bi-calculator"></i> Deducción Estimada
                    </label>
                    <div class="form-control form-control-sm bg-light text-center fw-bold"
                         id="montoRef">
                        @(Model.MontoDeducido > 0 ? $"₡{Model.MontoDeducido:N0}" : "Sin deducción")
                    </div>
                    <div class="form-text text-muted" id="montoHint" style="font-size: 0.7rem;">
                        Solo aplica si el tipo es Sin Pago.
                    </div>
                </div>

                @* Observaciones *@
                <div class="col-md-6">
                    <label asp-for="Observaciones" class="form-label fw-bold small">
                        <i class="bi bi-chat-text"></i> Observaciones
                        <span class="text-muted fw-normal small">(opcional)</span>
                    </label>
                    <textarea asp-for="Observaciones" class="form-control form-control-sm"
                              rows="2" maxlength="300"></textarea>
                    <span asp-validation-for="Observaciones" class="text-danger" style="font-size: 0.7rem;"></span>
                </div>

            </div>

            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-warning btn-sm px-4">
                    <i class="bi bi-check-circle"></i> Guardar Cambios
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-sm px-4">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        var salarioDiario = @Model.SalarioDiario.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);

        function calcularMonto() {
            var dias = parseFloat(document.getElementById('inputDias').value) || 0;
            var tipo = parseInt(document.getElementById('selectTipo').value);
            var montoRef = document.getElementById('montoRef');
            var hint = document.getElementById('montoHint');

            if (tipo === 2 && dias > 0 && salarioDiario > 0) {
                var monto = dias * salarioDiario;
                montoRef.textContent = '₡' + monto.toLocaleString('es-CR', { minimumFractionDigits: 2 });
                montoRef.className = 'form-control bg-light text-center fw-bold text-danger';
                hint.textContent = `${dias} días × ₡${salarioDiario.toLocaleString('es-CR', { minimumFractionDigits: 2 })}/día`;
            } else {
                montoRef.textContent = tipo === 1 ? 'Sin deducción' : '—';
                montoRef.className = 'form-control bg-light text-center fw-bold text-muted';
                hint.textContent = 'Solo aplica si el tipo es Sin Pago.';
            }
        }

        document.getElementById('inputDias').addEventListener('input', calcularMonto);
        document.getElementById('selectTipo').addEventListener('change', calcularMonto);
        calcularMonto();
    </script>
}