@{
    ViewData["Title"] = "Planilla - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="mb-4">
    Planilla
    <small class="text-muted">- @ViewBag.Periodo</small>
    <span class="badge bg-@(ViewBag.Estado == "Abierto" ? "success" : "secondary") fs-6">@ViewBag.Estado</span>
</h2>

<div class="row g-4 mb-5">
    <!-- TOTAL BRUTO -->
    <div class="col-md-4">
        <div class="card text-white bg-success h-100">
            <div class="card-body text-center">
                <i class="bi bi-cash-stack fs-1"></i>
                <h5 class="mt-3">Total Bruto</h5>
                <h2 class="display-5">₡@ViewBag.TotalBruto.ToString("N0")</h2>
            </div>
        </div>
    </div>

    <!-- TOTAL DEDUCCIONES -->
    <div class="col-md-4">
        <div class="card text-white bg-warning h-100">
            <div class="card-body text-center">
                <i class="bi bi-credit-card fs-1"></i>
                <h5 class="mt-3">Total Deducciones</h5>
                <h2 class="display-5">₡@ViewBag.TotalDeducciones.ToString("N0")</h2>
            </div>
        </div>
    </div>

    <!-- TOTAL NETO -->
    <div class="col-md-4">
        <div class="card text-white bg-primary h-100">
            <div class="card-body text-center">
                <i class="bi bi-graph-up-arrow fs-1"></i>
                <h5 class="mt-3">Total Neto a Pagar</h5>
                <h2 class="display-5">₡@ViewBag.TotalNeto.ToString("N0")</h2>
            </div>
        </div>
    </div>
</div>

<!-- BOTONES DE ACCIÓN -->
<div class="mb-4">
    <form asp-action="Calcular" method="post" class="d-inline">
        <button type="submit" class="btn btn-warning btn-lg px-5">
            <i class="bi bi-calculator"></i> Calcular Planilla
        </button>
    </form>

    <form asp-action="CerrarPeriodo" method="post" class="d-inline ms-3">
        <button type="submit" class="btn btn-success btn-lg px-5">
            <i class="bi bi-lock"></i> Cerrar Período (Inmutable)
        </button>
    </form>
</div>

<hr />

<h5>Detalle por Empleado (demo - después vendrá de la BD)</h5>
<table class="table table-hover table-striped">
    <thead class="table-dark">
        <tr>
            <th>Empleado</th>
            <th>Salario Base</th>
            <th>Comisiones</th>
            <th>Cuota Préstamo</th>
            <th>Neto</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>Hilario Solera Meza</td>
            <td>₡450,000</td>
            <td>₡45,000</td>
            <td>₡15,000</td>
            <td class="text-success fw-bold">₡480,000</td>
        </tr>
        <tr>
            <td>Juan Pérez</td>
            <td>₡380,000</td>
            <td>₡32,000</td>
            <td>₡8,000</td>
            <td class="text-success fw-bold">₡404,000</td>
        </tr>
    </tbody>
</table>