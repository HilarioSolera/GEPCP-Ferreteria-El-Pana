@model GEPCP_Ferreteria_El_Pana.Models.HorasExtras
@{
    ViewData["Title"] = "Registrar Horas Extras - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var periodoFechaInicio = ViewBag.PeriodoFechaInicio as string ?? "";
    var periodoFechaFin = ViewBag.PeriodoFechaFin as string ?? "";
    var periodoDescripcion = ViewBag.PeriodoDescripcion as string ?? "";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-clock-history"></i> Registrar Horas Extras</h2>
    <a asp-action="Index" asp-route-periodoId="@Model.PeriodoPagoId"
           class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <form asp-action="Create" method="post" id="formHorasExtras">
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger mb-3">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <strong>No se pudo registrar:</strong>
                    <ul class="mb-0 mt-1">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@error.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }

            <div class="row g-3">

                @* ── Período ── *@
                <div class="col-md-6">
                    <label asp-for="PeriodoPagoId" class="form-label fw-bold">
                        <i class="bi bi-calendar2-week"></i> Período
                        <span class="text-danger">*</span>
                    </label>
                    <select asp-for="PeriodoPagoId" asp-items="ViewBag.Periodos"
                            class="form-select" id="selectPeriodo">
                        <option value="">— Seleccione un período —</option>
                    </select>
                    <div class="form-text text-muted">
                        Solo se muestran períodos abiertos del mes actual.
                    </div>
                    <span asp-validation-for="PeriodoPagoId" class="text-danger small"></span>
                </div>

                @* ── Fecha ── *@
                <div class="col-md-6">
                    <label asp-for="Fecha" class="form-label fw-bold">
                        <i class="bi bi-calendar-date"></i> Fecha
                        <span class="text-danger">*</span>
                    </label>
                    <input asp-for="Fecha" type="date"
                           class="form-control"
                           id="inputFecha"
                           min="@periodoFechaInicio"
                           max="@periodoFechaFin" />
                    <div class="form-text" id="infoRangoFecha">
                        @if (!string.IsNullOrEmpty(periodoDescripcion))
                        {
                            <span class="text-success">
                                <i class="bi bi-calendar-check"></i>
                                Rango permitido: <strong>
                                @(string.IsNullOrEmpty(periodoFechaInicio) ? "" :
                                    DateTime.Parse(periodoFechaInicio).ToString("dd/MM/yyyy"))
                                al
                                @(string.IsNullOrEmpty(periodoFechaFin) ? "" :
                                    DateTime.Parse(periodoFechaFin).ToString("dd/MM/yyyy"))
                            </strong>
                        </span>
                    }
                        else
                    {
                        <span class="text-muted">Seleccioná un período primero.</span>
                    }
                </div>
                <span asp-validation-for="Fecha" class="text-danger small"></span>
            </div>

            @* ── Buscador de empleado ── *@
            <div class="col-12">
                <label class="form-label fw-bold">
                    <i class="bi bi-person-search"></i> Empleado
                    <span class="text-danger">*</span>
                </label>
                <input type="hidden" asp-for="EmpleadoId" id="EmpleadoId" />
                <div class="input-group mb-1">
                    <span class="input-group-text bg-white">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input type="text" id="buscarEmpleado"
                           class="form-control border-start-0"
                           placeholder="Buscar por nombre, apellido o cédula..."
                           autocomplete="off" />
                    <button type="button" class="btn btn-outline-secondary"
                            id="btnMostrarTodos" title="Mostrar todos los empleados">
                        <i class="bi bi-list-ul"></i> Todos
                    </button>
                </div>

                @* Empleado seleccionado *@
                <div id="empleadoSeleccionado" class="d-none">
                    <div class="alert alert-success py-2 d-flex justify-content-between align-items-center">
                        <div>
                            <i class="bi bi-person-check-fill"></i>
                            <strong id="empNombre"></strong>
                            <span class="text-muted ms-2 small" id="empCedula"></span>
                            <span class="badge bg-secondary ms-1" id="empPuesto"></span>
                        </div>
                        <div class="text-end d-flex align-items-center gap-3">
                            <div>
                                <div class="fw-bold" id="empSalario" style="font-size:0.95rem;"></div>
                                <div class="text-muted" style="font-size:0.72rem;">Salario Base</div>
                            </div>
                            <div>
                                <div class="fw-bold" id="empValorHora" style="font-size:0.95rem;"></div>
                                <div class="text-muted" style="font-size:0.72rem;">Valor Hora</div>
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-danger"
                                    id="btnLimpiarEmpleado">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                    </div>
                </div>

                @* Resultados *@
                <div id="resultadosBusqueda" class="border rounded shadow-sm"
                     style="display:none;max-height:280px;overflow-y:auto;
                    background:#fff;z-index:100;position:relative;">
                </div>
                <span asp-validation-for="EmpleadoId" class="text-danger small"></span>
            </div>

            @* ── Tipo de hora extra ── *@
            <div class="col-md-4">
                <label asp-for="Porcentaje" class="form-label fw-bold">
                    <i class="bi bi-percent"></i> Tipo de Hora Extra
                    <span class="text-danger">*</span>
                </label>
                <select asp-for="Porcentaje" class="form-select"
                        id="selectPorcentaje">
                    <option value="1.5">150% — Hora Extra Normal</option>
                    <option value="2.0">200% — Hora Extra Doble</option>
                </select>
                <span asp-validation-for="Porcentaje" class="text-danger small"></span>
            </div>

            @* ── Total horas ── *@
            <div class="col-md-4">
                <label asp-for="TotalHoras" class="form-label fw-bold">
                    <i class="bi bi-hourglass-split"></i> Total Horas
                    <span class="text-danger">*</span>
                </label>
                <input asp-for="TotalHoras" type="number" step="0.5"
                       min="0.5" max="999.99"
                       class="form-control"
                       id="inputHoras" placeholder="Ej: 12" />
                <div id="advertenciaHoras" class="form-text text-warning d-none">
                    <i class="bi bi-exclamation-triangle"></i>
                    Supera el límite recomendado de 48 hrs.
                </div>
                <span asp-validation-for="TotalHoras" class="text-danger small"></span>
            </div>

            @* ── Monto estimado ── *@
            <div class="col-md-4">
                <label class="form-label fw-bold text-muted">
                    <i class="bi bi-calculator"></i> Monto Estimado
                </label>
                <div class="form-control bg-light text-center fw-bold text-success"
                     id="montoRef">
                    —
                </div>
                <div class="form-text text-muted" id="valorHoraRef"></div>
            </div>

        </div>

        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-success btn px-5"
                    id="btnGuardar" disabled>
                <i class="bi bi-check-circle"></i> Registrar
            </button>
            <a asp-action="Index" asp-route-periodoId="@Model.PeriodoPagoId"
               class="btn btn-secondary btn px-5">Cancelar</a>
        </div>

    </form>
</div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        var empleadoActual = null;
        window._empResults = [];

        // ── Período → actualizar rango de fecha ───────────────────────────────
        document.getElementById('selectPeriodo').addEventListener('change', function() {
            var pid = this.value;
            var inputFecha = document.getElementById('inputFecha');
            var infoRango = document.getElementById('infoRangoFecha');
            if (!pid) {
                inputFecha.min = '';
                inputFecha.max = '@DateTime.Today.ToString("yyyy-MM-dd")';
                inputFecha.value = '';
                infoRango.innerHTML =
                    '<span class="text-muted">Seleccioná un período primero.</span>';
                limpiarEmpleado();
                return;
            }
            fetch('/HorasExtras/ObtenerRangoPeriodo?periodoId=' + pid)
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data.ok) {
                        inputFecha.min = data.fechaInicio;
                        inputFecha.max = data.fechaFin;
                        inputFecha.value = data.fechaInicio;
                        var fi = data.fechaInicio.split('-').reverse().join('/');
                        var ff = data.fechaFin.split('-').reverse().join('/');
                        infoRango.innerHTML =
                            '<span class="text-success">'
                            + '<i class="bi bi-calendar-check"></i> '
                            + 'Rango permitido: <strong>' + fi + ' al ' + ff + '</strong>'
                            + '</span>';
                    }
                })
                .catch(function(e) { console.error('Error rango período:', e); });
            limpiarEmpleado();
        });

        // Rango inicial si hay período preseleccionado
        (function() {
            var fi = '@periodoFechaInicio';
            var ff = '@periodoFechaFin';
            if (fi && ff) {
                document.getElementById('inputFecha').min = fi;
                document.getElementById('inputFecha').max = ff;
            }
        })();

        // ── Buscador de empleados ─────────────────────────────────────────────
        function buscarEmpleados(termino, mostrarTodos) {
            mostrarTodos = mostrarTodos || false;
            var pid = document.getElementById('selectPeriodo').value || '';
            var url = mostrarTodos
                ? '/HorasExtras/TodosLosEmpleados?periodoId=' + pid
                : '/HorasExtras/BuscarEmpleados?termino='
                + encodeURIComponent(termino) + '&periodoId=' + pid;

            fetch(url)
                .then(function(r) { return r.json(); })
                .then(function(empleados) {
                    var div = document.getElementById('resultadosBusqueda');
                    if (!empleados || !empleados.length) {
                        div.innerHTML =
                            '<div class="p-3 text-muted small text-center">'
                            + 'No se encontraron empleados.</div>';
                        div.style.display = 'block';
                        return;
                    }
                    window._empResults = empleados;
                    div.innerHTML = empleados.map(function(e, i) {
                        var vh = e.valorHora || 0;
                        var sb = e.salarioBase || 0;
                        var vhTexto = vh > 0
                            ? '₡' + vh.toLocaleString('es-CR',
                                { minimumFractionDigits: 2 }) + '/hr'
                            : '—';
                        var sbTexto = sb > 0
                            ? '₡' + sb.toLocaleString('es-CR',
                                { minimumFractionDigits: 0 })
                            : '';
                        return '<div class="p-2 border-bottom emp-item"'
                            + ' data-index="' + i + '"'
                            + ' style="cursor:pointer;background:#fff;">'
                            + '<div class="fw-bold small">' + e.nombre + '</div>'
                            + '<div class="text-muted" style="font-size:0.78rem;">'
                            + e.cedula + ' — ' + e.puesto
                            + ' <span class="badge bg-light text-secondary">'
                            + (e.tipoPago || '') + '</span>'
                            + '<span class="float-end">'
                            + (sbTexto ? '<span class="text-dark fw-bold">' + sbTexto + '</span> · ' : '')
                            + '<span class="fw-bold">' + vhTexto + '</span>'
                            + '</span>'
                            + '</div></div>';
                    }).join('');
                    div.querySelectorAll('.emp-item').forEach(function(el) {
                        el.addEventListener('mouseenter', function() {
                            this.style.background = '#f8f8f8';
                        });
                        el.addEventListener('mouseleave', function() {
                            this.style.background = '#fff';
                        });
                        el.addEventListener('click', function() {
                            var idx = parseInt(this.getAttribute('data-index'));
                            var emp = window._empResults[idx];
                            if (emp) seleccionarEmpleado(
                                emp.id, emp.nombre, emp.cedula,
                                emp.puesto, emp.valorHora || 0,
                                emp.salarioBase || 0);
                        });
                    });
                    div.style.display = 'block';
                })
                .catch(function(err) {
                    console.error('Error al buscar empleados:', err);
                });
        }

        function seleccionarEmpleado(id, nombre, cedula, puesto, valorHora, salarioBase) {
            valorHora = valorHora || 0;
            salarioBase = salarioBase || 0;
            empleadoActual = { id: id, nombre: nombre, cedula: cedula,
                puesto: puesto, valorHora: valorHora, salarioBase: salarioBase };
            document.getElementById('EmpleadoId').value = id;
            document.getElementById('empNombre').textContent = nombre;
            document.getElementById('empCedula').textContent = cedula;
            document.getElementById('empPuesto').textContent = puesto;
            document.getElementById('empSalario').textContent = salarioBase > 0
                ? '₡' + salarioBase.toLocaleString('es-CR',
                    { minimumFractionDigits: 0 })
                : '—';
            document.getElementById('empValorHora').textContent = valorHora > 0
                ? '₡' + valorHora.toLocaleString('es-CR',
                    { minimumFractionDigits: 2 }) + '/hr'
                : '—';
            document.getElementById('empleadoSeleccionado').classList.remove('d-none');
            document.getElementById('resultadosBusqueda').style.display = 'none';
            document.getElementById('buscarEmpleado').value = '';
            document.getElementById('btnGuardar').disabled = false;
            calcularMonto();
        }

        function limpiarEmpleado() {
            empleadoActual = null;
            window._empResults = [];
            document.getElementById('EmpleadoId').value = '';
            document.getElementById('empleadoSeleccionado').classList.add('d-none');
            document.getElementById('buscarEmpleado').value = '';
            document.getElementById('montoRef').textContent = '—';
            document.getElementById('valorHoraRef').textContent = '';
            document.getElementById('btnGuardar').disabled = true;
            document.getElementById('resultadosBusqueda').style.display = 'none';
        }

        document.getElementById('btnLimpiarEmpleado')
            .addEventListener('click', limpiarEmpleado);

        var timerBusqueda;
        document.getElementById('buscarEmpleado').addEventListener('input', function() {
            clearTimeout(timerBusqueda);
            var val = this.value.trim();
            if (val.length < 2) {
                document.getElementById('resultadosBusqueda').style.display = 'none';
                return;
            }
            timerBusqueda = setTimeout(function() {
                buscarEmpleados(val, false);
            }, 300);
        });

        document.getElementById('btnMostrarTodos').addEventListener('click', function() {
            buscarEmpleados('', true);
        });

        document.addEventListener('click', function(e) {
            if (!e.target.closest('#resultadosBusqueda') &&
                !e.target.closest('#buscarEmpleado') &&
                !e.target.closest('#btnMostrarTodos'))
                document.getElementById('resultadosBusqueda').style.display = 'none';
        });

        // ── Calcular monto ────────────────────────────────────────────────────
        function calcularMonto() {
            var empleadoId = parseInt(document.getElementById('EmpleadoId').value) || 0;
            var horas = parseFloat(document.getElementById('inputHoras').value) || 0;
            var porcentaje = parseFloat(
                document.getElementById('selectPorcentaje').value) || 1.5;
            var montoRef = document.getElementById('montoRef');
            var vhRef = document.getElementById('valorHoraRef');
            var advHoras = document.getElementById('advertenciaHoras');

            if (empleadoId <= 0 || horas <= 0) {
                montoRef.textContent = '—';
                vhRef.textContent = '';
                return;
            }

            fetch('/HorasExtras/CalcularMonto?empleadoId=' + empleadoId
                + '&horas=' + horas + '&porcentaje=' + porcentaje)
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data.monto > 0) {
                        montoRef.textContent = '₡' + data.monto.toLocaleString(
                            'es-CR', { minimumFractionDigits: 2 });
                        vhRef.innerHTML =
                            '<i class="bi bi-info-circle text-muted"></i> '
                            + 'Valor hora: <strong>₡'
                            + data.valorHora.toLocaleString('es-CR',
                                { minimumFractionDigits: 2 })
                            + '</strong> x ' + horas + ' hrs x '
                            + (porcentaje * 100).toFixed(0) + '%';
                        advHoras.classList.toggle('d-none', !data.advertencia);
                    } else {
                        montoRef.textContent = '—';
                        vhRef.textContent = '';
                    }
                })
                .catch(function(e) { console.error('Error calcular monto:', e); });
        }

        document.getElementById('inputHoras')
            .addEventListener('input', calcularMonto);
        document.getElementById('selectPorcentaje')
            .addEventListener('change', calcularMonto);

        if (parseInt(document.getElementById('EmpleadoId').value) > 0)
            document.getElementById('btnGuardar').disabled = false;
    </script>
}