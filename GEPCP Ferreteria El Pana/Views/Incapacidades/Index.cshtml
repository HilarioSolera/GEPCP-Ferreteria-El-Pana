@model List<GEPCP_Ferreteria_El_Pana.Models.Incapacidad>
@{
    ViewData["Title"] = "Incapacidades - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Corrección del error de null reference
    bool verTodos = ViewBag.VerTodos != null && (bool)ViewBag.VerTodos;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-hospital"></i> Control de Incapacidades</h2>
    <a asp-action="Create" class="btn btn-success btn">
        <i class="bi bi-plus-circle"></i> Nueva Incapacidad
    </a>
</div>

<!-- KPIs -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-primary">@(ViewBag.TotalRegistros ?? 0)</div>
            <div class="text-muted small">Total Registros</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-info">@(ViewBag.TotalDias ?? 0)</div>
            <div class="text-muted small">Total Días</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-warning">₡@(ViewBag.TotalMonto?.ToString("N0") ?? "0")</div>
            <div class="text-muted small">Monto Total</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-danger">₡@(ViewBag.TotalPatrono?.ToString("N0") ?? "0")</div>
            <div class="text-muted small">Costo Patrono</div>
        </div>
    </div>
</div>

<!-- Filtros -->
<form asp-action="Index" method="get" class="mb-4">
    <div class="row g-2">
        <div class="col-md-5">
            <div class="input-group shadow-sm">
                <span class="input-group-text bg-white">
                    <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" name="busqueda" value="@ViewBag.Busqueda"
                       class="form-control border-start-0"
                       placeholder="Nombre, cédula, tipo o tiquete..." />
            </div>
        </div>
        <div class="col-md-3">
            <select name="entidad" class="form-select shadow-sm">
                <option value="">Todas las entidades</option>
                <option value="CCSS" selected="@(ViewBag.EntidadFiltro == "CCSS")">CCSS</option>
                <option value="INS" selected="@(ViewBag.EntidadFiltro == "INS")">INS</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-funnel"></i> Filtrar
            </button>
        </div>
        <div class="col-md-2">
            @if (!verTodos)
            {
                <a asp-action="Index" asp-route-verTodos="true" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-list-ul"></i> Ver todos
                </a>
            }
            else
            {
                <a asp-action="Index" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-x-circle"></i> Volver
                </a>
            }
        </div>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info text-center py-5">
        <i class="bi bi-inbox fs-1 d-block mb-3"></i>
        No se encontraron incapacidades.<br>
        <small>Usa los filtros o presiona "Ver todos"</small>
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle mb-0">
            <thead style="background-color: #FF7A00; color: white;">
                <tr>
                    <th>Empleado</th>
                    <th>Entidad</th>
                    <th>Tipo</th>
                    <th>Período</th>
                    <th class="text-center">Días</th>
                    <th>Tiquete</th>
                    <th class="text-center">% Pago</th>
                    <th>Responsable</th>
                    <th class="text-end">Monto Total</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var i in Model)
                {
                    <tr>
                        <td>
                            <strong>@i.Empleado.PrimerApellido @i.Empleado.Nombre</strong>
                            <div class="small text-muted">@i.Empleado.Cedula</div>
                        </td>
                        <td>
                            <span class="badge @(i.Entidad == GEPCP_Ferreteria_El_Pana.Models.EntidadIncapacidad.CCSS ? "bg-primary" : "bg-warning text-dark")">
                                @i.Entidad
                            </span>
                        </td>
                        <td>@i.TipoIncapacidad</td>
                        <td>
                            <small>@i.FechaInicio.ToString("dd/MM/yyyy")</small><br>
                            <small class="text-muted">al @i.FechaFin.ToString("dd/MM/yyyy")</small>
                        </td>
                        <td class="text-center fw-bold">@i.TotalDias</td>
                        <td>@(string.IsNullOrEmpty(i.TiqueteCCSS) ? "—" : i.TiqueteCCSS)</td>
                        <td class="text-center">@i.PorcentajePago%</td>
                        <td>@i.ResponsablePago</td>
                        <td class="text-end fw-bold text-danger">₡@i.MontoTotal.ToString("N0")</td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">
                                <a asp-action="DescargarPDF" asp-route-id="@i.IncapacidadId"
                                       class="btn btn-sm btn-outline-danger long-action" data-loading-message="Generando PDF..." title="PDF">
                                                <i class="bi bi-file-earmark-pdf"></i>
                                            </a>
                                            @if (!string.IsNullOrEmpty(i.Empleado.CorreoElectronico))
                                            {
                                                <form asp-action="EnviarPorEmail" method="post" class="d-inline form-loading" data-loading-message="Enviando correo...">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@i.IncapacidadId" />
                                                    <button type="submit" class="btn btn-sm btn-outline-success" title="Enviar correo">
                                                        <i class="bi bi-envelope"></i>
                                                    </button>
                                                </form>
                                            }
                                            <a asp-action="Edit" asp-route-id="@i.IncapacidadId"
                                                   class="btn btn-sm btn-warning" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <button type="button" class="btn btn-sm btn-danger btnEliminarIncapacidad"
                                                    data-id="@i.IncapacidadId"
                                                    data-empleado="@i.Empleado.PrimerApellido"
                                                    title="Eliminar">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                    </tr>
                                 }
                             </tbody>
                         </table>
                     </div>
                }

                <!-- Modal Eliminar Incapacidad -->
                <div class="modal fade" id="confirmEliminarIncapacidadModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content" style="background-color: #ffffff; border: 2px solid #FF7A00;">
                            <div class="modal-header" style="background-color: #FF7A00; border-bottom: 2px solid #FF7A00;">
                                <h5 class="modal-title text-white fw-bold">
                                    <i class="bi bi-exclamation-triangle"></i> Eliminar Incapacidad
                                </h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body" style="padding: 24px;">
                                <div style="background-color: #FFF5EB; border-left: 4px solid #FF7A00; padding: 16px; margin-bottom: 16px; border-radius: 6px;">
                                    <div style="color: #333; font-weight: 600;">
                                        <i class="bi bi-exclamation-triangle-fill" style="color: #FF7A00; margin-right: 8px;"></i>
                                        ¿Eliminar esta incapacidad de <span id="modalIncapacidadEmpleado"></span>?
                                    </div>
                                </div>

                                <div style="background-color: #F8F8F8; border: 1px solid #E0E0E0; border-radius: 6px; padding: 12px;">
                                    <p style="color: #888; font-size: 0.85rem; margin-bottom: 0;">
                                        <i class="bi bi-info-circle" style="color: #FF7A00; margin-right: 6px;"></i>
                                        Esta operación no se puede deshacer.
                                    </p>
                                </div>
                            </div>
                            <div class="modal-footer" style="border-top: 1px solid #E0E0E0; padding: 12px 16px;">
                                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                                    <i class="bi bi-x-circle"></i> Cancelar
                                </button>
                                <button type="button" class="btn text-white fw-bold" style="background-color: #FF7A00; border-color: #FF7A00;" id="btnConfirmarEliminarIncapacidad">
                                    <i class="bi bi-check-circle"></i> Sí, Eliminar
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Formulario oculto -->
                <form method="post" asp-action="Delete" style="display:none;" id="formEliminarIncapacidad">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="inputIdIncapacidad" />
                </form>

                <script>
                    document.addEventListener('DOMContentLoaded', function() {
                        const botonesEliminar = document.querySelectorAll('.btnEliminarIncapacidad');
                        const modalEliminar = new bootstrap.Modal(document.getElementById('confirmEliminarIncapacidadModal'), {
                            backdrop: 'static',
                            keyboard: false
                        });
                        const btnConfirmar = document.getElementById('btnConfirmarEliminarIncapacidad');
                        const formEliminar = document.getElementById('formEliminarIncapacidad');
                        const inputId = document.getElementById('inputIdIncapacidad');

                        botonesEliminar.forEach(function(btn) {
                            btn.addEventListener('click', function() {
                                document.getElementById('modalIncapacidadEmpleado').textContent = this.dataset.empleado;
                                inputId.value = this.dataset.id;
                                modalEliminar.show();
                            });
                        });

                        btnConfirmar.addEventListener('click', function() {
                            modalEliminar.hide();
                            Loading.show('Eliminando incapacidad...');
                            setTimeout(function() {
                                formEliminar.submit();
                            }, 100);
                        });
                    });
                </script>