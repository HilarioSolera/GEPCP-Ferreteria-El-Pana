@model GEPCP_Ferreteria_El_Pana.Models.EmpleadoViewModel
@{
    ViewData["Title"] = "Nuevo Empleado - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-person-plus"></i> Nuevo Empleado</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <form asp-action="Create" method="post" id="formEmpleado">
            @Html.AntiForgeryToken()
            <div class="row g-3">

                <div class="col-md-4">
                    <label asp-for="Cedula" class="form-label fw-bold">
                        <i class="bi bi-card-text"></i> Cédula <span class="text-danger">*</span>
                    </label>
                    <input asp-for="Cedula" class="form-control form-control-lg"
                           maxlength="20" placeholder="Ej: 1-1234-5678"
                           autocomplete="off" />
                    <span asp-validation-for="Cedula" class="text-danger small"></span>
                </div>

                <div class="col-md-8">
                    <label asp-for="Nombre" class="form-label fw-bold">
                        <i class="bi bi-person"></i> Nombre <span class="text-danger">*</span>
                    </label>
                    <input asp-for="Nombre" class="form-control form-control-lg"
                           maxlength="100" placeholder="Ej: Juan" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="PrimerApellido" class="form-label fw-bold">
                        <i class="bi bi-person"></i> Primer Apellido <span class="text-danger">*</span>
                    </label>
                    <input asp-for="PrimerApellido" class="form-control form-control-lg"
                           maxlength="50" placeholder="Ej: Pérez" />
                    <span asp-validation-for="PrimerApellido" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="SegundoApellido" class="form-label fw-bold">
                        <i class="bi bi-person"></i> Segundo Apellido
                        <span class="text-muted fw-normal small">(opcional)</span>
                    </label>
                    <input asp-for="SegundoApellido" class="form-control form-control-lg"
                           maxlength="50" placeholder="Ej: González" />
                    <span asp-validation-for="SegundoApellido" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Puesto" class="form-label fw-bold">
                        <i class="bi bi-briefcase"></i> Puesto <span class="text-danger">*</span>
                    </label>
                    <select asp-for="Puesto" class="form-select form-select-lg"
                            asp-items="ViewBag.Puestos" id="selectPuesto">
                        <option value="">-- Seleccione un puesto --</option>
                    </select>
                    <span asp-validation-for="Puesto" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="SalarioBase" class="form-label fw-bold">
                        <i class="bi bi-currency-dollar"></i> Salario Base (₡) <span class="text-danger">*</span>
                    </label>
                    <input asp-for="SalarioBase" type="number" step="0.01" min="0" max="9999999.99"
                           class="form-control form-control-lg" id="inputSalario"
                           placeholder="Se llena automáticamente al elegir puesto" />
                    <div class="form-text text-muted" id="salarioHint"></div>
                    <span asp-validation-for="SalarioBase" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Telefono" class="form-label fw-bold">
                        <i class="bi bi-phone"></i> Teléfono / Celular
                        <span class="text-muted fw-normal small">(opcional)</span>
                    </label>
                    <input asp-for="Telefono" class="form-control form-control-lg"
                           maxlength="20" placeholder="Ej: 8888-8888" />
                    <span asp-validation-for="Telefono" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="CorreoElectronico" class="form-label fw-bold">
                        <i class="bi bi-envelope"></i> Correo Electrónico
                        <span class="text-muted fw-normal small">(opcional)</span>
                    </label>
                    <input asp-for="CorreoElectronico" type="email"
                           class="form-control form-control-lg"
                           maxlength="150" placeholder="Ej: empleado@correo.com" />
                    <span asp-validation-for="CorreoElectronico" class="text-danger small"></span>
                </div>

            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-success btn-lg px-5">
                    <i class="bi bi-check-circle"></i> Guardar Empleado
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-lg px-5">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Auto-completar salario al seleccionar puesto
        document.getElementById('selectPuesto').addEventListener('change', async function () {
            const puesto = this.value;
            const inputSalario = document.getElementById('inputSalario');
            const hint = document.getElementById('salarioHint');

            if (!puesto) {
                hint.textContent = '';
                return;
            }

            try {
                const response = await fetch(`/Empleados/ObtenerSalarioPuesto?nombre=${encodeURIComponent(puesto)}`);
                const data = await response.json();

                if (data.salario !== null) {
                    inputSalario.value = data.salario;
                    hint.innerHTML = `<i class="bi bi-info-circle"></i> Salario base del puesto: <strong>₡${Number(data.salario).toLocaleString('es-CR')}</strong>. Podés modificarlo.`;
                    hint.className = 'form-text text-success';
                }
            } catch (e) {
                console.error('Error al obtener salario:', e);
            }
        });
    </script>
}