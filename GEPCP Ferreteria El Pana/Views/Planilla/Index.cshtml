@model List<GEPCP_Ferreteria_El_Pana.Models.PlanillaEmpleado>

@{
    ViewData["Title"] = "Planilla - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var rol = Context.Session.GetString("Rol");
    var periodos = ViewBag.Periodos as List<GEPCP_Ferreteria_El_Pana.Models.PeriodoPago>;
    var periodo = ViewBag.Periodo as GEPCP_Ferreteria_El_Pana.Models.PeriodoPago;
    var periodoCerrado = periodo?.Estado == GEPCP_Ferreteria_El_Pana.Models.EstadoPeriodo.Cerrado;
    int? periodoId = ViewBag.PeriodoId;
    string ordenActual = ViewBag.Orden as string ?? "departamento";

    var totalEmpleados = (int)(ViewBag.TotalEmpleados ?? 0);
    var totalDevengado = (decimal)(ViewBag.TotalDevengado ?? 0m);
    var totalDeducciones = (decimal)(ViewBag.TotalDeducciones ?? 0m);
    var totalNeto = (decimal)(ViewBag.TotalNeto ?? 0m);
}

@* Selector de período *@
@if (periodos == null || !periodos.Any())
{
    <div class="text-center py-5">
        <div class="alert alert-warning d-inline-block px-5 py-4 shadow-sm" style="max-width:520px;">
            <i class="bi bi-calendar-x fs-1 text-warning d-block mb-3"></i>
            <h5 class="fw-bold mb-2">No hay períodos de pago creados</h5>
            <p class="text-muted mb-3">
                Para poder calcular y gestionar la planilla, primero debes crear al menos un período de pago.
            </p>
            <a asp-controller="PeriodosPago" asp-action="Create" class="btn btn-success px-4">
                <i class="bi bi-plus-circle"></i> Crear Período de Pago
            </a>
        </div>
    </div>
}
else
{
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-2 align-items-end">
            <div class="col-md-6">
                <label class="form-label fw-bold">
                    <i class="bi bi-calendar-range"></i> Seleccionar Período
                </label>
                <select name="periodoId" class="form-select"
                        onchange="this.form.submit()">
                    <option value="">-- Seleccioná un período --</option>
                    @if (periodos != null)
                    {
                        @foreach (var p in periodos)
                        {
                            <option value="@p.PeriodoPagoId"
                                    selected="@(p.PeriodoPagoId == periodoId ? "selected" : null)">
                                @p.Descripcion
                                @if (p.Estado == GEPCP_Ferreteria_El_Pana.Models.EstadoPeriodo.Cerrado)
                                {
                                    <text> — Cerrado</text>
                                }
                                else if (p.Estado == GEPCP_Ferreteria_El_Pana.Models.EstadoPeriodo.Abierto)
                                {
                                    <text> — Abierto</text>
                                }
                            </option>
                        }
                    }
                </select>
            </div>
            @if (periodoId.HasValue && Model.Any())
            {
                <div class="col-md-4">
                    <label class="form-label fw-bold">
                        <i class="bi bi-sort-down"></i> Ordenar Por
                    </label>
                    <select name="orden" class="form-select" onchange="this.form.submit()">
                        <option value="departamento" selected="@(ordenActual == "departamento")">Departamento + Apellido</option>
                        <option value="alfabetico" selected="@(ordenActual == "alfabetico")">Alfabético (Apellido)</option>
                        <option value="salario" selected="@(ordenActual == "salario")">Salario Bruto (Mayor → Menor)</option>
                        <option value="neto" selected="@(ordenActual == "neto")">Neto a Pagar (Mayor → Menor)</option>
                        <option value="puesto" selected="@(ordenActual == "puesto")">Puesto + Apellido</option>
                        <option value="antiguedad" selected="@(ordenActual == "antiguedad")">Antigüedad (Mayor → Menor)</option>
                    </select>
                </div>
            }
        </form>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">
        <i class="bi bi-file-earmark-text"></i>
        Planilla @(periodo?.TipoPeriodo.ToString() ?? "")
    </h2>

    @if (rol == "RRHH" && periodo != null)
    {
        <div class="d-flex gap-2">
            @if (!periodoCerrado)
            {
                <form asp-action="Calcular" method="post" class="form-loading" data-loading-message="Calculando planilla para todos los empleados..." data-skip-beforeunload="true" id="formCalcular">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="periodoId" value="@periodo.PeriodoPagoId" />
                    <button type="button" class="btn btn-sm" id="btnCalcular" style="background-color: #FF7A00; color: white; border-color: #FF7A00;">
                        <i class="bi bi-calculator"></i> Calcular Planilla
                    </button>
                </form>

                @if (Model.Any())
                {
                    <form asp-action="CerrarPeriodo" method="post" class="form-loading" data-loading-message="Cerrando período..." id="formCerrarPeriodo">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="periodoId" value="@periodo.PeriodoPagoId" />
                        <button type="button" class="btn btn-danger btn-sm" id="btnCerrarPeriodo">
                            <i class="bi bi-lock"></i> Cerrar Período
                        </button>
                    </form>
                }
            }
            @if (periodoCerrado)
            {
                <form asp-action="ReabrirPeriodo" method="post" class="form-loading" data-loading-message="Reabriendo período..." id="formReabrir">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="periodoId" value="@periodo.PeriodoPagoId" />
                    <button type="submit" class="btn btn-warning btn-sm">
                        <i class="bi bi-unlock"></i> Reabrir Período
                    </button>
                </form>
            }
        </div>
    }

</div>

<!-- KPIs -->
@if (Model.Any())
{
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body py-3">
                    <h3 class="mb-0">@totalEmpleados</h3>
                    <small class="text-muted">EMPLEADOS</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm border-success">
                <div class="card-body py-3">
                    <h5 class="mb-0 text-success">₡@totalDevengado.ToString("N0")</h5>
                    <small class="text-muted">DEVENGADO</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm border-danger">
                <div class="card-body py-3">
                    <h5 class="mb-0 text-danger">₡@totalDeducciones.ToString("N0")</h5>
                    <small class="text-muted">DEDUCCIONES</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm border-warning">
                <div class="card-body py-3">
                    <h5 class="mb-0 text-warning">₡@totalNeto.ToString("N0")</h5>
                    <small class="text-muted">NETO A PAGAR</small>
                </div>
            </div>
        </div>
    </div>

    @* Indicador de ordenamiento actual *@
    <div class="alert alert-info py-2 px-3 d-flex align-items-center mb-3" style="font-size: 0.85rem;">
        <i class="bi bi-info-circle me-2"></i>
        <span>
            <strong>Ordenado por:</strong>
            @switch (ordenActual)
            {
                case "alfabetico":
                    <text>Alfabético (Apellido → Nombre)</text>
                    break;
                case "salario":
                    <text>Salario Bruto Mensual (Mayor → Menor)</text>
                    break;
                case "neto":
                    <text>Neto a Pagar (Mayor → Menor)</text>
                    break;
                case "puesto":
                    <text>Puesto + Apellido</text>
                    break;
                case "antiguedad":
                    <text>Antigüedad (Empleados más antiguos primero)</text>
                    break;
                default:
                    <text>Departamento + Apellido</text>
                    break;
            }
        </span>
    </div>

    <div class="d-flex gap-2 mb-3">
        <a asp-action="ExportarExcel" asp-route-periodoId="@periodo!.PeriodoPagoId" class="btn btn-dark long-action" data-loading-message="Exportando Excel...">
            <i class="bi bi-file-earmark-excel"></i> Excel
        </a>
        <a asp-action="ExportarPDF" asp-route-periodoId="@periodo!.PeriodoPagoId" class="btn btn-dark long-action" data-loading-message="Generando PDF general...">
            <i class="bi bi-file-earmark-pdf"></i> PDF General
        </a>
        <form asp-action="EnviarTodosPorEmail" method="post" class="d-inline form-loading" data-loading-message="Enviando boletas a todos los empleados..." id="formEnviarTodos">
            @Html.AntiForgeryToken()
            <input type="hidden" name="periodoId" value="@periodo.PeriodoPagoId" />
            <button type="button" class="btn btn-dark" id="btnEnviarTodos">
                <i class="bi bi-envelope-fill"></i> Enviar Boletas a Todos
            </button>
        </form>
    </div>
}

<!-- Modal de Confirmación - Enviar Boletas -->
<div class="modal fade" id="confirmEnvioModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title">Confirmar Envío</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>¿Enviar el comprobante de pago por correo a <strong>todos los empleados</strong>?</p>
                <p class="text-muted small">Este proceso puede tomar algunos minutos.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-warning" id="btnConfirmarEnvio">Sí, Enviar Ahora</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal de Confirmación - Calcular Planilla -->
<div class="modal fade" id="confirmCalcularModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background-color: #ffffff; border: 2px solid #FF7A00;">
            <div class="modal-header" style="background-color: #FF7A00; border-bottom: 2px solid #FF7A00;">
                <h5 class="modal-title text-white fw-bold">
                    <i class="bi bi-calculator"></i> Recalcular Planilla
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                                <p style="color: #333;">¿Recalcular la planilla para <strong>todos los empleados</strong>?</p>
                                <p class="text-muted small">Los cálculos anteriores serán reemplazados.</p>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                                <button type="button" class="btn text-white fw-bold" style="background-color: #FF7A00; border-color: #FF7A00;" id="btnConfirmarCalcular">Sí, Recalcular</button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Modal de Confirmación - Cerrar Período -->
<div class="modal fade" id="confirmCerrarPeriodoModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background-color: #ffffff; border: 2px solid #FF7A00;">
            <div class="modal-header" style="background-color: #FF7A00; border-bottom: 2px solid #FF7A00;">
                <h5 class="modal-title text-white fw-bold">
                    <i class="bi bi-lock"></i> Cerrar Período
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding: 24px;">
                <div style="background-color: #FFF5EB; border-left: 4px solid #FF7A00; padding: 16px; margin-bottom: 16px; border-radius: 6px;">
                    <div style="color: #333; font-weight: 600; margin-bottom: 8px;">
                        <i class="bi bi-exclamation-triangle-fill" style="color: #FF7A00; margin-right: 8px;"></i>
                        Esta acción es IRREVERSIBLE
                    </div>
                    <p style="color: #555; margin: 0; font-size: 0.9rem;">
                        Los períodos cerrados son inmutables. No podrás hacer cambios posteriores.
                    </p>
                </div>

                <p style="color: #333; margin-bottom: 12px;">¿Cerrar el período?</p>

                <div style="background-color: #F8F8F8; border: 1px solid #E0E0E0; border-radius: 6px; padding: 12px; margin-bottom: 16px;">
                    <div style="font-size: 0.9rem; color: #666;">
                        <strong style="color: #333;">@periodo.Descripcion</strong>
                        <br />
                        <span style="color: #888;">@periodo.FechaInicio.ToString("dd/MM/yyyy") — @periodo.FechaFin.ToString("dd/MM/yyyy")</span>
                    </div>
                </div>

                <p style="color: #555; font-size: 0.9rem; margin-bottom: 0;">
                    <i class="bi bi-info-circle" style="color: #FF7A00; margin-right: 6px;"></i>
                    Esta acción consolida los registros.
                </p>
            </div>
            <div class="modal-footer" style="border-top: 1px solid #E0E0E0; padding: 12px 16px;">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle"></i> Cancelar
                </button>
                <button type="button" class="btn text-white fw-bold" style="background-color: #FF7A00; border-color: #FF7A00;" id="btnConfirmarCerrarPeriodo">
                    <i class="bi bi-check-circle"></i> Sí, Cerrar Período
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // ===== ENVIAR BOLETAS =====
        const btnEnviarTodos = document.getElementById('btnEnviarTodos');
        const btnConfirmarEnvio = document.getElementById('btnConfirmarEnvio');
        const formEnviarTodos = document.getElementById('formEnviarTodos');
        const modalEnvio = new bootstrap.Modal(document.getElementById('confirmEnvioModal'));

        if (btnEnviarTodos) {
            btnEnviarTodos.addEventListener('click', function(e) {
                e.preventDefault();
                modalEnvio.show();
            });
        }

        if (btnConfirmarEnvio) {
            btnConfirmarEnvio.addEventListener('click', function() {
                modalEnvio.hide();
                Loading.show('Enviando boletas a todos los empleados...');
                setTimeout(function() {
                    formEnviarTodos.submit();
                }, 200);
            });
        }

        // ===== CALCULAR PLANILLA =====
        const btnCalcular = document.getElementById('btnCalcular');
        const btnConfirmarCalcular = document.getElementById('btnConfirmarCalcular');
        const formCalcular = document.getElementById('formCalcular');
        const modalCalcular = new bootstrap.Modal(document.getElementById('confirmCalcularModal'));

        if (btnCalcular) {
            btnCalcular.addEventListener('click', function(e) {
                e.preventDefault();
                modalCalcular.show();
            });
        }

        if (btnConfirmarCalcular) {
            btnConfirmarCalcular.addEventListener('click', function() {
                modalCalcular.hide();
                Loading.show('Calculando planilla para todos los empleados...');
                setTimeout(function() {
                    formCalcular.submit();
                }, 200);
            });
        }

        // ===== CERRAR PERÍODO =====
        const btnCerrarPeriodo = document.getElementById('btnCerrarPeriodo');
        const btnConfirmarCerrarPeriodo = document.getElementById('btnConfirmarCerrarPeriodo');
        const formCerrarPeriodo = document.getElementById('formCerrarPeriodo');
        const modalCerrarPeriodo = new bootstrap.Modal(document.getElementById('confirmCerrarPeriodoModal'));

        if (btnCerrarPeriodo) {
            btnCerrarPeriodo.addEventListener('click', function(e) {
                e.preventDefault();
                modalCerrarPeriodo.show();
            });
        }

        if (btnConfirmarCerrarPeriodo) {
            btnConfirmarCerrarPeriodo.addEventListener('click', function() {
                modalCerrarPeriodo.hide();
                Loading.show('Cerrando período...');
                setTimeout(function() {
                    formCerrarPeriodo.submit();
                }, 200);
            });
        }
    });
</script>

<!-- Tabla Única con Columna de Renta -->
@if (Model.Any())
{
    <!-- CSS mejorado para mejor legibilidad -->
    <style>
        .planilla-table {
            font-size: 0.875rem; /* Aumentado de 0.82rem */
            min-width: 1800px; /* Ancho mínimo para evitar que se aplaste */
        }
        .planilla-table th,
        .planilla-table td {
            padding: 0.75rem 0.5rem !important; /* Mejor espaciado vertical */
            white-space: nowrap;
        }
        .planilla-table .text-end {
            padding-right: 0.75rem !important;
        }
        .planilla-table thead th {
            font-size: 0.85rem;
            font-weight: 600;
            position: sticky;
            top: 0;
            z-index: 10;
        }
        .planilla-table tbody td {
            font-size: 0.875rem;
        }
        /* Mejorar visibilidad de números */
        .planilla-table .text-end {
            font-family: 'Courier New', monospace;
            font-weight: 500;
        }
        /* Separadores visuales */
        .planilla-table td:nth-child(3),
        .planilla-table td:nth-child(9),
        .planilla-table td:nth-child(16) {
            border-right: 2px solid #dee2e6;
        }
    </style>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 planilla-table">
                    <thead class="table-dark">
                        <tr>
                            <th rowspan="2" style="vertical-align:middle;">Empleado</th>
                            <th rowspan="2" class="text-end fw-bold" style="background:#e8f4fd; vertical-align:middle;">Salario Bruto Mensual</th>
                            <th rowspan="2" style="vertical-align:middle;">Departamento</th>

                            <!-- SECCIÓN DEVENGADOS -->
                            <th colspan="6" class="text-center" style="background:#d4edda; color:#155724; font-weight:bold; border-left:3px solid #28a745;">
                                <i class="bi bi-plus-circle"></i> DEVENGADOS
                            </th>

                            <!-- SECCIÓN DEDUCCIONES -->
                            <th colspan="7" class="text-center" style="background:#f8d7da; color:#721c24; font-weight:bold; border-left:3px solid #dc3545;">
                                <i class="bi bi-dash-circle"></i> DEDUCCIONES
                            </th>

                            <th rowspan="2" class="text-end fw-bold" style="background:#fff3cd; color:#856404; vertical-align:middle; border-left:3px solid #ffc107;">
                                <i class="bi bi-cash-coin"></i> Neto
                            </th>
                            <th rowspan="2" class="text-center" style="vertical-align:middle;">Acciones</th>
                        </tr>
                        <tr>
                            <!-- DETALLE DEVENGADOS -->
                            <th class="text-end" style="background:#e8f5e9; border-left:3px solid #28a745;">Sal. Ord.</th>
                            <th class="text-end" style="background:#e8f5e9;">H. Extra</th>
                            <th class="text-end" style="background:#e8f5e9;">Comisión</th>
                            <th class="text-end" style="background:#e8f5e9;">Feriados</th>
                            <th class="text-end fw-bold" style="background:#c8e6c9;">Total Dev.</th>

                            <!-- DETALLE DEDUCCIONES -->
                            <th class="text-end" style="background:#ffebee; border-left:3px solid #dc3545;">CCSS</th>
                            <th class="text-end" style="background:#ffebee;">Renta</th>
                            <th class="text-end" style="background:#ffebee;">Préstamos</th>
                            <th class="text-end" style="background:#ffebee;">Crédito</th>
                            <th class="text-end" style="background:#ffebee;">H.N/L</th>
                            <th class="text-end" style="background:#ffebee;" title="Deducción por días de incapacidad no trabajados">Incap.</th>
                            <th class="text-end" style="background:#ffebee;">Otras D.</th>
                            <th class="text-end fw-bold" style="background:#ffcdd2;">Total Ded.</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            IEnumerable<GEPCP_Ferreteria_El_Pana.Models.PlanillaEmpleado> planillasOrdenadas = ordenActual switch
                            {
                                "alfabetico" => Model.OrderBy(x => x.Empleado.PrimerApellido).ThenBy(x => x.Empleado.Nombre),
                                "salario" => Model.OrderByDescending(x => x.TotalDevengado * (periodo!.TipoPeriodo switch
                                {
                                    GEPCP_Ferreteria_El_Pana.Models.TipoPeriodo.Semanal => 52m / 12m,
                                    GEPCP_Ferreteria_El_Pana.Models.TipoPeriodo.Mensual => 1m,
                                    _ => 2m
                                })).ThenBy(x => x.Empleado.PrimerApellido),
                                "neto" => Model.OrderByDescending(x => x.NetoAPagar).ThenBy(x => x.Empleado.PrimerApellido),
                                "puesto" => Model.OrderBy(x => x.Empleado.Puesto).ThenBy(x => x.Empleado.PrimerApellido),
                                "antiguedad" => Model.OrderBy(x => x.Empleado.FechaIngreso).ThenBy(x => x.Empleado.PrimerApellido),
                                _ => Model.OrderBy(x => x.Empleado.Departamento).ThenBy(x => x.Empleado.PrimerApellido) // departamento por defecto
                            };
                        }
                        @foreach (var p in planillasOrdenadas)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold">@p.Empleado.PrimerApellido @p.Empleado.Nombre</div>
                                    <small class="text-muted">@p.Empleado.Puesto</small>
                                    @if (p.Empleado.FormaPago == GEPCP_Ferreteria_El_Pana.Models.FormaPago.Efectivo)
                                    {
                                        <span class="badge bg-secondary">Efectivo</span>
                                    }
                                    @{
                                        var diasPer = (periodo!.FechaFin - periodo.FechaInicio).Days + 1;
                                        var diasEf = p.DiasTrabajados > 0 ? p.DiasTrabajados : diasPer;
                                        var esParcialPer = diasEf < diasPer;
                                    }
                                    @if (esParcialPer)
                                    {
                                        <br /><span class="badge bg-warning text-dark" title="Ingresó a mitad del período: @p.Empleado.FechaIngreso.ToString("dd/MM/yyyy")">
                                            <i class="bi bi-clock-history"></i> @diasEf/@diasPer días
                                        </span>
                                    }
                                </td>
                                @{
                                    var factorMes = periodo!.TipoPeriodo switch
                                    {
                                        GEPCP_Ferreteria_El_Pana.Models.TipoPeriodo.Semanal => 52m / 12m,
                                        GEPCP_Ferreteria_El_Pana.Models.TipoPeriodo.Mensual => 1m,
                                        _ => 2m
                                    };
                                    var brutoMensual = p.TotalDevengado * factorMes;
                                }
                                <td class="text-end fw-bold" style="background:#e8f4fd; font-size:0.95rem;">₡@brutoMensual.ToString("N0")</td>
                                <td><strong>@p.Empleado.Departamento</strong></td>

                                <!-- ✅ DEVENGADOS - Fondo verde claro -->
                                <td class="text-end" style="background:#f1f8f4; border-left:3px solid #28a745;">@p.SalarioOrdinario.ToString("N0")</td>
                                <td class="text-end" style="background:#f1f8f4;">@(p.MontoHorasExtras > 0 ? p.MontoHorasExtras.ToString("N0") : "—")</td>
                                <td class="text-end" style="background:#f1f8f4;">@(p.AumentoAplicado > 0 ? p.AumentoAplicado.ToString("N0") : "—")</td>
                                <td class="text-end" style="background:#f1f8f4;">@(p.MontoFeriados > 0 ? p.MontoFeriados.ToString("N0") : "—")</td>
                                <td class="text-end fw-bold" style="background:#d4edda; color:#155724;">₡@p.TotalDevengado.ToString("N0")</td>

                                <!-- ❌ DEDUCCIONES - Fondo rojo claro -->
                                <td class="text-end" style="background:#fef5f5; border-left:3px solid #dc3545;">@p.DeduccionCCSS.ToString("N0")</td>
                                <td class="text-end text-danger" style="background:#fef5f5;">@(p.DeduccionRenta > 0 ? p.DeduccionRenta.ToString("N0") : "—")</td>
                                <td class="text-end" style="background:#fef5f5;">@(p.DeduccionPrestamos > 0 ? p.DeduccionPrestamos.ToString("N0") : "—")</td>
                                <td class="text-end" style="background:#fef5f5;">@(p.DeduccionCreditoFerreteria > 0 ? p.DeduccionCreditoFerreteria.ToString("N0") : "—")</td>
                                <td class="text-end" style="background:#fef5f5;">@(p.DeduccionHorasNoLaboradas > 0 ? p.DeduccionHorasNoLaboradas.ToString("N0") : "—")</td>
                                <td class="text-end text-danger" style="background:#fef5f5;">@(p.DeduccionIncapacidad > 0 ? p.DeduccionIncapacidad.ToString("N0") : "—")</td>
                                <td class="text-end" style="background:#fef5f5;" title="@p.DescripcionOtrasDeducciones">
                                    @(p.OtrasDeducciones > 0 ? p.OtrasDeducciones.ToString("N0") : "—")
                                </td>
                                <td class="text-end fw-bold" style="background:#f8d7da; color:#721c24;">₡@p.TotalDeducciones.ToString("N0")</td>

                                <!-- 💰 NETO - Fondo amarillo -->
                                <td class="text-end fw-bold" style="background:#fff3cd; font-size:1rem; color:#856404; border-left:3px solid #ffc107;">₡@p.NetoAPagar.ToString("N0")</td>

                                <!-- Acciones -->
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        @if (rol == "RRHH" && !periodoCerrado)
                                        {
                                            <a asp-action="Editar" asp-route-id="@p.PlanillaEmpleadoId" class="btn btn-outline-secondary" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        }
                                        <a asp-action="DescargarPDF" asp-route-id="@p.PlanillaEmpleadoId" class="btn btn-outline-secondary long-action" data-loading-message="Generando PDF..." title="Descargar PDF">
                                            <i class="bi bi-file-earmark-pdf"></i>
                                        </a>
                                        @if (!string.IsNullOrEmpty(p.Empleado.CorreoElectronico))
                                        {
                                            <form asp-action="EnviarPorEmail" method="post" class="d-inline form-loading" data-loading-message="Enviando correo...">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@p.PlanillaEmpleadoId" />
                                                <button type="submit" class="btn btn-outline-secondary" title="Enviar correo">
                                                    <i class="bi bi-envelope"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Total General con división visual -->
    <div class="card mt-4 shadow-sm border-0">
        <div class="card-body py-4">
            <div class="row align-items-center text-center">
                <!-- Devengado -->
                <div class="col-md-4">
                    <div class="p-3 rounded" style="background:#d4edda; border-left:5px solid #28a745;">
                        <div class="d-flex align-items-center justify-content-center gap-2 mb-2">
                            <i class="bi bi-plus-circle-fill text-success fs-4"></i>
                            <small class="text-muted fw-bold">TOTAL DEVENGADO</small>
                        </div>
                        <h3 class="mb-0" style="color:#155724;">₡@Model.Sum(p => p.TotalDevengado).ToString("N0")</h3>
                        <small class="text-muted">@Model.Count() empleados</small>
                    </div>
                </div>

                <!-- Símbolo menos -->
                <div class="col-md-1">
                    <h2 class="mb-0 text-muted">−</h2>
                </div>

                <!-- Deducciones -->
                <div class="col-md-3">
                    <div class="p-3 rounded" style="background:#f8d7da; border-left:5px solid #dc3545;">
                        <div class="d-flex align-items-center justify-content-center gap-2 mb-2">
                            <i class="bi bi-dash-circle-fill text-danger fs-4"></i>
                            <small class="text-muted fw-bold">TOTAL DEDUCCIONES</small>
                        </div>
                        <h3 class="mb-0" style="color:#721c24;">₡@Model.Sum(p => p.TotalDeducciones).ToString("N0")</h3>
                    </div>
                </div>

                <!-- Símbolo igual -->
                <div class="col-md-1">
                    <h2 class="mb-0 text-muted">=</h2>
                </div>

                <!-- Neto -->
                <div class="col-md-3">
                    <div class="p-3 rounded" style="background:#fff3cd; border-left:5px solid #ffc107;">
                        <div class="d-flex align-items-center justify-content-center gap-2 mb-2">
                            <i class="bi bi-cash-coin fs-4" style="color:#856404;"></i>
                            <small class="text-muted fw-bold">NETO A PAGAR</small>
                        </div>
                        <h3 class="mb-0 fw-bold" style="color:#856404;">₡@Model.Sum(p => p.NetoAPagar).ToString("N0")</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
                        } @* cierre else (hay períodos) *@