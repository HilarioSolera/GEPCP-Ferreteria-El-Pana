@model GEPCP_Ferreteria_El_Pana.Models.Puesto
@{
    ViewData["Title"] = "Editar Puesto - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-pencil"></i> Editar Puesto</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-2">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="PuestoId" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger mb-2" style="font-size: 0.75rem;">
                    <ul class="mb-0">
                        @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@e.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }

            <div class="row g-1">
                <div class="col-md-4">
                    <label asp-for="Departamento" class="form-label fw-bold small">
                        <i class="bi bi-building"></i> Departamento <span class="text-danger">*</span>
                    </label>
                    <select asp-for="Departamento" class="form-select form-select-sm">
                        <option value="">-- Seleccione --</option>
                        <option value="Administrativo">Administrativo</option>
                        <option value="Caja">Caja</option>
                        <option value="Ventas">Ventas</option>
                        <option value="Bodega">Bodega</option>
                        <option value="Conductores">Conductores</option>
                    </select>
                    <span asp-validation-for="Departamento" class="text-danger" style="font-size: 0.7rem;"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Codigo" class="form-label fw-bold small">
                        <i class="bi bi-tag"></i> Código <span class="text-danger">*</span>
                    </label>
                    <input asp-for="Codigo" class="form-control form-control-sm" maxlength="20" />
                    <span asp-validation-for="Codigo" class="text-danger" style="font-size: 0.7rem;"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Nombre" class="form-label fw-bold small">
                        <i class="bi bi-briefcase"></i> Nombre Puesto <span class="text-danger">*</span>
                    </label>
                    <input asp-for="Nombre" class="form-control form-control-sm"
                           maxlength="100" />
                    <span asp-validation-for="Nombre" class="text-danger" style="font-size: 0.7rem;"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="SalarioBase" class="form-label fw-bold small">
                        <i class="bi bi-currency-dollar"></i> Salario Base (₡) <span class="text-danger">*</span>
                    </label>
                    <input asp-for="SalarioBase" type="number" step="0.01" min="0" max="9999999.99"
                           class="form-control form-control-sm" />
                    <div class="form-text" style="font-size: 0.7rem;">
                        Cambiar no afecta empleados ya asignados.
                    </div>
                    <span asp-validation-for="SalarioBase" class="text-danger" style="font-size: 0.7rem;"></span>
                </div>

                <div class="col-md-6">
                    <div class="form-check form-switch mt-2">
                        <input asp-for="Activo" class="form-check-input" type="checkbox" />
                        <label asp-for="Activo" class="form-check-label fw-bold small">Puesto activo</label>
                        <div class="form-text" style="font-size: 0.7rem;">
                            Desactivar evita que aparezca en formularios.
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-warning btn-sm px-4">
                    <i class="bi bi-check-circle"></i> Guardar Cambios
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-sm px-4">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}