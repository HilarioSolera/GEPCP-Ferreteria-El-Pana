@{
    ViewData["Title"] = "Nueva contraseña";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="login-page">
    <div class="container" style="position:relative;z-index:2;">
        <div class="row justify-content-center">
            <div class="col-md-4">
                <div class="login-card card">
                    <div class="card-header">
                        <h4><i class="bi bi-lock"></i> Nueva contraseña</h4>
                        <p>Definí tu nueva contraseña de acceso</p>
                    </div>
                    <div class="card-body">
                        <form asp-action="NuevaPassword" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="usuarioRecuperacion"
                                   value="@ViewBag.UsuarioRecuperacion" />
                            <div asp-validation-summary="All" class="text-danger small mb-2"></div>

                            <div class="mb-3">
                                <label class="form-label">
                                    <i class="bi bi-lock"></i> Nueva contraseña
                                </label>
                                <div class="input-group">
                                    <input type="password" name="password" id="inputNueva"
                                           class="form-control"
                                           placeholder="Mínimo 8 caracteres" autofocus />
                                    <button type="button" class="btn btn-outline-secondary"
                                            onclick="togglePassword('inputNueva', this)"
                                            tabindex="-1">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">
                                    <i class="bi bi-lock-fill"></i> Confirmar contraseña
                                </label>
                                <div class="input-group">
                                    <input type="password" name="confirmar" id="inputConfirmar"
                                           class="form-control"
                                           placeholder="Repetí la contraseña" />
                                    <button type="button" class="btn btn-outline-secondary"
                                            onclick="togglePassword('inputConfirmar', this)"
                                            tabindex="-1">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </div>
                            </div>

                            <button type="submit" class="btn-login btn btn-lg w-100">
                                <i class="bi bi-check-circle"></i> Guardar contraseña
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function togglePassword(inputId, btn) {
            var input = document.getElementById(inputId);
            var icon  = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('bi-eye', 'bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('bi-eye-slash', 'bi-eye');
            }
        }
    </script>
}