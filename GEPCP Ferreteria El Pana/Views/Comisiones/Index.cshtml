@model List<GEPCP_Ferreteria_El_Pana.Models.Comision>
@{
    ViewData["Title"] = "Comisiones - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-graph-up-arrow"></i> Comisiones</h2>
    <a asp-action="Create" class="btn btn-success btn-lg">
        <i class="bi bi-plus-circle"></i> Nueva Comisión
    </a>
</div>

@* KPIs *@
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-primary">@ViewBag.TotalComisiones</div>
            <div class="text-muted small">Total Registros</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-success">₡@ViewBag.MontoTotal.ToString("N0")</div>
            <div class="text-muted small">Monto Total</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-warning">₡@ViewBag.PromedioMonto.ToString("N0")</div>
            <div class="text-muted small">Promedio por Comisión</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-info">@ViewBag.EmpleadosConComision</div>
            <div class="text-muted small">Empleados con Comisión</div>
        </div>
    </div>
</div>

@* Filtros *@
<form asp-action="Index" method="get" class="mb-4">
    <div class="row g-2">
        <div class="col-md-5">
            <div class="input-group shadow-sm">
                <span class="input-group-text bg-white">
                    <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" name="busqueda" value="@ViewBag.Busqueda"
                       class="form-control border-start-0"
                       placeholder="Buscar por nombre, cédula o descripción..." />
            </div>
        </div>
        <div class="col-md-2">
            <input type="date" name="desde" value="@ViewBag.Desde"
                   class="form-control shadow-sm" title="Desde" />
        </div>
        <div class="col-md-2">
            <input type="date" name="hasta" value="@ViewBag.Hasta"
                   class="form-control shadow-sm" title="Hasta" />
        </div>
        <div class="col-md-1">
            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-funnel"></i>
            </button>
        </div>
        <div class="col-md-2">
            @if (!string.IsNullOrEmpty(ViewBag.Busqueda as string) ||
                        !string.IsNullOrEmpty(ViewBag.Desde as string) ||
                        !string.IsNullOrEmpty(ViewBag.Hasta as string))
            {
                <a asp-action="Index" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-x-circle"></i> Limpiar
                </a>
            }
        </div>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info text-center py-4">
        <i class="bi bi-inbox fs-3 d-block mb-2"></i>
        No se encontraron comisiones con los filtros aplicados.
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle mb-0">
            <thead style="background-color: #FF7A00; color: white;">
                <tr>
                    <th>Empleado</th>
                    <th>Fecha</th>
                    <th class="text-end">Monto</th>
                    <th>Descripción</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td>
                            <strong>@c.Empleado.PrimerApellido @c.Empleado.Nombre</strong>
                            <div class="small text-muted">
                                <span class="badge bg-secondary">@c.Empleado.Puesto</span>
                            </div>
                        </td>
                        <td>@c.Fecha.ToString("dd/MM/yyyy")</td>
                        <td class="text-end fw-bold text-success">
                            ₡@c.Monto.ToString("N0")
                        </td>
                        <td>
                            <span class="text-truncate d-inline-block" style="max-width: 250px;"
                                  title="@c.Descripcion">
                                @c.Descripcion
                            </span>
                        </td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">
                                <a asp-action="Edit" asp-route-id="@c.ComisionId"
                                   class="btn btn-sm btn-warning" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="Delete" method="post" class="d-inline"
                                      onsubmit="return confirm('¿Eliminar la comisión de ₡@c.Monto.ToString("N0") de @c.Empleado.PrimerApellido @c.Empleado.Nombre?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@c.ComisionId" />
                                    <button type="submit" class="btn btn-sm btn-danger" title="Eliminar">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot class="table-light fw-bold">
                <tr>
                    <td colspan="2" class="text-end text-muted">Total:</td>
                    <td class="text-end text-success">₡@Model.Sum(c => c.Monto).ToString("N0")</td>
                    <td colspan="2"></td>
                </tr>
            </tfoot>
        </table>
    </div>

    <div class="text-muted small mt-2 text-end">
        Mostrando <strong>@Model.Count</strong> comisión(es)
    </div>
}