@model GEPCP_Ferreteria_El_Pana.Models.UsuarioCreateViewModel
@{
    ViewData["Title"] = "Nuevo Usuario - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-person-plus"></i> Nuevo Usuario</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div class="card shadow-sm border-0" style="max-width: 650px;">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">

                <div class="col-md-6">
                    <label asp-for="NombreUsuario" class="form-label fw-bold">
                        <i class="bi bi-person"></i> Nombre de Usuario <span class="text-danger">*</span>
                    </label>
                    <input asp-for="NombreUsuario" class="form-control form-control-lg"
                           maxlength="50" placeholder="Ej: maria.lopez"
                           autocomplete="off" />
                    <div class="form-text text-muted">
                        Solo letras, números, puntos y guiones.
                    </div>
                    <span asp-validation-for="NombreUsuario" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="NombreCompleto" class="form-label fw-bold">
                        <i class="bi bi-person-badge"></i> Nombre Completo <span class="text-danger">*</span>
                    </label>
                    <input asp-for="NombreCompleto" class="form-control form-control-lg"
                           maxlength="100" placeholder="Ej: María López Jiménez" />
                    <span asp-validation-for="NombreCompleto" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="CorreoElectronico" class="form-label fw-bold">
                        <i class="bi bi-envelope"></i> Correo Electrónico
                        <span class="text-muted fw-normal small">(requerido para recuperar contraseña)</span>
                    </label>
                    <input asp-for="CorreoElectronico" type="email"
                           class="form-control form-control-lg"
                           maxlength="150" placeholder="Ej: maria@ferreteria.com" />
                    <span asp-validation-for="CorreoElectronico" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Password" class="form-label fw-bold">
                        <i class="bi bi-lock"></i> Contraseña <span class="text-danger">*</span>
                    </label>
                    <input asp-for="Password" type="password"
                           class="form-control form-control-lg"
                           placeholder="Mínimo 8 caracteres"
                           autocomplete="new-password"
                           id="inputPassword" />
                    <div class="form-text text-muted" id="passwordHint"></div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="ConfirmarPassword" class="form-label fw-bold">
                        <i class="bi bi-lock-fill"></i> Confirmar Contraseña <span class="text-danger">*</span>
                    </label>
                    <input asp-for="ConfirmarPassword" type="password"
                           class="form-control form-control-lg"
                           placeholder="Repetí la contraseña"
                           autocomplete="new-password" />
                    <span asp-validation-for="ConfirmarPassword" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Rol" class="form-label fw-bold">
                        <i class="bi bi-shield"></i> Rol <span class="text-danger">*</span>
                    </label>
                    <select asp-for="Rol" class="form-select form-select-lg">
                        <option value="RRHH">RRHH</option>
                        <option value="Jefatura">Jefatura</option>
                    </select>
                    <span asp-validation-for="Rol" class="text-danger small"></span>
                </div>

            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-success btn-lg px-5">
                    <i class="bi bi-check-circle"></i> Crear Usuario
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-lg px-5">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.getElementById('inputPassword').addEventListener('input', function () {
            var pwd   = this.value;
            var hint  = document.getElementById('passwordHint');
            var score = 0;

            if (pwd.length >= 8)                        score++;
            if (/[A-Z]/.test(pwd))                      score++;
            if (/[a-z]/.test(pwd))                      score++;
            if (/[0-9]/.test(pwd))                      score++;
            if (/[!@@#$%^&*\(\)\-_=\+]/.test(pwd))     score++;

            var labels = ['Muy débil', 'Débil', 'Regular', 'Buena', 'Fuerte'];
            var colors = ['text-danger', 'text-danger', 'text-warning', 'text-info', 'text-success'];

            if (pwd.length === 0) { hint.textContent = ''; return; }

            var idx = Math.max(0, score - 1);
            hint.className = 'form-text ' + colors[idx];
            hint.innerHTML = '<i class="bi bi-shield"></i> Fortaleza: <strong>'
                           + labels[idx]
                           + '</strong> — Debe tener: mayúscula, minúscula, número y carácter especial.';
        });
    </script>
}