@model GEPCP_Ferreteria_El_Pana.Models.EmpleadoViewModel
@{
    ViewData["Title"] = "Editar Empleado - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-pencil"></i> Editar Empleado</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="EmpleadoId" />

            <div class="row g-3">

                @* ── Identificación ── *@
                <div class="col-12">
                    <h6 class="text-muted fw-bold border-bottom pb-2">
                        <i class="bi bi-person-badge"></i> Identificación
                    </h6>
                </div>

                <div class="col-md-4">
                    <label asp-for="Cedula" class="form-label fw-bold">
                        <i class="bi bi-card-text"></i> Cédula
                    </label>
                    <input asp-for="Cedula" class="form-control form-control-lg bg-light"
                           maxlength="20" readonly />
                    <div class="form-text text-muted">La cédula no puede modificarse.</div>
                </div>

                <div class="col-md-8">
                    <label asp-for="Nombre" class="form-label fw-bold">
                        <i class="bi bi-person"></i> Nombre <span class="text-danger">*</span>
                    </label>
                    <input asp-for="Nombre" class="form-control form-control-lg" maxlength="100" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="PrimerApellido" class="form-label fw-bold">
                        <i class="bi bi-person"></i> Primer Apellido <span class="text-danger">*</span>
                    </label>
                    <input asp-for="PrimerApellido" class="form-control form-control-lg" maxlength="50" />
                    <span asp-validation-for="PrimerApellido" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="SegundoApellido" class="form-label fw-bold">
                        <i class="bi bi-person"></i> Segundo Apellido
                        <span class="text-muted fw-normal small">(opcional)</span>
                    </label>
                    <input asp-for="SegundoApellido" class="form-control form-control-lg" maxlength="50" />
                    <span asp-validation-for="SegundoApellido" class="text-danger small"></span>
                </div>

                @* ── Información Laboral ── *@
                <div class="col-12 mt-2">
                    <h6 class="text-muted fw-bold border-bottom pb-2">
                        <i class="bi bi-briefcase"></i> Información Laboral
                    </h6>
                </div>

                <select asp-for="Departamento" class="form-select form-select-lg">
                    <option value="Administrativo">Administrativo</option>
                    <option value="Caja">Caja</option>
                    <option value="Ventas">Ventas</option>
                    <option value="Bodega">Bodega</option>
                    <option value="Conductores">Conductores</option>
                </select>

                <div class="col-md-4">
                    <label asp-for="Puesto" class="form-label fw-bold">
                        <i class="bi bi-briefcase"></i> Puesto <span class="text-danger">*</span>
                    </label>
                    <select asp-for="Puesto" class="form-select form-select-lg"
                            asp-items="ViewBag.Puestos" id="selectPuesto">
                        <option value="">-- Seleccione un puesto --</option>
                    </select>
                    <span asp-validation-for="Puesto" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="TipoJornada" class="form-label fw-bold">
                        <i class="bi bi-clock"></i> Tipo de Jornada <span class="text-danger">*</span>
                    </label>
                    <select asp-for="TipoJornada" class="form-select form-select-lg"
                            id="selectJornada">
                        <option value="1">Completa (240 hrs/mes)</option>
                        <option value="2">Media Jornada (120 hrs/mes)</option>
                    </select>
                    <span asp-validation-for="TipoJornada" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="FechaIngreso" class="form-label fw-bold">
                        <i class="bi bi-calendar-check"></i> Fecha de Ingreso <span class="text-danger">*</span>
                    </label>
                    <input asp-for="FechaIngreso" type="date"
                           class="form-control form-control-lg"
                           max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="FechaIngreso" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="SalarioBase" class="form-label fw-bold">
                        <i class="bi bi-currency-dollar"></i> Salario Base (₡) <span class="text-danger">*</span>
                    </label>
                    <input asp-for="SalarioBase" type="number" step="0.01"
                           min="0" max="9999999.99"
                           class="form-control form-control-lg" id="inputSalario" />
                    <div class="form-text" id="salarioHint"></div>
                    <span asp-validation-for="SalarioBase" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold text-muted">
                        <i class="bi bi-calculator"></i> Valor Hora (referencia)
                    </label>
                    <div class="form-control form-control-lg bg-light text-center fw-bold"
                         id="valorHoraRef" style="color: #0D6EFD;">
                        —
                    </div>
                    <div class="form-text text-muted">Calculado: salario ÷ horas jornada</div>
                </div>

                @* ── Contacto y Pago ── *@
                <div class="col-12 mt-2">
                    <h6 class="text-muted fw-bold border-bottom pb-2">
                        <i class="bi bi-telephone"></i> Contacto y Forma de Pago
                    </h6>
                </div>

                <div class="col-md-6">
                    <label asp-for="Telefono" class="form-label fw-bold">
                        <i class="bi bi-phone"></i> Teléfono / Celular
                        <span class="text-muted fw-normal small">(opcional)</span>
                    </label>
                    <input asp-for="Telefono" class="form-control form-control-lg" maxlength="20" />
                    <span asp-validation-for="Telefono" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="CorreoElectronico" class="form-label fw-bold">
                        <i class="bi bi-envelope"></i> Correo Electrónico
                        <span class="text-muted fw-normal small">(opcional)</span>
                    </label>
                    <input asp-for="CorreoElectronico" type="email"
                           class="form-control form-control-lg" maxlength="150" />
                    <span asp-validation-for="CorreoElectronico" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="FormaPago" class="form-label fw-bold">
                        <i class="bi bi-credit-card"></i> Forma de Pago <span class="text-danger">*</span>
                    </label>
                    <select asp-for="FormaPago" class="form-select form-select-lg"
                            id="selectFormaPago">
                        <option value="1">Transferencia Banco Nacional</option>
                        <option value="2">Efectivo</option>
                    </select>
                    <span asp-validation-for="FormaPago" class="text-danger small"></span>
                </div>

                <div class="col-md-8" id="divNumeroCuenta">
                    <label asp-for="NumeroCuenta" class="form-label fw-bold">
                        <i class="bi bi-bank"></i> Número de Cuenta BN
                        <span class="text-muted fw-normal small">(opcional)</span>
                    </label>
                    <input asp-for="NumeroCuenta" class="form-control form-control-lg"
                           maxlength="30" placeholder="Ej: 100-01-000-000000-0" />
                    <div class="form-text text-muted">
                        Número de cuenta Banco Nacional para depósito del salario.
                    </div>
                    <span asp-validation-for="NumeroCuenta" class="text-danger small"></span>
                </div>

            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-warning btn-lg px-5">
                    <i class="bi bi-check-circle"></i> Guardar Cambios
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-lg px-5">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function calcularValorHora() {
            var salario = parseFloat(document.getElementById('inputSalario').value) || 0;
            var jornada = parseInt(document.getElementById('selectJornada').value);
            var horas   = jornada === 1 ? 240 : 120;
            var vHora   = salario > 0 ? (salario / horas) : 0;
            var vExtra  = vHora * 1.5;
            var ref     = document.getElementById('valorHoraRef');

            if (vHora > 0) {
                ref.innerHTML =
                    '&#8353;' + vHora.toLocaleString('es-CR', {minimumFractionDigits: 2, maximumFractionDigits: 2}) +
                    ' <small class="text-muted fw-normal">(extra: &#8353;' +
                    vExtra.toLocaleString('es-CR', {minimumFractionDigits: 2, maximumFractionDigits: 2}) +
                    ')</small>';
            } else {
                ref.innerHTML = '—';
            }
        }

        function toggleCuenta() {
            var forma = parseInt(document.getElementById('selectFormaPago').value);
            var div   = document.getElementById('divNumeroCuenta');
            div.style.display = forma === 1 ? 'block' : 'none';
        }

        document.getElementById('selectFormaPago').addEventListener('change', toggleCuenta);
        toggleCuenta();

        document.getElementById('selectPuesto').addEventListener('change', async function () {
            var puesto = this.value;
            var hint   = document.getElementById('salarioHint');
            if (!puesto) { hint.textContent = ''; return; }
            try {
                var res  = await fetch('/Empleados/ObtenerSalarioPuesto?nombre=' + encodeURIComponent(puesto));
                var data = await res.json();
                if (data.salario !== null) {
                    document.getElementById('inputSalario').value = data.salario;
                    hint.innerHTML =
                        '<i class="bi bi-info-circle text-success"></i> ' +
                        'Salario base del puesto: <strong>&#8353;' +
                        Number(data.salario).toLocaleString('es-CR') +
                        '</strong>. Podés modificarlo.';
                    hint.className = 'form-text text-success';
                    calcularValorHora();
                }
            } catch (e) { console.error('Error al obtener salario:', e); }
        });

        document.getElementById('inputSalario').addEventListener('input', calcularValorHora);
        document.getElementById('selectJornada').addEventListener('change', calcularValorHora);
        calcularValorHora();
    </script>
}