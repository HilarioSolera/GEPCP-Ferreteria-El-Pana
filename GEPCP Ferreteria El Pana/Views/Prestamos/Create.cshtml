@model GEPCP_Ferreteria_El_Pana.Models.PrestamoViewModel
@{
    ViewData["Title"] = "Nuevo Préstamo - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Nuevo Préstamo a Empleado</h2>

<form asp-action="Create" method="post">
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="NombreEmpleado" class="form-label fw-bold"></label>
            <input asp-for="NombreEmpleado" class="form-control form-control-lg" placeholder="Hilario Solera Meza" />
        </div>
        <div class="col-md-6">
            <label asp-for="MontoPrincipal" class="form-label fw-bold"></label>
            <input asp-for="MontoPrincipal" type="number" class="form-control form-control-lg" />
        </div>

        <div class="col-md-6">
            <label asp-for="CuotaMensual" class="form-label fw-bold"></label>
            <input asp-for="CuotaMensual" type="number" class="form-control form-control-lg" />
        </div>
        <div class="col-md-6">
            <label class="form-label fw-bold">Fecha de Inicio</label>
            <input type="date" class="form-control form-control-lg" value="2025-07-01" />
        </div>
    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-success btn-lg px-5">Registrar Préstamo</button>
        <a href="/Prestamos" class="btn btn-secondary btn-lg px-5">Cancelar</a>
    </div>
</form>