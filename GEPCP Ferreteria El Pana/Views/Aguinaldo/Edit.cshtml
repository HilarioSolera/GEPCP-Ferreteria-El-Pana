@model GEPCP_Ferreteria_El_Pana.Models.Aguinaldo
@{
    ViewData["Title"] = "Editar Aguinaldo - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-gift"></i> Editar Aguinaldo</h4>
    <a asp-action="Index" asp-route-anio="@Model.Anio" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-2">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="AguinaldoId" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger mb-2" style="font-size: 0.75rem;">
                    <ul class="mb-0">
                        @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@e.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }

            <div class="row g-1">
                <!-- Información del Empleado -->
                <div class="col-12">
                    <label class="form-label fw-bold small">Empleado</label>
                    <div class="form-control form-control-sm bg-light" style="font-size: 0.85rem;">
                        @if (Model.Empleado != null)
                        {
                            <strong>@Model.Empleado.PrimerApellido @Model.Empleado.Nombre</strong>

                            <br>
                            <small class="text-muted">
                                @Model.Empleado.Cedula — @Model.Empleado.Puesto
                            </small>
                        }
                        else
                        {
                            <span class="text-danger fw-bold">⚠ Empleado no encontrado</span>
                        }
                    </div>
                    <input type="hidden" asp-for="EmpleadoId" />
                </div>

                <div class="col-md-3">
                    <label asp-for="Anio" class="form-label fw-bold small">Año</label>
                    <input asp-for="Anio" type="number" class="form-control form-control-sm" />
                </div>

                <div class="col-md-3">
                    <label asp-for="FechaInicio" class="form-label fw-bold small">Inicio</label>
                    <input asp-for="FechaInicio" type="date" class="form-control form-control-sm" />
                </div>

                <div class="col-md-3">
                    <label asp-for="FechaFin" class="form-label fw-bold small">Fin</label>
                    <input asp-for="FechaFin" type="date" class="form-control form-control-sm" />
                </div>

                <div class="col-md-3">
                    <label asp-for="FechaPago" class="form-label fw-bold small">Fecha Pago</label>
                    <input asp-for="FechaPago" type="date" class="form-control form-control-sm" />
                </div>

                <div class="col-md-6">
                    <label asp-for="MontoTotal" class="form-label fw-bold small">Monto Total (₡)</label>
                    <input asp-for="MontoTotal" type="number" step="0.01" class="form-control form-control-sm" />
                </div>

                <div class="col-md-6">
                    <label asp-for="Observaciones" class="form-label fw-bold small">Observaciones</label>
                    <textarea asp-for="Observaciones" class="form-control form-control-sm" rows="2"></textarea>
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-warning btn-sm px-4">
                    <i class="bi bi-check-circle"></i> Guardar Cambios
                </button>
                <a asp-action="Index" asp-route-anio="@Model.Anio" class="btn btn-secondary btn-sm px-4">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}