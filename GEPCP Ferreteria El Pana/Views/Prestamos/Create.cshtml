@model GEPCP_Ferreteria_El_Pana.Models.PrestamoViewModel
@{
    ViewData["Title"] = "Nuevo Préstamo - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-cash-coin"></i> Nuevo Préstamo</h4>
    <a asp-action="Index" asp-route-verTodos="true" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-2">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger mb-2" style="font-size: 0.75rem;">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <strong>No se pudo registrar:</strong>
                    <ul class="mb-0 mt-1">
                        @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@e.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }

            <div class="row g-1">
                <!-- Buscador de empleado -->
                <div class="col-12">
                    <label class="form-label fw-bold small">
                        <i class="bi bi-person-search"></i> Empleado <span class="text-danger">*</span>
                    </label>
                    <input type="hidden" asp-for="EmpleadoId" id="EmpleadoId" />
                    <div class="input-group input-group-sm mb-1">
                        <span class="input-group-text bg-white">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        <input type="text" id="buscarEmpleado"
                               class="form-control form-control-sm border-start-0"
                               placeholder="Buscar por nombre, apellido o cédula..."
                               autocomplete="off" />
                        <button type="button" class="btn btn-outline-secondary btn-sm" id="btnTodos">
                            <i class="bi bi-list-ul"></i> Todos
                        </button>
                    </div>

                    <div id="empleadoSeleccionado" class="d-none">
                        <div class="alert py-1 d-flex justify-content-between align-items-center" id="empAlerta" style="font-size: 0.85rem;">
                            <div>
                                <i class="bi bi-person-check-fill"></i>
                                <strong id="empNombre"></strong>
                                <span class="text-muted ms-2" style="font-size: 0.75rem;" id="empCedula"></span>
                                <span class="badge bg-secondary ms-1" style="font-size: 0.65rem;" id="empPuesto"></span>
                            </div>
                            <div class="text-end me-2" style="font-size: 0.75rem;">
                                <div>Salario base: <strong id="empSalarioBase"></strong></div>
                                <div>
                                    <span id="labelSalarioPeriodo">Salario del período:</span>
                                    <strong id="empSalarioQuincenal"></strong>
                                </div>
                                <div id="empActivoWarn" class="text-danger d-none fw-bold" style="font-size: 0.7rem;">
                                    <i class="bi bi-exclamation-triangle"></i> Ya tiene un préstamo activo
                                </div>
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-danger" id="btnLimpiar" style="font-size: 0.7rem;">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                    </div>

                    <div id="resultados" class="border rounded shadow-sm"
                         style="display:none; max-height:200px; overflow-y:auto; background:#fff; z-index:100; position:relative; font-size: 0.85rem;">
                    </div>
                    <span asp-validation-for="EmpleadoId" class="text-danger" style="font-size: 0.7rem;"></span>
                </div>

                <!-- Monto -->
                <div class="col-md-4">
                    <label asp-for="MontoPrincipal" class="form-label fw-bold small">
                        <i class="bi bi-currency-dollar"></i> Monto Préstamo (₡) <span class="text-danger">*</span>
                    </label>
                    <input asp-for="MontoPrincipal" type="number" step="0.01" min="1" id="inputMonto"
                           class="form-control form-control-sm" placeholder="Ej: 500000" />
                </div>

                <!-- Número de Cuotas -->
                <div class="col-md-4">
                    <label asp-for="CuotasTotal" class="form-label fw-bold small">
                        <i class="bi bi-calendar-range"></i> Número Cuotas <span class="text-danger">*</span>
                    </label>
                    <input asp-for="CuotasTotal" type="number" min="1" max="120" id="inputCuotas"
                           class="form-control form-control-sm" placeholder="Ej: 12" />
                </div>

                <!-- Cuota -->
                <div class="col-md-4">
                    <label asp-for="CuotaMensual" class="form-label fw-bold small">
                        <i class="bi bi-cash"></i> Cuota Período (₡) <span class="text-danger">*</span>
                    </label>
                    <input asp-for="CuotaMensual" type="number" step="0.01" min="1" id="inputCuota"
                           class="form-control form-control-sm" placeholder="Auto-calculado" />
                    <div class="form-text" id="cuotaHint" style="font-size: 0.7rem;"></div>
                </div>

                <!-- Fecha -->
                <div class="col-md-4">
                    <label asp-for="FechaPrestamo" class="form-label fw-bold small">
                        <i class="bi bi-calendar"></i> Fecha Préstamo <span class="text-danger">*</span>
                    </label>
                    <input asp-for="FechaPrestamo" type="date" class="form-control form-control-sm"
                           max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>

                <!-- Resumen -->
                <div class="col-12">
                    <div id="resumenPrestamo" class="d-none">
                        <div class="card border-0" style="background:#fff9f0; border-left:3px solid #FF7A00 !important;">
                            <div class="card-body py-1 px-2">
                                <div class="row g-1 text-center" style="font-size: 0.8rem;">
                                    <div class="col-md-3">
                                        <div style="font-size:0.6rem;color:#888;text-transform:uppercase;">Monto préstamo</div>
                                        <div class="fw-bold" style="color:#FF7A00;" id="resumenMonto">—</div>
                                    </div>
                                    <div class="col-md-3">
                                        <div style="font-size:0.6rem;color:#888;text-transform:uppercase;">Cuota</div>
                                        <div class="fw-bold" id="resumenCuota">—</div>
                                    </div>
                                    <div class="col-md-3">
                                        <div style="font-size:0.6rem;color:#888;text-transform:uppercase;">Cuotas</div>
                                        <div class="fw-bold" id="resumenCuotas">—</div>
                                    </div>
                                    <div class="col-md-3">
                                        <div style="font-size:0.6rem;color:#888;text-transform:uppercase;">% del salario</div>
                                        <div class="fw-bold" id="resumenPct">—</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-success btn-sm px-4" id="btnGuardar" disabled>
                    <i class="bi bi-check-circle"></i> Registrar Préstamo
                </button>
                <a asp-action="Index" asp-route-verTodos="true" class="btn btn-secondary btn-sm px-4">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        var empData = null;
        window._empResults = [];

        // ====================== BUSCAR ======================
        async function buscar(termino, todos = false) {
            var url = todos
                ? '/Prestamos/TodosLosEmpleados'
                : '/Prestamos/BuscarEmpleados?termino=' + encodeURIComponent(termino);

            try {
                var res = await fetch(url);
                var data = await res.json();
                var div = document.getElementById('resultados');

                if (!data.length) {
                    div.innerHTML = '<div class="p-3 text-muted text-center small">Sin resultados.</div>';
                    div.style.display = 'block';
                    return;
                }

                window._empResults = data;

                div.innerHTML = data.map((e, i) => {
                    var salRef = e.salarioQuincenal.toLocaleString('es-CR', { minimumFractionDigits: 0 });
                    var labelSal = e.tipoPago === 'Semanal' ? 'Semanal'
                        : e.tipoPago === 'Mensual' ? 'Mensual'
                            : 'Quinc.';

                    var bg = e.tieneActivo ? '#fff9f0' : '#fff';
                    var badge = e.tieneActivo
                        ? '<span class="badge bg-warning text-dark ms-1" style="font-size:0.6rem;">Préstamo activo</span>'
                        : '';

                    return `<div class="p-2 border-bottom emp-item" data-index="${i}" style="cursor:pointer; background:${bg};">
                                <div class="fw-bold small">${e.nombre}${badge}</div>
                                <div class="text-muted" style="font-size:0.78rem;">
                                    ${e.cedula} — ${e.puesto}
                                    <span class="float-end">${labelSal}: ₡${salRef}</span>
                                </div>
                            </div>`;
                }).join('');

                // Eventos
                div.querySelectorAll('.emp-item').forEach(el => {
                    el.addEventListener('mouseenter', () => el.style.background = '#f0f0f0');
                    el.addEventListener('mouseleave', () => {
                        const idx = parseInt(el.dataset.index);
                        el.style.background = window._empResults[idx]?.tieneActivo ? '#fff9f0' : '#fff';
                    });
                    el.addEventListener('click', () => seleccionar(parseInt(el.dataset.index)));
                });

                div.style.display = 'block';
            } catch (err) {
                console.error(err);
                document.getElementById('resultados').innerHTML = '<div class="p-3 text-danger">Error al cargar empleados</div>';
            }
        }

        function seleccionar(index) {
            var e = window._empResults[index];
            if (!e) return;

            empData = e;
            document.getElementById('EmpleadoId').value = e.id;
            document.getElementById('empNombre').textContent = e.nombre;
            document.getElementById('empCedula').textContent = e.cedula;
            document.getElementById('empPuesto').textContent = e.puesto;

            // Salario base
            document.getElementById('empSalarioBase').textContent =
                '₡' + e.salarioBase.toLocaleString('es-CR', { minimumFractionDigits: 0 });

            // Salario según tipo de pago
            var labelPago = e.tipoPago === 'Semanal' ? 'Salario semanal:'
                : e.tipoPago === 'Mensual' ? 'Salario mensual:'
                    : 'Salario quincenal:';
            document.getElementById('labelSalarioPeriodo').textContent = labelPago;

            document.getElementById('empSalarioQuincenal').textContent =
                '₡' + e.salarioQuincenal.toLocaleString('es-CR', { minimumFractionDigits: 0 });

            // Warning de préstamo activo
            var alerta = document.getElementById('empAlerta');
            var warn = document.getElementById('empActivoWarn');
            if (e.tieneActivo) {
                alerta.className = 'alert alert-warning py-1 d-flex justify-content-between align-items-center';
                alerta.style.fontSize = '0.85rem';
                warn.classList.remove('d-none');
                document.getElementById('btnGuardar').disabled = true;
            } else {
                alerta.className = 'alert alert-success py-1 d-flex justify-content-between align-items-center';
                alerta.style.fontSize = '0.85rem';
                warn.classList.add('d-none');
                document.getElementById('btnGuardar').disabled = false;
            }

            document.getElementById('empleadoSeleccionado').classList.remove('d-none');
            document.getElementById('resultados').style.display = 'none';
            document.getElementById('buscarEmpleado').value = '';

            actualizarResumen();
        }

        // ====================== RESUMEN ======================
        function actualizarResumen() {
            var monto = parseFloat(document.getElementById('inputMonto').value) || 0;
            var cuotas = parseInt(document.getElementById('inputCuotas').value) || 0;
            var cuota = parseFloat(document.getElementById('inputCuota').value) || 0;

            var resumenDiv = document.getElementById('resumenPrestamo');

            if (monto > 0 || cuota > 0) {
                resumenDiv.classList.remove('d-none');

                document.getElementById('resumenMonto').textContent = '₡' + monto.toLocaleString('es-CR', { minimumFractionDigits: 0 });
                document.getElementById('resumenCuota').textContent = cuota > 0 ? '₡' + cuota.toLocaleString('es-CR', { minimumFractionDigits: 2 }) : '—';

                var labelCuota = empData && empData.tipoPago === 'Semanal' ? 'semana(s)'
                    : empData && empData.tipoPago === 'Mensual' ? 'mes(es)'
                        : 'quincena(s)';

                document.getElementById('resumenCuotas').textContent = cuotas > 0 ? cuotas + ' ' + labelCuota : '—';

                // Porcentaje
                if (empData && empData.salarioQuincenal > 0 && cuota > 0) {
                    var pct = Math.round((cuota / empData.salarioQuincenal) * 100);
                    var pctEl = document.getElementById('resumenPct');
                    pctEl.textContent = pct + '%';
                    pctEl.style.color = pct > 100 ? '#B71C1C' : pct > 70 ? '#E65100' : '#1B5E20';
                }
            } else {
                resumenDiv.classList.add('d-none');
            }
        }

        // ====================== EVENTOS ======================
        var timer;
        document.getElementById('buscarEmpleado').addEventListener('input', function() {
            clearTimeout(timer);
            var val = this.value.trim();
            if (val.length < 2) {
                document.getElementById('resultados').style.display = 'none';
                return;
            }
            timer = setTimeout(() => buscar(val, false), 300);
        });

        document.getElementById('btnTodos').addEventListener('click', () => buscar('', true));

        document.getElementById('btnLimpiar').addEventListener('click', function() {
            empData = null;
            document.getElementById('EmpleadoId').value = '';
            document.getElementById('empleadoSeleccionado').classList.add('d-none');
            document.getElementById('buscarEmpleado').value = '';
            document.getElementById('btnGuardar').disabled = true;
            document.getElementById('resumenPrestamo').classList.add('d-none');
        });

        document.getElementById('inputMonto').addEventListener('input', calcularCuota);
        document.getElementById('inputCuotas').addEventListener('input', calcularCuota);
        document.getElementById('inputCuota').addEventListener('input', actualizarResumen);

        function calcularCuota() {
            var monto = parseFloat(document.getElementById('inputMonto').value) || 0;
            var cuotas = parseInt(document.getElementById('inputCuotas').value) || 0;
            if (monto > 0 && cuotas > 0) {
                var cuota = Math.round((monto / cuotas) * 100) / 100;
                document.getElementById('inputCuota').value = cuota.toFixed(2);
            }
            actualizarResumen();
        }

        // Click fuera para cerrar resultados
        document.addEventListener('click', function(e) {
            if (!e.target.closest('#resultados') &&
                !e.target.closest('#buscarEmpleado') &&
                !e.target.closest('#btnTodos')) {
                document.getElementById('resultados').style.display = 'none';
            }
        });
    </script>
}