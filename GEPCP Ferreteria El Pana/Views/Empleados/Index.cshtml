@model IEnumerable<GEPCP_Ferreteria_El_Pana.Models.EmpleadoViewModel>
@{
    ViewData["Title"] = "Empleados - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var busqueda = ViewBag.Busqueda as string ?? "";
    var filtroEstado = ViewBag.FiltroEstado as string ?? "activos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-people"></i> Empleados</h2>
    <a asp-action="Create" class="btn btn-success btn">
        <i class="bi bi-person-plus"></i> Nuevo Empleado
    </a>
</div>

@* Barra de búsqueda *@
<form asp-action="Index" method="get" class="mb-3" id="formBusqueda">
    <input type="hidden" name="filtroEstado" id="hiddenFiltroEstado" value="@filtroEstado" />
    <div class="input-group input-group-lg shadow-sm">
        <span class="input-group-text bg-white">
            <i class="bi bi-search text-muted"></i>
        </span>
        <input type="text" name="busqueda" id="inputBusqueda"
               value="@busqueda"
               class="form-control border-start-0"
               placeholder="Buscar por nombre, cédula, puesto, departamento..." />
        <button type="submit" class="btn btn-primary px-4">
            <i class="bi bi-search"></i> Buscar
        </button>
        @if (!string.IsNullOrEmpty(busqueda))
        {
            <a asp-action="Index" asp-route-filtroEstado="@filtroEstado" class="btn btn-outline-secondary" title="Limpiar búsqueda">
                <i class="bi bi-x-circle"></i> Limpiar
            </a>
        }
    </div>
</form>

@* Filtros de estado + Mostrar todos *@
<div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
    <span class="text-muted small me-1"><i class="bi bi-funnel"></i> Estado:</span>
    <a asp-action="Index" asp-route-busqueda="@busqueda" asp-route-mostrarTodos="true" asp-route-filtroEstado="activos"
       class="btn btn-sm @(filtroEstado == "activos" ? "btn-success" : "btn-outline-success")">
        <i class="bi bi-check-circle"></i> Activos
    </a>
    <a asp-action="Index" asp-route-busqueda="@busqueda" asp-route-mostrarTodos="true" asp-route-filtroEstado="inactivos"
       class="btn btn-sm @(filtroEstado == "inactivos" ? "btn-secondary" : "btn-outline-secondary")">
        <i class="bi bi-pause-circle"></i> Inactivos
    </a>
    <a asp-action="Index" asp-route-busqueda="@busqueda" asp-route-mostrarTodos="true" asp-route-filtroEstado="todos"
       class="btn btn-sm @(filtroEstado == "todos" ? "btn-info" : "btn-outline-info")">
        <i class="bi bi-people"></i> Todos
    </a>

    @if (!string.IsNullOrEmpty(busqueda))
    {
        <small class="text-muted ms-auto">
            Resultados para: <strong>"@busqueda"</strong> —
            @Model.Count() empleado(s) encontrado(s)
        </small>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center py-4">
        <i class="bi bi-inbox fs-3 d-block mb-2"></i>
        @if (!string.IsNullOrEmpty(busqueda))
        {
            <span>No se encontraron empleados para "<strong>@busqueda</strong>".</span>
        }
        else
        {
            <span>Usá la barra de búsqueda para encontrar empleados, o presioná <strong>Mostrar todos</strong>.</span>
        }
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle mb-0">
            <thead style="background-color: #FF7A00; color: white;">
                <tr>
                    <th>Cédula</th>
                    <th>Nombre Completo</th>
                    <th>Departamento</th>
                    <th>Puesto</th>
                    <th>Jornada</th>
                    <th class="text-end">Salario Base</th>
                    <th class="text-end">Valor Hora</th>
                    <th>Contacto</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="@(item.Estado == "Inactivo" ? "table-danger" : "")" 
                        style="@(item.Estado == "Inactivo" ? "background-color: #ffe6e6 !important;" : "")">
                        <td><code>@item.Cedula</code></td>
                        <td>
                            <strong>@item.PrimerApellido @item.SegundoApellido</strong>
                            @item.Nombre
                            @if (item.Estado == "Inactivo")
                            {
                                <span class="badge bg-danger ms-2">INACTIVO</span>
                            }
                            <div class="small text-muted">
                                Ingresó: @item.FechaIngreso.ToString("dd/MM/yyyy")
                            </div>
                        </td>
                        <td>
                            <span class="badge bg-secondary">@item.Departamento</span>
                        </td>
                        <td>@item.Puesto</td>
                        <td>
                            <span class="badge @(item.TipoJornada == GEPCP_Ferreteria_El_Pana.Models.TipoJornada.Completa ? "bg-primary" : "bg-info")">
                                @(item.TipoJornada == GEPCP_Ferreteria_El_Pana.Models.TipoJornada.Completa ? "Completa" : "Media")
                            </span>
                        </td>
                        <td class="text-end fw-bold">₡@item.SalarioBase.ToString("N0")</td>
                        <td class="text-end text-primary">₡@item.ValorHora.ToString("N2")</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.Telefono))
                            {
                                <a href="tel:@item.Telefono" class="text-decoration-none d-block small">
                                    <i class="bi bi-phone"></i> @item.Telefono
                                </a>
                            }
                            @if (!string.IsNullOrEmpty(item.CorreoElectronico))
                            {
                                <a href="mailto:@item.CorreoElectronico" class="text-decoration-none d-block small">
                                    <i class="bi bi-envelope"></i> @item.CorreoElectronico
                                </a>
                            }
                            @if (string.IsNullOrEmpty(item.Telefono) && string.IsNullOrEmpty(item.CorreoElectronico))
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-center">
                            <span class="badge @(item.Estado == "Activo" ? "bg-success" : "bg-secondary")">
                                @item.Estado
                            </span>
                        </td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center flex-wrap">
                                <a asp-action="Details" asp-route-id="@item.EmpleadoId"
                                       asp-route-busqueda="@busqueda"
                                       class="btn btn-sm btn-outline-info" title="Ver detalles">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="DescargarHistorial" asp-route-id="@item.EmpleadoId"
                                       class="btn btn-sm btn-outline-dark" title="Descargar historial PDF">
                                    <i class="bi bi-file-earmark-pdf"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.EmpleadoId"
                                       class="btn btn-sm btn-warning" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @if (item.Estado == "Activo")
                                {
                                                                     <button type="button" class="btn btn-sm btn-secondary btnDesactivarEmpleadoLista"
                                                                        data-id="@item.EmpleadoId"
                                                                        data-nombre="@item.PrimerApellido @item.Nombre"
                                                                        data-busqueda="@busqueda"
                                                                        title="Desactivar">
                                                                        <i class="bi bi-pause-circle"></i>
                                                                    </button>
                                                            }
                                                            else
                                                            {
                                                                <button type="button" class="btn btn-sm btn-success btnActivarEmpleadoLista"
                                                                        data-id="@item.EmpleadoId"
                                                                        data-nombre="@item.PrimerApellido @item.Nombre"
                                                                        data-busqueda="@busqueda"
                                                                        title="Activar">
                                                                    <i class="bi bi-play-circle"></i>
                                                                </button>
                                                            }
                                                            <a asp-action="Delete" asp-route-id="@item.EmpleadoId"
                                                                   class="btn btn-sm btn-danger" title="Eliminar">
                                                                <i class="bi bi-trash"></i>
                                                            </a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
    </div>

         <div class="text-muted small mt-2 text-end">
             Total: <strong>@Model.Count()</strong> empleado(s) —
             Activos: <strong>@Model.Count(e => e.Estado == "Activo")</strong> /
             Inactivos: <strong>@Model.Count(e => e.Estado == "Inactivo")</strong>
         </div>
    }

    <!-- Modal Activar/Desactivar Empleado en Lista -->
    <div class="modal fade" id="confirmAccionEmpleadoListaModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background-color: #ffffff; border: 2px solid #FF7A00;">
                <div class="modal-header" style="background-color: #FF7A00; border-bottom: 2px solid #FF7A00;">
                    <h5 class="modal-title text-white fw-bold" id="modalAccionEmpleadoListaTitulo">
                        <i class="bi bi-exclamation-triangle"></i> Cambiar Estado
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" style="padding: 24px;">
                    <div style="background-color: #FFF5EB; border-left: 4px solid #FF7A00; padding: 16px; margin-bottom: 16px; border-radius: 6px;">
                        <div style="color: #333; font-weight: 600;" id="modalAccionEmpleadoListaMensaje">
                            <i class="bi bi-exclamation-triangle-fill" style="color: #FF7A00; margin-right: 8px;"></i>
                            Mensaje
                        </div>
                    </div>

                    <div style="background-color: #F8F8F8; border: 1px solid #E0E0E0; border-radius: 6px; padding: 12px;">
                        <p style="color: #888; font-size: 0.85rem; margin-bottom: 0;">
                            <i class="bi bi-info-circle" style="color: #FF7A00; margin-right: 6px;"></i>
                            Asegúrese de que esta es la acción correcta.
                        </p>
                    </div>
                </div>
                <div class="modal-footer" style="border-top: 1px solid #E0E0E0; padding: 12px 16px;">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle"></i> Cancelar
                    </button>
                    <button type="button" class="btn text-white fw-bold" style="background-color: #FF7A00; border-color: #FF7A00;" id="btnConfirmarAccionEmpleadoLista">
                        <i class="bi bi-check-circle"></i> Confirmar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Formularios ocultos para acciones de empleado -->
    <form method="post" asp-action="Desactivar" style="display:none;" id="formDesactivarEmpleadoLista">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" id="inputIdEmpleadoLista" />
        <input type="hidden" name="busqueda" id="inputBusquedaEmpleadoLista" />
    </form>
    <form method="post" asp-action="Activar" style="display:none;" id="formActivarEmpleadoLista">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" id="inputIdEmpleadoLista2" />
        <input type="hidden" name="busqueda" id="inputBusquedaEmpleadoLista2" />
    </form>

    @section Scripts {
         <script>
             // Preservar búsqueda en sessionStorage
             var input = document.getElementById('inputBusqueda');
             var key = 'empleados_busqueda';

             // Al cargar: si no hay valor en el input pero hay uno guardado, restaurarlo
             if (input && !input.value) {
                 var guardado = sessionStorage.getItem(key);
                 if (guardado) {
                     input.value = guardado;
                 }
             }

             // Al hacer submit: guardar el valor
             var form = document.getElementById('formBusqueda');
             if (form) {
                 form.addEventListener('submit', function() {
                     sessionStorage.setItem(key, input.value);
                 });
             }

             // Si hay valor en la URL, guardarlo también
             if (input && input.value) {
                 sessionStorage.setItem(key, input.value);
             }

             // Limpiar sessionStorage si se presiona Limpiar o Mostrar todos
             document.querySelectorAll('a[href*="busqueda"]').forEach(function(a) {
                 a.addEventListener('click', function() {
                     sessionStorage.removeItem(key);
                 });
             });

             // Modal de empleados en lista
             document.addEventListener('DOMContentLoaded', function() {
                 const btnsDesactivar = document.querySelectorAll('.btnDesactivarEmpleadoLista');
                 const btnsActivar = document.querySelectorAll('.btnActivarEmpleadoLista');
                 const formDesactivar = document.getElementById('formDesactivarEmpleadoLista');
                 const formActivar = document.getElementById('formActivarEmpleadoLista');
                 let accionActual = null;

                 const modal = new bootstrap.Modal(document.getElementById('confirmAccionEmpleadoListaModal'), {
                     backdrop: 'static',
                     keyboard: false
                 });

                 btnsDesactivar.forEach(function(btn) {
                     btn.addEventListener('click', function() {
                         accionActual = 'desactivar';
                         document.getElementById('modalAccionEmpleadoListaTitulo').textContent = 'Desactivar Empleado';
                         document.getElementById('modalAccionEmpleadoListaMensaje').innerHTML = 
                             '<i class="bi bi-exclamation-triangle-fill" style="color: #FF7A00; margin-right: 8px;"></i>' +
                             '¿Desactivar a ' + this.dataset.nombre + '?';
                         document.getElementById('inputIdEmpleadoLista').value = this.dataset.id;
                         document.getElementById('inputBusquedaEmpleadoLista').value = this.dataset.busqueda;
                         modal.show();
                     });
                 });

                 btnsActivar.forEach(function(btn) {
                     btn.addEventListener('click', function() {
                         accionActual = 'activar';
                         document.getElementById('modalAccionEmpleadoListaTitulo').textContent = 'Activar Empleado';
                         document.getElementById('modalAccionEmpleadoListaMensaje').innerHTML = 
                             '<i class="bi bi-exclamation-triangle-fill" style="color: #FF7A00; margin-right: 8px;"></i>' +
                             '¿Activar a ' + this.dataset.nombre + '?';
                         document.getElementById('inputIdEmpleadoLista2').value = this.dataset.id;
                         document.getElementById('inputBusquedaEmpleadoLista2').value = this.dataset.busqueda;
                         modal.show();
                     });
                 });

                 const btnConfirmar = document.getElementById('btnConfirmarAccionEmpleadoLista');
                 if (btnConfirmar) {
                     btnConfirmar.addEventListener('click', function() {
                         modal.hide();
                         Loading.show('Procesando acción...');
                         setTimeout(function() {
                             if (accionActual === 'desactivar') {
                                 formDesactivar.submit();
                             } else if (accionActual === 'activar') {
                                 formActivar.submit();
                             }
                         }, 100);
                     });
                 }
             });
         </script>
    }