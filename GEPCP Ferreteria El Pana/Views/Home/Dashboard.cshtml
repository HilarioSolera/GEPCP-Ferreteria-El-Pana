@{
    ViewData["Title"] = "Dashboard Ejecutivo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="mb-4">Dashboard - Período Activo: Julio 2025 Quincena 1</h2>

<div class="row">
    <div class="col-md-3">
        <div class="card text-white bg-success card-kpi">
            <div class="card-body">
                <h5><i class="bi bi-people"></i> Empleados Activos</h5>
                <h3>28</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-primary card-kpi">
            <div class="card-body">
                <h5><i class="bi bi-cash-stack"></i> Planilla Estimada</h5>
                <h3>₡4,850,000</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning card-kpi">
            <div class="card-body">
                <h5><i class="bi bi-credit-card"></i> Saldo Préstamos</h5>
                <h3>₡1,240,000</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info card-kpi">
            <div class="card-body">
                <h5><i class="bi bi-graph-up"></i> Comisiones Total</h5>
                <h3>₡320,000</h3>
            </div>
        </div>
    </div>
</div>