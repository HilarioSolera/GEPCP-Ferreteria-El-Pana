@model IEnumerable<GEPCP_Ferreteria_El_Pana.Models.EmpleadoViewModel>
@{
    ViewData["Title"] = "Empleados - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-people"></i> Empleados</h2>
    <a asp-action="Create" class="btn btn-success btn-lg">
        <i class="bi bi-person-plus"></i> Nuevo Empleado
    </a>
</div>

@* Barra de búsqueda *@
<form asp-action="Index" method="get" class="mb-4">
    <div class="input-group input-group-lg shadow-sm">
        <span class="input-group-text bg-white">
            <i class="bi bi-search text-muted"></i>
        </span>
        <input type="text" name="busqueda" value="@ViewBag.Busqueda"
               class="form-control border-start-0"
               placeholder="Buscar por nombre, cédula, puesto, departamento, correo o teléfono..." />
        <button type="submit" class="btn btn-primary px-4">Buscar</button>
        @if (!string.IsNullOrEmpty(ViewBag.Busqueda as string))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-x-circle"></i> Limpiar
            </a>
        }
    </div>
    @if (!string.IsNullOrEmpty(ViewBag.Busqueda as string))
    {
        <small class="text-muted ms-1 mt-1 d-block">
            Resultados para: <strong>"@ViewBag.Busqueda"</strong> —
            @Model.Count() empleado(s) encontrado(s)
        </small>
    }
</form>

@if (!Model.Any())
{
    <div class="alert alert-info text-center py-4">
        <i class="bi bi-inbox fs-3 d-block mb-2"></i>
        @if (!string.IsNullOrEmpty(ViewBag.Busqueda as string))
        {
            <span>No se encontraron empleados para "<strong>@ViewBag.Busqueda</strong>".</span>
        }
        else
        {
            <span>No hay empleados registrados aún.</span>
        }
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle mb-0">
            <thead style="background-color: #FF7A00; color: white;">
                <tr>
                    <th>Cédula</th>
                    <th>Nombre Completo</th>
                    <th>Departamento</th>
                    <th>Puesto</th>
                    <th>Jornada</th>
                    <th class="text-end">Salario Base</th>
                    <th class="text-end">Valor Hora</th>
                    <th>Contacto</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="@(item.Estado == "Inactivo" ? "table-light text-muted" : "")">
                        <td><code>@item.Cedula</code></td>
                        <td>
                            <strong>@item.PrimerApellido @item.SegundoApellido</strong>
                            @item.Nombre
                            <div class="small text-muted">
                                Ingresó: @item.FechaIngreso.ToString("dd/MM/yyyy")
                            </div>
                        </td>
                        <td>
                            <span class="badge bg-secondary">@item.Departamento</span>
                        </td>
                        <td>@item.Puesto</td>
                        <td>
                            <span class="badge @(item.TipoJornada == GEPCP_Ferreteria_El_Pana.Models.TipoJornada.Completa ? "bg-primary" : "bg-info")">
                                @(item.TipoJornada == GEPCP_Ferreteria_El_Pana.Models.TipoJornada.Completa
                                    ? "Completa" : "Media")
                            </span>
                        </td>
                        <td class="text-end fw-bold">₡@item.SalarioBase.ToString("N0")</td>
                        <td class="text-end text-primary">₡@item.ValorHora.ToString("N2")</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.Telefono))
                            {
                                <a href="tel:@item.Telefono" class="text-decoration-none d-block small">
                                    <i class="bi bi-phone"></i> @item.Telefono
                                </a>
                            }
                            @if (!string.IsNullOrEmpty(item.CorreoElectronico))
                            {
                                <a href="mailto:@item.CorreoElectronico"
                                       class="text-decoration-none d-block small">
                                    <i class="bi bi-envelope"></i> @item.CorreoElectronico
                                </a>
                            }
                            @if (string.IsNullOrEmpty(item.Telefono) &&
                                                             string.IsNullOrEmpty(item.CorreoElectronico))
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-center">
                            <span class="badge @(item.Estado == "Activo" ? "bg-success" : "bg-secondary")">
                                @item.Estado
                            </span>
                        </td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center flex-wrap">
                                <a asp-action="Details" asp-route-id="@item.EmpleadoId"
                                       class="btn btn-sm btn-outline-info" title="Ver detalles">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.EmpleadoId"
                                       class="btn btn-sm btn-warning" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @if (item.Estado == "Activo")
                                {
                                    <form asp-action="Desactivar" method="post" class="d-inline"
                                          onsubmit="return confirm('¿Desactivar a @item.PrimerApellido @item.Nombre?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.EmpleadoId" />
                                        <button type="submit" class="btn btn-sm btn-secondary"
                                                title="Desactivar">
                                            <i class="bi bi-pause-circle"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="Activar" method="post" class="d-inline"
                                          onsubmit="return confirm('¿Activar a @item.PrimerApellido @item.Nombre?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.EmpleadoId" />
                                        <button type="submit" class="btn btn-sm btn-success"
                                                title="Activar">
                                            <i class="bi bi-play-circle"></i>
                                        </button>
                                    </form>
                                }
                                <a asp-action="Delete" asp-route-id="@item.EmpleadoId"
                                       class="btn btn-sm btn-danger" title="Eliminar">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="text-muted small mt-2 text-end">
        Total: <strong>@Model.Count()</strong> empleado(s) —
        Activos: <strong>@Model.Count(e => e.Estado == "Activo")</strong> /
        Inactivos: <strong>@Model.Count(e => e.Estado == "Inactivo")</strong>
    </div>
}