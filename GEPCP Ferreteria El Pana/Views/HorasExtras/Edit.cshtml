@model GEPCP_Ferreteria_El_Pana.Models.HorasExtras
@{
    ViewData["Title"] = "Editar Horas Extras - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-pencil"></i> Editar Horas Extras</h2>
    <a asp-action="Index" asp-route-periodoId="@Model.PeriodoPagoId"
           class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div class="card shadow-sm border-0" style="max-width: 700px;">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="HorasExtrasId" />
            <input type="hidden" asp-for="EmpleadoId" />
            <input type="hidden" asp-for="PeriodoPagoId" />

            <div class="row g-3">

                <div class="col-12">
                    <div class="alert alert-info py-2 mb-0">
                        <i class="bi bi-person-circle"></i>
                        <strong>@Model.Empleado?.PrimerApellido @Model.Empleado?.Nombre</strong>
                        — @Model.PeriodoPago?.Descripcion
                    </div>
                </div>

                <div class="col-md-4">
                    <label asp-for="TotalHoras" class="form-label fw-bold">
                        <i class="bi bi-hourglass-split"></i> Total Horas <span class="text-danger">*</span>
                    </label>
                    <input asp-for="TotalHoras" type="number" step="0.01"
                           min="0.01" max="999.99"
                           class="form-control form-control-lg" id="inputHoras" />
                    <span asp-validation-for="TotalHoras" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Porcentaje" class="form-label fw-bold">
                        <i class="bi bi-percent"></i> Porcentaje <span class="text-danger">*</span>
                    </label>
                    <select asp-for="Porcentaje" class="form-select form-select-lg"
                            id="selectPorcentaje">
                        <option value="1.5">150% — Hora Extra Normal</option>
                        <option value="2.0">200% — Hora Extra Doble</option>
                    </select>
                    <span asp-validation-for="Porcentaje" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold text-muted">
                        <i class="bi bi-calculator"></i> Monto Estimado
                    </label>
                    <div class="form-control form-control-lg bg-light text-center fw-bold text-success"
                         id="montoRef">
                        ₡@Model.MontoTotal.ToString("N0")
                    </div>
                    <div class="form-text text-muted" id="valorHoraRef">
                        Valor hora actual: ₡@Model.ValorHora.ToString("N2")
                    </div>
                </div>

            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-warning btn-lg px-5">
                    <i class="bi bi-check-circle"></i> Guardar Cambios
                </button>
                <a asp-action="Index" asp-route-periodoId="@Model.PeriodoPagoId"
                   class="btn btn-secondary btn-lg px-5">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        var empleadoId = @Model.EmpleadoId;
        var valorHoraActual = @Model.ValorHora.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);

        function calcularMonto() {
            var horas      = parseFloat(document.getElementById('inputHoras').value) || 0;
            var porcentaje = parseFloat(document.getElementById('selectPorcentaje').value) || 1.5;
            var montoRef   = document.getElementById('montoRef');
            var hint       = document.getElementById('valorHoraRef');

            if (horas > 0) {
                var monto = horas * valorHoraActual * porcentaje;
                montoRef.innerHTML = '&#8353;' +
                    monto.toLocaleString('es-CR', {minimumFractionDigits: 2});
                hint.innerHTML =
                    'Valor hora: <strong>&#8353;' +
                    parseFloat(valorHoraActual).toLocaleString('es-CR', {minimumFractionDigits: 2}) +
                    '</strong> &times; ' + horas + ' hrs &times; ' + (porcentaje * 100) + '%';
            } else {
                montoRef.textContent = '—';
            }
        }

        document.getElementById('inputHoras').addEventListener('input', calcularMonto);
        document.getElementById('selectPorcentaje').addEventListener('change', calcularMonto);
        calcularMonto();
    </script>
}