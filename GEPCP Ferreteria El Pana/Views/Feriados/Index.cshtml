@model List<GEPCP_Ferreteria_El_Pana.Models.Feriado>
@{
    ViewData["Title"] = "Feriados - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int anio = ViewBag.AnioActual;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-calendar-event"></i> Feriados</h2>
    <a asp-action="Create" class="btn btn-success btn">
        <i class="bi bi-plus-circle"></i> Nuevo Feriado
    </a>
</div>

@* KPIs *@
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-primary">@ViewBag.TotalFeriados</div>
            <div class="text-muted small">Total Feriados @anio</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-danger">@ViewBag.TotalObligatorio</div>
            <div class="text-muted small">Obligatorios</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-warning">@ViewBag.TotalNoObligatorio</div>
            <div class="text-muted small">No Obligatorios</div>
        </div>
    </div>
</div>

@* Navegación por año *@
<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" asp-route-anio="@ViewBag.AnioAnterior"
           class="btn btn-outline-secondary">
        <i class="bi bi-chevron-left"></i> @ViewBag.AnioAnterior
    </a>
    <h5 class="mb-0 fw-bold">@anio</h5>
    <a asp-action="Index" asp-route-anio="@ViewBag.AnioSiguiente"
           class="btn btn-outline-secondary">
        @ViewBag.AnioSiguiente <i class="bi bi-chevron-right"></i>
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center py-4">
        <i class="bi bi-inbox fs-3 d-block mb-2"></i>
        No hay feriados registrados para @anio.
        <div class="mt-2">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Agregar feriado
            </a>
        </div>
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle mb-0">
            <thead style="background-color: #FF7A00; color: white;">
                <tr>
                    <th>Fecha</th>
                    <th>Día</th>
                    <th>Nombre</th>
                    <th class="text-center">Tipo</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in Model)
                {
                    <tr>
                        <td class="fw-bold">@f.Fecha.ToString("dd/MM/yyyy")</td>
                        <td class="text-muted" style="text-transform:capitalize;">
                            @f.Fecha.ToString("dddd", new System.Globalization.CultureInfo("es-CR"))
                        </td>
                        <td>@f.Nombre</td>
                        <td class="text-center">
                                        @if (f.Tipo == GEPCP_Ferreteria_El_Pana.Models.TipoFeriado.Obligatorio)
                                        {
                                            <span class="badge bg-danger">Obligatorio</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">No Obligatorio</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex gap-1 justify-content-center">
                                            <a asp-action="Edit" asp-route-id="@f.FeriadoId"
                                                   class="btn btn-sm btn-warning" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <button type="button" class="btn btn-sm btn-danger btnEliminarFeriado"
                                                    data-id="@f.FeriadoId"
                                                    data-nombre="@f.Nombre"
                                                    title="Eliminar">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                            <a asp-action="PagosPorPeriodo" class="btn btn-sm btn-primary">
                                                <i class="bi bi-cash-coin"></i> Pagos
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
            </tbody>
        </table>
    </div>
}

<!-- Modal Eliminar Feriado -->
<div class="modal fade" id="confirmEliminarFeriadoModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background-color: #ffffff; border: 2px solid #FF7A00;">
            <div class="modal-header" style="background-color: #FF7A00; border-bottom: 2px solid #FF7A00;">
                <h5 class="modal-title text-white fw-bold">
                    <i class="bi bi-exclamation-triangle"></i> Eliminar Feriado
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding: 24px;">
                <div style="background-color: #FFF5EB; border-left: 4px solid #FF7A00; padding: 16px; margin-bottom: 16px; border-radius: 6px;">
                    <div style="color: #333; font-weight: 600;">
                        <i class="bi bi-exclamation-triangle-fill" style="color: #FF7A00; margin-right: 8px;"></i>
                        ¿Eliminar el feriado <span id="modalFeriadoNombre"></span>?
                    </div>
                </div>

                <div style="background-color: #F8F8F8; border: 1px solid #E0E0E0; border-radius: 6px; padding: 12px;">
                    <p style="color: #888; font-size: 0.85rem; margin-bottom: 0;">
                        <i class="bi bi-info-circle" style="color: #FF7A00; margin-right: 6px;"></i>
                        Esta operación no se puede deshacer.
                    </p>
                </div>
            </div>
            <div class="modal-footer" style="border-top: 1px solid #E0E0E0; padding: 12px 16px;">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle"></i> Cancelar
                </button>
                <button type="button" class="btn text-white fw-bold" style="background-color: #FF7A00; border-color: #FF7A00;" id="btnConfirmarEliminarFeriado">
                    <i class="bi bi-check-circle"></i> Sí, Eliminar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Formulario oculto -->
<form method="post" asp-action="Delete" style="display:none;" id="formEliminarFeriado">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="inputIdFeriado" />
</form>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const botonesEliminar = document.querySelectorAll('.btnEliminarFeriado');
        const modalEliminar = new bootstrap.Modal(document.getElementById('confirmEliminarFeriadoModal'), {
            backdrop: 'static',
            keyboard: false
        });
        const btnConfirmar = document.getElementById('btnConfirmarEliminarFeriado');
        const formEliminar = document.getElementById('formEliminarFeriado');
        const inputId = document.getElementById('inputIdFeriado');

        botonesEliminar.forEach(function(btn) {
            btn.addEventListener('click', function() {
                document.getElementById('modalFeriadoNombre').textContent = this.dataset.nombre;
                inputId.value = this.dataset.id;
                modalEliminar.show();
            });
        });

        btnConfirmar.addEventListener('click', function() {
            modalEliminar.hide();
            Loading.show('Eliminando feriado...');
            setTimeout(function() {
                formEliminar.submit();
            }, 100);
        });
    });
</script>