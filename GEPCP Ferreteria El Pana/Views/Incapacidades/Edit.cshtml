@model GEPCP_Ferreteria_El_Pana.Models.Incapacidad
@{
    ViewData["Title"] = "Editar Incapacidad - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-pencil"></i> Editar Incapacidad</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div class="card shadow-sm border-0" style="max-width: 750px;">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="IncapacidadId" />

            <div class="row g-3">

                <div class="col-12">
                    <label asp-for="EmpleadoId" class="form-label fw-bold">
                        <i class="bi bi-person"></i> Empleado <span class="text-danger">*</span>
                    </label>
                    <select asp-for="EmpleadoId" asp-items="ViewBag.Empleados"
                            class="form-select form-select-lg" id="selectEmpleado">
                        <option value="">— Seleccione un empleado —</option>
                    </select>
                    <span asp-validation-for="EmpleadoId" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Entidad" class="form-label fw-bold">
                        <i class="bi bi-building-check"></i> Entidad <span class="text-danger">*</span>
                    </label>
                    <select asp-for="Entidad" class="form-select form-select-lg"
                            id="selectEntidad">
                        <option value="1">CCSS</option>
                        <option value="2">INS</option>
                    </select>
                    <span asp-validation-for="Entidad" class="text-danger small"></span>
                </div>

                <div class="col-md-8">
                    <label asp-for="TipoIncapacidad" class="form-label fw-bold">
                        <i class="bi bi-clipboard2-pulse"></i> Tipo <span class="text-danger">*</span>
                    </label>
                    <select asp-for="TipoIncapacidad" class="form-select form-select-lg">
                        <option value="Enfermedad común">Enfermedad común</option>
                        <option value="Accidente de tránsito">Accidente de tránsito</option>
                        <option value="Accidente laboral">Accidente laboral</option>
                        <option value="Licencia de maternidad">Licencia de maternidad</option>
                        <option value="Recuperación">Recuperación</option>
                        <option value="Otro">Otro</option>
                    </select>
                    <span asp-validation-for="TipoIncapacidad" class="text-danger small"></span>
                </div>

                <div class="col-md-5">
                    <label asp-for="FechaInicio" class="form-label fw-bold">
                        <i class="bi bi-calendar-check"></i> Fecha Inicio <span class="text-danger">*</span>
                    </label>
                    <input asp-for="FechaInicio" type="date"
                           class="form-control form-control-lg" id="inputFechaInicio" />
                    <span asp-validation-for="FechaInicio" class="text-danger small"></span>
                </div>

                <div class="col-md-5">
                    <label asp-for="FechaFin" class="form-label fw-bold">
                        <i class="bi bi-calendar-x"></i> Fecha Fin <span class="text-danger">*</span>
                    </label>
                    <input asp-for="FechaFin" type="date"
                           class="form-control form-control-lg" id="inputFechaFin" />
                    <span asp-validation-for="FechaFin" class="text-danger small"></span>
                </div>

                <div class="col-md-2">
                    <label class="form-label fw-bold text-muted">Días</label>
                    <div class="form-control form-control-lg bg-light text-center fw-bold text-primary"
                         id="totalDiasRef">
                        @Model.TotalDias
                    </div>
                </div>

                <div class="col-md-6" id="divTiquete">
                    <label asp-for="TiqueteCCSS" class="form-label fw-bold">
                        <i class="bi bi-ticket-perforated"></i> Tiquete CCSS
                    </label>
                    <input asp-for="TiqueteCCSS" class="form-control form-control-lg"
                           maxlength="50" />
                    <span asp-validation-for="TiqueteCCSS" class="text-danger small"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="PorcentajePago" class="form-label fw-bold">
                        <i class="bi bi-percent"></i> % Pago <span class="text-danger">*</span>
                    </label>
                    <select asp-for="PorcentajePago" class="form-select form-select-lg">
                        <option value="50">50%</option>
                        <option value="60">60%</option>
                        <option value="100">100%</option>
                    </select>
                    <span asp-validation-for="PorcentajePago" class="text-danger small"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="ResponsablePago" class="form-label fw-bold">
                        <i class="bi bi-person-check"></i> Responsable <span class="text-danger">*</span>
                    </label>
                    <select asp-for="ResponsablePago" class="form-select form-select-lg">
                        <option value="1">Patrono</option>
                        <option value="2">CCSS</option>
                        <option value="3">INS</option>
                    </select>
                    <span asp-validation-for="ResponsablePago" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Observaciones" class="form-label fw-bold">
                        <i class="bi bi-chat-text"></i> Observaciones
                        <span class="text-muted fw-normal small">(opcional)</span>
                    </label>
                    <input asp-for="Observaciones" class="form-control form-control-lg"
                           maxlength="200" />
                    <span asp-validation-for="Observaciones" class="text-danger small"></span>
                </div>

            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-warning btn-lg px-5">
                    <i class="bi bi-check-circle"></i> Guardar Cambios
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-lg px-5">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function toggleTiquete() {
            var entidad = parseInt(document.getElementById('selectEntidad').value);
            document.getElementById('divTiquete').style.display =
                entidad === 1 ? 'block' : 'none';
        }

        function calcularDias() {
            var fi   = new Date(document.getElementById('inputFechaInicio').value);
            var ff   = new Date(document.getElementById('inputFechaFin').value);
            var dias = Math.round((ff - fi) / (1000 * 60 * 60 * 24)) + 1;
            document.getElementById('totalDiasRef').textContent = dias > 0 ? dias : '—';
        }

        document.getElementById('selectEntidad').addEventListener('change', toggleTiquete);
        document.getElementById('inputFechaInicio').addEventListener('change', calcularDias);
        document.getElementById('inputFechaFin').addEventListener('change', calcularDias);

        toggleTiquete();
        calcularDias();
    </script>
}