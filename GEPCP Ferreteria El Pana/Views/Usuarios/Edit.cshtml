@model GEPCP_Ferreteria_El_Pana.Models.UsuarioEditViewModel
@{
    ViewData["Title"] = "Editar Usuario - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-person-gear"></i> Editar Usuario</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div class="card shadow-sm border-0" style="max-width: 650px;">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="UsuarioId" />

            <div class="row g-3">

                <div class="col-12">
                    <div class="alert alert-info py-2 small mb-0">
                        <i class="bi bi-person-circle"></i>
                        Usuario: <strong>@Model.NombreUsuario</strong>
                    </div>
                </div>

                <div class="col-12">
                    <label asp-for="NombreCompleto" class="form-label fw-bold">
                        <i class="bi bi-person-badge"></i> Nombre Completo <span class="text-danger">*</span>
                    </label>
                    <input asp-for="NombreCompleto" class="form-control"
                           maxlength="100" placeholder="Ej: María López Jiménez" />
                    <span asp-validation-for="NombreCompleto" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="CorreoElectronico" class="form-label fw-bold">
                        <i class="bi bi-envelope"></i> Correo Electrónico
                        <span class="text-muted fw-normal small">(requerido para recuperar contraseña)</span>
                    </label>
                    <input asp-for="CorreoElectronico" type="email"
                           class="form-control"
                           maxlength="150" placeholder="Ej: maria@ferreteria.com" />
                    <span asp-validation-for="CorreoElectronico" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Rol" class="form-label fw-bold">
                        <i class="bi bi-shield"></i> Rol <span class="text-danger">*</span>
                    </label>
                    <select asp-for="Rol" class="form-select">
                        <option value="RRHH">RRHH</option>
                        <option value="Jefatura">Jefatura</option>
                    </select>
                    <span asp-validation-for="Rol" class="text-danger small"></span>
                </div>

            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-warning btn px-5">
                    <i class="bi bi-check-circle"></i> Guardar Cambios
                </button>
                <a asp-action="Index" class="btn btn-secondary btn px-5">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}