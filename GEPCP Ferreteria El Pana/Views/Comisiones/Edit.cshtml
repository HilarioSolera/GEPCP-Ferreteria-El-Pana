@model GEPCP_Ferreteria_El_Pana.Models.Comision
@{
    ViewData["Title"] = "Editar Comisión - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-pencil"></i> Editar Comisión</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-2">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ComisionId" />
            <input type="hidden" asp-for="EmpleadoId" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger mb-2" style="font-size: 0.75rem;">
                    <ul class="mb-0">
                        @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@e.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }

            <div class="row g-1">

                @* ── Empleado solo lectura ── *@
                <div class="col-12">
                    <label class="form-label fw-bold small">
                        <i class="bi bi-person"></i> Empleado
                    </label>
                    <div class="alert alert-secondary py-1 d-flex align-items-center gap-2 mb-0" style="font-size: 0.85rem;">
                        <i class="bi bi-person-badge"></i>
                        <strong>@ViewBag.EmpleadoNombre</strong>
                        <span class="text-muted small ms-1">@ViewBag.EmpleadoCedula</span>
                        <span class="badge bg-secondary ms-auto" style="font-size:0.6rem;">
                            Solo lectura
                        </span>
                    </div>
                </div>

                @* ── Período ── *@
                <div class="col-12">
                    <label class="form-label fw-bold small">
                        <i class="bi bi-calendar2-range"></i> Período de Pago
                        <span class="text-danger">*</span>
                    </label>
                    <select name="PeriodoPagoId" id="selectPeriodo"
                            class="form-select form-select-sm">
                        <option value="">— Seleccione un período —</option>
                        @foreach (var p in ViewBag.PeriodosSelect as IEnumerable<dynamic>
                                                                    ?? Enumerable.Empty<dynamic>())
                        {
                            <option value="@p.PeriodoPagoId"
                                    data-inicio="@p.FechaInicio.ToString("yyyy-MM-dd")"
                                    data-fin="@p.FechaFin.ToString("yyyy-MM-dd")"
                                    selected="@(p.Seleccionado ? "selected" : null)">
                                @p.Descripcion
                            </option>
                        }
                    </select>
                    <div class="form-text text-muted" id="rangoPeriodo" style="font-size: 0.7rem;"></div>
                </div>

                @* ── Fecha ── *@
                <div class="col-md-4">
                    <label asp-for="Fecha" class="form-label fw-bold small">
                        <i class="bi bi-calendar"></i> Fecha <span class="text-danger">*</span>
                    </label>
                    <input asp-for="Fecha" type="date" id="inputFecha"
                           class="form-control form-control-sm" />
                    <span asp-validation-for="Fecha" class="text-danger" style="font-size: 0.7rem;"></span>
                </div>

                @* ── Monto ── *@
                <div class="col-md-4">
                    <label asp-for="Monto" class="form-label fw-bold small">
                        <i class="bi bi-cash"></i> Monto (₡) <span class="text-danger">*</span>
                    </label>
                    <input asp-for="Monto" type="number" min="1" step="0.01"
                           max="9999999.99" class="form-control form-control-sm" />
                    <span asp-validation-for="Monto" class="text-danger" style="font-size: 0.7rem;"></span>
                </div>

                @* ── Descripción ── *@
                <div class="col-md-4">
                    <label asp-for="Descripcion" class="form-label fw-bold small">
                        <i class="bi bi-chat-text"></i> Descripción
                        <span class="text-danger">*</span>
                    </label>
                    <input asp-for="Descripcion" class="form-control form-control-sm"
                           maxlength="200" />
                    <span asp-validation-for="Descripcion" class="text-danger" style="font-size: 0.7rem;"></span>
                </div>

            </div>

            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-warning btn-sm px-4">
                    <i class="bi bi-check-circle"></i> Guardar Cambios
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-sm px-4">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        var selectPeriodo = document.getElementById('selectPeriodo');
        var inputFecha = document.getElementById('inputFecha');
        var rangoInfo = document.getElementById('rangoPeriodo');

        function actualizarRango() {
            var opt = selectPeriodo.options[selectPeriodo.selectedIndex];
            var ini = opt?.dataset?.inicio;
            var fin = opt?.dataset?.fin;
            if (ini && fin) {
                inputFecha.min = ini;
                inputFecha.max = fin;
                rangoInfo.textContent =
                    'Fecha entre ' +
                    new Date(ini + 'T00:00:00').toLocaleDateString('es-CR') +
                    ' y ' +
                    new Date(fin + 'T00:00:00').toLocaleDateString('es-CR');
            } else {
                inputFecha.min = '';
                inputFecha.max = '';
                rangoInfo.textContent = '';
            }
        }
        selectPeriodo.addEventListener('change', actualizarRango);
        actualizarRango();
    </script>
}