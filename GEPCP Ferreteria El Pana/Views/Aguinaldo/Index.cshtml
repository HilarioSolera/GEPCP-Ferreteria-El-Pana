@model List<GEPCP_Ferreteria_El_Pana.Models.Aguinaldo>
@using GEPCP_Ferreteria_El_Pana.Models
@{
    ViewData["Title"] = "Aguinaldos - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var anioActual = (int)(ViewBag.AnioActual ?? DateTime.Today.Year);
    var anios = ViewBag.Anios as List<int> ?? new List<int> { anioActual };
    var periodosMap = ViewBag.PeriodosContribuyentes as Dictionary<int, List<PeriodoPago>>
                      ?? new Dictionary<int, List<PeriodoPago>>();
    var planillasMap = ViewBag.PlanillasContribuyentes as Dictionary<int, List<PlanillaEmpleado>>
                      ?? new Dictionary<int, List<PlanillaEmpleado>>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-gift"></i> Aguinaldos @anioActual</h2>
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-success btn">
            <i class="bi bi-calculator"></i> Calcular manualmente
        </a>
        @if (Context.Session.GetString("Rol") == "RRHH")
        {
            <button type="button" class="btn btn-primary btnCalcularAguinaldoAutomatico" data-anio="@anioActual">
                <i class="bi bi-calculator"></i> Calcular Automático
            </button>
        }
    </div>
</div>

<!-- Filtros -->
<form asp-action="Index" method="get" class="row g-3 mb-4">
    <div class="col-md-3">
        <select name="anio" class="form-select" onchange="this.form.submit()">
            @foreach (var a in anios)
            {
                <option value="@a" selected="@(a == anioActual)">Aguinaldo @a</option>
            }
        </select>
    </div>
    <div class="col-md-7">
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input type="text" name="busqueda" value="@ViewBag.Busqueda"
                   class="form-control" placeholder="Buscar por nombre, apellido o cédula..." />
            <button type="submit" class="btn btn-outline-secondary">
                <i class="bi bi-search"></i> Buscar
            </button>
        </div>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100 btn">Filtrar</button>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info text-center py-5">
        <i class="bi bi-inbox fs-1 d-block mb-3"></i>
        No hay aguinaldos registrados para este año.<br>
        Usa el botón "Calcular manualmente" o "Calcular Automático".
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead style="background:#FF7A00; color:white;">
                <tr>
                    <th>Empleado</th>
                    <th>Período base</th>
                    <th>Períodos incluidos</th>
                    <th>Fecha de Pago</th>
                    <th class="text-end">Monto Total</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model)
                {
                    var periodos = periodosMap.ContainsKey(a.AguinaldoId)
                        ? periodosMap[a.AguinaldoId]
                        : new List<PeriodoPago>();
                    var planillas = planillasMap.ContainsKey(a.AguinaldoId)
                        ? planillasMap[a.AguinaldoId]
                        : new List<PlanillaEmpleado>();
                    var collapseId = $"periodos-{a.AguinaldoId}";
                    var esProporcional = a.PeriodosConsiderados > 0 && a.PeriodosConsiderados < 24;
                    <tr>
                        <td>
                            <strong>@a.Empleado.PrimerApellido @a.Empleado.Nombre</strong><br>
                            <small class="text-muted">@a.Empleado.Puesto — @a.Empleado.Departamento</small>
                            @if (esProporcional)
                            {
                                <br><span class="badge bg-warning text-dark mt-1" title="Aguinaldo proporcional MTSS — empleado con menos de 12 meses en el período">
                                    <i class="bi bi-clock-history me-1"></i>Proporcional
                                </span>
                            }
                        </td>
                        <td>
                            @a.FechaInicio.ToString("dd/MM/yyyy") <span class="text-muted">→</span>
                            @a.FechaFin.ToString("dd/MM/yyyy")
                        </td>
                        <td>
                            @if (periodos.Any())
                            {
                                <button class="btn btn-sm btn-outline-secondary py-0 px-2"
                                        type="button"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#@collapseId"
                                        aria-expanded="false">
                                    @periodos.Count período(s)
                                    <i class="bi bi-chevron-down ms-1"></i>
                                </button>
                                <div class="collapse mt-2" id="@collapseId">
                                    @{
                                        // Agrupar por mes/año
                                        var gruposMes = planillas
                                            .GroupBy(pe => new { pe.PeriodoPago.Anio, pe.PeriodoPago.Mes })
                                            .OrderBy(g => g.Key.Anio).ThenBy(g => g.Key.Mes)
                                            .ToList();

                                        string[] nombresMes = { "", "Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio",
                                                                  "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre" };
                                    }
                                    <table class="table table-sm table-bordered mb-1" style="font-size:0.79rem;">
                                        <thead style="background:#FF7A00;color:white;">
                                            <tr>
                                                <th>Mes</th>
                                                <th class="text-center">Días</th>
                                                <th class="text-end">Sal. Bruto (₡)</th>
                                                <th>Observación</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var grupo in gruposMes)
                                            {
                                                var planillasGrupo = grupo.ToList();
                                                var tipoPeriodoGrupo = planillasGrupo.First().PeriodoPago.TipoPeriodo;

                                                // Períodos esperados por mes según tipo
                                                int periodosEsperados = tipoPeriodoGrupo == TipoPeriodo.Mensual ? 1 : 2;
                                                bool mesCompleto = planillasGrupo.Count >= periodosEsperados;

                                                // Hay prorrateo si alguna planilla tiene DiasTrabajados < días del período
                                                bool tieneProrrateo = planillasGrupo.Any(pe =>
                                                    pe.DiasTrabajados > 0 &&
                                                    pe.DiasTrabajados < (pe.PeriodoPago.FechaFin - pe.PeriodoPago.FechaInicio).Days + 1);

                                                bool esParcial = !mesCompleto || tieneProrrateo;

                                                var brutoGrupo = planillasGrupo.Sum(pe => pe.TotalDevengado);
                                                var netoGrupo  = planillasGrupo.Sum(pe => pe.NetoAPagar);
                                                var nombreMes  = nombresMes[grupo.Key.Mes];

                                                if (!esParcial)
                                                {
                                                    // Mes completo → una sola fila con neto
                                                    <tr class="table-light">
                                                        <td class="fw-semibold">@nombreMes @grupo.Key.Anio</td>
                                                        <td class="text-center text-muted">—</td>
                                                        <td class="text-end fw-bold">₡@brutoGrupo.ToString("N2")</td>
                                                        <td>
                                                            <span class="badge bg-success" style="font-size:0.70rem;">
                                                                <i class="bi bi-check-circle me-1"></i>Mes completo
                                                            </span>
                                                        </td>
                                                    </tr>
                                                }
                                                else
                                                {
                                                    // Mes parcial → una fila por período con días reales y bruto
                                                    foreach (var pe in planillasGrupo.OrderBy(x => x.PeriodoPago.FechaInicio))
                                                    {
                                                        int diasPeriodo    = (pe.PeriodoPago.FechaFin - pe.PeriodoPago.FechaInicio).Days + 1;
                                                        int diasEfectivos  = pe.DiasTrabajados > 0 ? pe.DiasTrabajados : diasPeriodo;
                                                        bool esDiasParcial = diasEfectivos < diasPeriodo;

                                                        string labelPeriodo = tipoPeriodoGrupo == TipoPeriodo.Mensual
                                                            ? $"{nombreMes} {grupo.Key.Anio}"
                                                            : $"Quincena {(int)pe.PeriodoPago.Quincena} — {nombreMes} {grupo.Key.Anio}";

                                                        <tr @(esDiasParcial ? "class=table-warning" : "")>
                                                            <td>
                                                                <span class="fw-semibold">@labelPeriodo</span><br>
                                                                <small class="text-muted">
                                                                    @pe.PeriodoPago.FechaInicio.ToString("dd/MM") al @pe.PeriodoPago.FechaFin.ToString("dd/MM/yyyy")
                                                                </small>
                                                            </td>
                                                            <td class="text-center">
                                                                @if (esDiasParcial)
                                                                {
                                                                    <span class="fw-bold text-danger">
                                                                        @diasEfectivos <small class="fw-normal text-muted">/ @diasPeriodo días</small>
                                                                    </span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="text-muted">@diasPeriodo días</span>
                                                                }
                                                            </td>
                                                            <td class="text-end fw-bold">₡@pe.TotalDevengado.ToString("N2")</td>
                                                            <td>
                                                                @if (esDiasParcial)
                                                                {
                                                                    <span class="badge bg-danger" style="font-size:0.70rem;">
                                                                        <i class="bi bi-clock-history me-1"></i>Parcial — @diasEfectivos día(s)
                                                                    </span>
                                                                }
                                                                else if (!mesCompleto)
                                                                {
                                                                    <span class="badge bg-info text-dark" style="font-size:0.70rem;">
                                                                        <i class="bi bi-exclamation-circle me-1"></i>Solo quincena @((int)pe.PeriodoPago.Quincena)
                                                                    </span>
                                                                }
                                                            </td>
                                                        </tr>
                                                    }
                                                }
                                            }
                                        </tbody>
                                        @if (planillas.Any())
                                        {
                                            <tfoot style="background:#fff3e0;">
                                                <tr>
                                                    <td colspan="2" class="text-end fw-bold">Total bruto del período:</td>
                                                    <td class="text-end fw-bold">₡@planillas.Sum(x => x.TotalDevengado).ToString("N2")</td>
                                                    <td></td>
                                                </tr>
                                            </tfoot>
                                        }
                                    </table>
                                    @if (a.SumaDevengados > 0)
                                    {
                                        <div class="mt-1 px-1 text-muted" style="font-size:0.76rem;">
                                            <i class="bi bi-calculator me-1"></i>
                                            Fórmula MTSS: ₡@a.SumaDevengados.ToString("N2") ÷ 12 = <strong class="text-dark">₡@a.MontoTotal.ToString("N2")</strong>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="text-muted small">Sin períodos cerrados</span>
                            }
                        </td>
                        <td>@a.FechaPago.ToString("dd/MM/yyyy")</td>
                        <td class="text-end fw-bold text-success fs-5">
                            ₡@a.MontoTotal.ToString("N0")
                        </td>
                        <td class="text-center">
                            <a asp-action="DescargarPDF" asp-route-id="@a.AguinaldoId"
                                   class="btn btn-sm btn-outline-danger me-1 long-action" data-loading-message="Generando PDF..." title="Descargar PDF">
                                <i class="bi bi-file-earmark-pdf"></i>
                            </a>
                            @if (!string.IsNullOrEmpty(a.Empleado.CorreoElectronico))
                            {
                                                            <form asp-action="EnviarPorEmail" method="post" class="d-inline form-loading" data-loading-message="Enviando correo a @a.Empleado.CorreoElectronico...">
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="id" value="@a.AguinaldoId" />
                                                                <button type="submit" class="btn btn-sm btn-outline-success me-1" title="Enviar correo">
                                                                    <i class="bi bi-envelope"></i>
                                                                </button>
                                                            </form>
                                                        }
                                                        <a asp-action="Edit" asp-route-id="@a.AguinaldoId"
                                                               class="btn btn-sm btn-warning me-1" title="Editar">
                                                            <i class="bi bi-pencil"></i>
                                                        </a>
                                                        @if (Context.Session.GetString("Rol") == "RRHH")
                                                        {
                                                            <button type="button" class="btn btn-sm btn-danger btnEliminarAguinaldo"
                                                                    data-id="@a.AguinaldoId"
                                                                    data-empleado="@a.Empleado.PrimerApellido @a.Empleado.Nombre"
                                                                    title="Eliminar">
                                                                <i class="bi bi-trash"></i>
                                                            </button>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                                     </tbody>
                                                 </table>
                                             </div>
                                        }

                                        <!-- Modal Eliminar Aguinaldo -->
                                        <div class="modal fade" id="confirmEliminarAguinaldoModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
                                            <div class="modal-dialog modal-dialog-centered">
                                                <div class="modal-content" style="background-color: #ffffff; border: 2px solid #FF7A00;">
                                                    <div class="modal-header" style="background-color: #FF7A00; border-bottom: 2px solid #FF7A00;">
                                                        <h5 class="modal-title text-white fw-bold">
                                                            <i class="bi bi-exclamation-triangle"></i> Eliminar Aguinaldo
                                                        </h5>
                                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                                    </div>
                                                    <div class="modal-body" style="padding: 24px;">
                                                        <div style="background-color: #FFF5EB; border-left: 4px solid #FF7A00; padding: 16px; margin-bottom: 16px; border-radius: 6px;">
                                                            <div style="color: #333; font-weight: 600;">
                                                                <i class="bi bi-exclamation-triangle-fill" style="color: #FF7A00; margin-right: 8px;"></i>
                                                                ¿Eliminar aguinaldo de <span id="modalAguinaldoEmpleado"></span>?
                                                            </div>
                                                        </div>

                                                        <div style="background-color: #F8F8F8; border: 1px solid #E0E0E0; border-radius: 6px; padding: 12px;">
                                                            <p style="color: #888; font-size: 0.85rem; margin-bottom: 0;">
                                                                <i class="bi bi-info-circle" style="color: #FF7A00; margin-right: 6px;"></i>
                                                                Esta operación no se puede deshacer.
                                                            </p>
                                                        </div>
                                                    </div>
                                                    <div class="modal-footer" style="border-top: 1px solid #E0E0E0; padding: 12px 16px;">
                                                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                                                            <i class="bi bi-x-circle"></i> Cancelar
                                                        </button>
                                                        <button type="button" class="btn text-white fw-bold" style="background-color: #FF7A00; border-color: #FF7A00;" id="btnConfirmarEliminarAguinaldo">
                                                            <i class="bi bi-check-circle"></i> Sí, Eliminar
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Formulario oculto -->
                                        <form method="post" asp-action="Delete" style="display:none;" id="formEliminarAguinaldo">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" id="inputIdAguinaldo" />
                                        </form>

                                        <script>
                                            document.addEventListener('DOMContentLoaded', function() {
                                                const botonesEliminar = document.querySelectorAll('.btnEliminarAguinaldo');
                                                const modalEliminar = new bootstrap.Modal(document.getElementById('confirmEliminarAguinaldoModal'), {
                                                    backdrop: 'static',
                                                    keyboard: false
                                                });
                                                const btnConfirmar = document.getElementById('btnConfirmarEliminarAguinaldo');
                                                const formEliminar = document.getElementById('formEliminarAguinaldo');
                                                const inputId = document.getElementById('inputIdAguinaldo');

                                                botonesEliminar.forEach(function(btn) {
                                                    btn.addEventListener('click', function() {
                                                        document.getElementById('modalAguinaldoEmpleado').textContent = this.dataset.empleado;
                                                        inputId.value = this.dataset.id;
                                                        modalEliminar.show();
                                                    });
                                                });

                                                        btnConfirmar.addEventListener('click', function() {
                                                            modalEliminar.hide();
                                                            Loading.show('Eliminando aguinaldo...');
                                                            setTimeout(function() {
                                                                formEliminar.submit();
                                                            }, 100);
                                                        });
                                                    });
                                                </script>

                                                <!-- Modal Calcular Automático -->
                                                <div class="modal fade" id="confirmCalcularAguinaldoModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
                                                    <div class="modal-dialog modal-dialog-centered">
                                                        <div class="modal-content" style="background-color: #ffffff; border: 2px solid #FF7A00;">
                                                            <div class="modal-header" style="background-color: #FF7A00; border-bottom: 2px solid #FF7A00;">
                                                                <h5 class="modal-title text-white fw-bold">
                                                                    <i class="bi bi-calculator"></i> Calcular Aguinaldos Automáticamente
                                                                </h5>
                                                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                                            </div>
                                                            <div class="modal-body" style="padding: 24px;">
                                                                <div style="background-color: #FFF5EB; border-left: 4px solid #FF7A00; padding: 16px; margin-bottom: 16px; border-radius: 6px;">
                                                                    <div style="color: #333; font-weight: 600;">
                                                                        <i class="bi bi-exclamation-triangle-fill" style="color: #FF7A00; margin-right: 8px;"></i>
                                                                        ¿Calcular aguinaldo automático para todos los empleados activos de <span id="modalAguinaldoAnio"></span>?
                                                                    </div>
                                                                </div>

                                                                <div style="background-color: #F8F8F8; border: 1px solid #E0E0E0; border-radius: 6px; padding: 12px;">
                                                                    <p style="color: #888; font-size: 0.85rem; margin: 0;">
                                                                        <i class="bi bi-info-circle" style="color: #FF7A00; margin-right: 6px;"></i>
                                                                        Se calcularán los aguinaldos basados en el salario promedio y períodos de nómina cerrados.
                                                                    </p>
                                                                </div>
                                                            </div>
                                                            <div class="modal-footer" style="border-top: 1px solid #E0E0E0; padding: 12px 16px;">
                                                                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                                                                    <i class="bi bi-x-circle"></i> Cancelar
                                                                </button>
                                                                <button type="button" class="btn text-white fw-bold" style="background-color: #FF7A00; border-color: #FF7A00;" id="btnConfirmarCalcularAguinaldo">
                                                                    <i class="bi bi-check-circle"></i> Sí, Calcular
                                                                </button>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Formulario oculto para Calcular Automático -->
                                                <form asp-action="CalcularTodos" method="post" style="display:none;" id="formCalcularAguinaldoAutomatico">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="anio" id="inputAnioAguinaldo" />
                                                </form>

                                                <script>
                                                    document.addEventListener('DOMContentLoaded', function() {
                                                        const btnCalcularAutomatico = document.querySelector('.btnCalcularAguinaldoAutomatico');
                                                        const modalCalcular = new bootstrap.Modal(document.getElementById('confirmCalcularAguinaldoModal'), {
                                                            backdrop: 'static',
                                                            keyboard: false
                                                        });
                                                        const btnConfirmar = document.getElementById('btnConfirmarCalcularAguinaldo');
                                                        const formCalcular = document.getElementById('formCalcularAguinaldoAutomatico');
                                                        const inputAnio = document.getElementById('inputAnioAguinaldo');

                                                        if (btnCalcularAutomatico) {
                                                            btnCalcularAutomatico.addEventListener('click', function() {
                                                                document.getElementById('modalAguinaldoAnio').textContent = this.dataset.anio;
                                                                inputAnio.value = this.dataset.anio;
                                                                modalCalcular.show();
                                                            });
                                                        }

                                                        btnConfirmar.addEventListener('click', function() {
                                                            modalCalcular.hide();
                                                            Loading.show('Calculando aguinaldos para todos los empleados...');
                                                            setTimeout(function() {
                                                                formCalcular.submit();
                                                            }, 100);
                                                        });
                                                    });
                                                </script>