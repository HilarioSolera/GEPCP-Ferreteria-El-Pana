@model List<GEPCP_Ferreteria_El_Pana.Models.PlanillaEmpleado>
@{
    ViewData["Title"] = "Planilla - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var rol = Context.Session.GetString("Rol");
    var periodo = ViewBag.Periodo as GEPCP_Ferreteria_El_Pana.Models.PeriodoPago;
    var periodoCerrado = periodo?.Estado == GEPCP_Ferreteria_El_Pana.Models.EstadoPeriodo.Cerrado;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-file-earmark-text"></i> Planilla Quincenal</h2>

    @if (rol == "RRHH" && periodo != null)
    {
        <div class="d-flex gap-2 flex-wrap">
            @if (!periodoCerrado)
            {
                <form asp-action="Calcular" method="post" class="d-inline"
                      onsubmit="return confirm('¿Recalcular la planilla? Se reemplazarán los datos actuales.')">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="periodoId" value="@periodo.PeriodoPagoId" />
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-calculator"></i> Calcular Planilla
                    </button>
                </form>

                @if (Model.Any())
                {
                    <form asp-action="CerrarPeriodo" method="post" class="d-inline"
                          onsubmit="return confirm('¿Cerrar el período @periodo.Descripcion? Esta acción aplicará los descuentos a préstamos y créditos.')">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="periodoId" value="@periodo.PeriodoPagoId" />
                        <button type="submit" class="btn btn-danger btn-lg">
                            <i class="bi bi-lock"></i> Cerrar Período
                        </button>
                    </form>
                }
            }

            @if (periodoCerrado)
            {
                <form asp-action="ReabrirPeriodo" method="post" class="d-inline"
                      onsubmit="return confirm('¿Reabrir el período @periodo.Descripcion? Los saldos ya aplicados NO se revierten automáticamente.')">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="periodoId" value="@periodo.PeriodoPagoId" />
                    <button type="submit" class="btn btn-warning btn-lg">
                        <i class="bi bi-unlock"></i> Reabrir Período
                    </button>
                </form>
            }
        </div>
    }
</div>

@* Selector de período *@
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <form asp-action="Index" method="get" class="d-flex align-items-center gap-3 flex-wrap">
            <label class="fw-bold mb-0">
                <i class="bi bi-calendar2-range"></i> Período:
            </label>
            <select name="periodoId" class="form-select"
                    style="max-width:400px;" onchange="this.form.submit()">
                @foreach (var p in ViewBag.Periodos as List<GEPCP_Ferreteria_El_Pana.Models.PeriodoPago>)
                {
                    <option value="@p.PeriodoPagoId"
                            selected="@(p.PeriodoPagoId == (int)(ViewBag.PeriodoId ?? 0)
                                                                                            ? "selected" : null)">
                        @p.Descripcion —
                        @(p.Estado == GEPCP_Ferreteria_El_Pana.Models.EstadoPeriodo.Abierto
                            ? "Abierto" : "Cerrado")
                    </option>
                }
            </select>
            @if (periodo != null)
            {
                <span class="badge @(periodoCerrado ? "bg-secondary" : "bg-success") fs-6">
                    <i class="bi @(periodoCerrado ? "bi-lock" : "bi-unlock")"></i>
                    @(periodoCerrado ? "Cerrado" : "Abierto")
                </span>
            }
        </form>
    </div>
</div>

@* Alerta período cerrado *@
@if (periodoCerrado)
{
    <div class="alert alert-secondary d-flex align-items-center mb-3">
        <i class="bi bi-lock-fill me-2"></i>
        <span>
            Este período está <strong>cerrado</strong>. Los datos son de solo lectura.
            @if (rol == "RRHH")
            {
                <span>Usá el botón <strong>Reabrir Período</strong> si necesitás hacer correcciones.</span>
            }
        </span>
    </div>
}

@* KPIs *@
@if (Model.Any())
{
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-4 fw-bold text-primary">@ViewBag.TotalEmpleados</div>
                <div class="text-muted small">Empleados</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-4 fw-bold text-success">₡@ViewBag.TotalDevengado.ToString("N0")</div>
                <div class="text-muted small">Total Devengado</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-4 fw-bold text-danger">₡@ViewBag.TotalDeducciones.ToString("N0")</div>
                <div class="text-muted small">Total Deducciones</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-4 fw-bold text-warning">₡@ViewBag.TotalNeto.ToString("N0")</div>
                <div class="text-muted small">Total Neto a Pagar</div>
            </div>
        </div>
    </div>

    @* Botones de exportación *@
    @if (Model.Any() && periodo != null)
    {
        <div class="d-flex gap-2 mb-3">
            <a asp-action="ExportarExcel"
                   asp-route-periodoId="@periodo.PeriodoPagoId"
                   class="btn btn-success">
                <i class="bi bi-file-earmark-excel"></i> Exportar Excel
            </a>
            <a asp-action="ExportarPDF"
                   asp-route-periodoId="@periodo.PeriodoPagoId"
                   class="btn btn-danger">
                <i class="bi bi-file-earmark-pdf"></i> Exportar PDF General
            </a>
        </div>
    }
}

@* Estados vacíos *@
@if (periodo == null)
{
    <div class="alert alert-warning text-center py-4">
        <i class="bi bi-exclamation-triangle fs-3 d-block mb-2"></i>
        No hay períodos de pago creados.
        <div class="mt-2">
            <a asp-controller="PeriodosPago" asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Crear Período
            </a>
        </div>
    </div>
}
else if (!Model.Any())
{
    <div class="alert alert-info text-center py-4">
        <i class="bi bi-inbox fs-3 d-block mb-2"></i>
        No hay planilla calculada para este período.
        @if (rol == "RRHH" && !periodoCerrado)
        {
            <div class="mt-2">
                <form asp-action="Calcular" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="periodoId" value="@periodo.PeriodoPagoId" />
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-calculator"></i> Calcular ahora
                    </button>
                </form>
            </div>
        }
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle mb-0 small">
            <thead style="background-color: #FF7A00; color: white;">
                <tr>
                    <th>Empleado</th>
                    <th class="text-end">Sal. Ordinario</th>
                    <th class="text-end">Hrs. Extras</th>
                    <th class="text-end">Comisión</th>
                    <th class="text-end">Feriados</th>
                    <th class="text-end fw-bold">Total Dev.</th>
                    <th class="text-end">CCSS 10.83%</th>
                    <th class="text-end">Préstamo</th>
                    <th class="text-end">Cré. Ferre.</th>
                    <th class="text-end">Incap.</th>
                    <th class="text-end">Hrs. No Lab.</th>
                    <th class="text-end fw-bold">Total Ded.</th>
                    <th class="text-end fw-bold">Neto</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>
                            <strong>@p.Empleado.PrimerApellido @p.Empleado.Nombre</strong>
                            <div class="text-muted" style="font-size:0.75rem;">
                                @p.Empleado.Puesto
                                @if (p.Empleado.FormaPago == GEPCP_Ferreteria_El_Pana.Models.FormaPago.Efectivo)
                                {
                                    <span class="badge bg-warning text-dark ms-1">
                                        <i class="bi bi-cash"></i> Efectivo
                                    </span>
                                }
                                else if (!string.IsNullOrEmpty(p.Empleado.NumeroCuenta))
                                {
                                    <span class="badge bg-info ms-1">
                                        <i class="bi bi-bank"></i> @p.Empleado.NumeroCuenta
                                    </span>
                                }
                            </div>
                        </td>
                        <td class="text-end">₡@p.SalarioOrdinario.ToString("N0")</td>
                        <td class="text-end @(p.MontoHorasExtras > 0 ? "text-success" : "text-muted")">
                            @(p.MontoHorasExtras > 0 ? "₡" + p.MontoHorasExtras.ToString("N0") : "—")
                        </td>
                        <td class="text-end @(p.AumentoAplicado > 0 ? "text-success" : "text-muted")">
                            @(p.AumentoAplicado > 0 ? "₡" + p.AumentoAplicado.ToString("N0") : "—")
                        </td>
                        <td class="text-end @(p.MontoFeriados > 0 ? "text-success" : "text-muted")">
                            @(p.MontoFeriados > 0 ? "₡" + p.MontoFeriados.ToString("N0") : "—")
                        </td>
                        <td class="text-end fw-bold">₡@p.TotalDevengado.ToString("N0")</td>
                        <td class="text-end text-danger">₡@p.DeduccionCCSS.ToString("N0")</td>
                        <td class="text-end @(p.DeduccionPrestamos > 0 ? "text-danger" : "text-muted")">
                            @(p.DeduccionPrestamos > 0 ? "₡" + p.DeduccionPrestamos.ToString("N0") : "—")
                        </td>
                        <td class="text-end @(p.DeduccionCreditoFerreteria > 0 ? "text-danger" : "text-muted")">
                            @(p.DeduccionCreditoFerreteria > 0 ? "₡" + p.DeduccionCreditoFerreteria.ToString("N0") : "—")
                        </td>
                        <td class="text-end @(p.DeduccionIncapacidad > 0 ? "text-danger" : "text-muted")">
                            @(p.DeduccionIncapacidad > 0 ? "₡" + p.DeduccionIncapacidad.ToString("N0") : "—")
                        </td>
                        <td class="text-end @(p.DeduccionHorasNoLaboradas > 0 ? "text-danger" : "text-muted")">
                            @(p.DeduccionHorasNoLaboradas > 0 ? "₡" + p.DeduccionHorasNoLaboradas.ToString("N0") : "—")
                        </td>
                        <td class="text-end fw-bold text-danger">₡@p.TotalDeducciones.ToString("N0")</td>
                        <td class="text-end fw-bold text-success">₡@p.NetoAPagar.ToString("N0")</td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">
                                @if (rol == "RRHH" && !periodoCerrado)
                                {
                                    <a asp-action="Editar" asp-route-id="@p.PlanillaEmpleadoId"
                                           class="btn btn-sm btn-warning" title="Ajustar manualmente">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                }
                                <a asp-action="DescargarPDF" asp-route-id="@p.PlanillaEmpleadoId"
                                       class="btn btn-sm btn-outline-danger" title="Descargar PDF">
                                    <i class="bi bi-file-earmark-pdf"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot class="fw-bold table-light">
                <tr>
                    <td>TOTALES</td>
                    <td class="text-end">₡@Model.Sum(p => p.SalarioOrdinario).ToString("N0")</td>
                    <td class="text-end">₡@Model.Sum(p => p.MontoHorasExtras).ToString("N0")</td>
                    <td class="text-end">₡@Model.Sum(p => p.AumentoAplicado).ToString("N0")</td>
                    <td class="text-end">₡@Model.Sum(p => p.MontoFeriados).ToString("N0")</td>
                    <td class="text-end">₡@Model.Sum(p => p.TotalDevengado).ToString("N0")</td>
                    <td class="text-end text-danger">₡@Model.Sum(p => p.DeduccionCCSS).ToString("N0")</td>
                    <td class="text-end text-danger">₡@Model.Sum(p => p.DeduccionPrestamos).ToString("N0")</td>
                    <td class="text-end text-danger">₡@Model.Sum(p => p.DeduccionCreditoFerreteria).ToString("N0")</td>
                    <td class="text-end text-danger">₡@Model.Sum(p => p.DeduccionIncapacidad).ToString("N0")</td>
                    <td class="text-end text-danger">₡@Model.Sum(p => p.DeduccionHorasNoLaboradas).ToString("N0")</td>
                    <td class="text-end text-danger">₡@Model.Sum(p => p.TotalDeducciones).ToString("N0")</td>
                    <td class="text-end text-success">₡@Model.Sum(p => p.NetoAPagar).ToString("N0")</td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    </div>
}