@model GEPCP_Ferreteria_El_Pana.Models.PeriodoPago
@{
    ViewData["Title"] = "Nuevo Período - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-plus-circle"></i> Nuevo Período de Pago</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div class="card shadow-sm border-0" style="max-width:620px;">
    <div class="card-body p-4">

        @* Errores del servidor *@
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger mb-3">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <strong>No se pudo crear el período:</strong>
                <ul class="mb-0 mt-1">
                    @foreach (var error in ViewData.ModelState.Values
                                            .SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </div>
        }

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">

                <div class="col-md-4">
                    <label asp-for="Anio" class="form-label fw-bold">
                        <i class="bi bi-calendar"></i> Año <span class="text-danger">*</span>
                    </label>
                    <input asp-for="Anio" type="number" min="2020" max="2099"
                           class="form-control form-control-lg" id="inputAnio" />
                    <span asp-validation-for="Anio" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Mes" class="form-label fw-bold">
                        <i class="bi bi-calendar2"></i> Mes <span class="text-danger">*</span>
                    </label>
                    <select asp-for="Mes" class="form-select form-select-lg" id="selectMes">
                        <option value="1">Enero</option>
                        <option value="2">Febrero</option>
                        <option value="3">Marzo</option>
                        <option value="4">Abril</option>
                        <option value="5">Mayo</option>
                        <option value="6">Junio</option>
                        <option value="7">Julio</option>
                        <option value="8">Agosto</option>
                        <option value="9">Septiembre</option>
                        <option value="10">Octubre</option>
                        <option value="11">Noviembre</option>
                        <option value="12">Diciembre</option>
                    </select>
                    <span asp-validation-for="Mes" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Quincena" class="form-label fw-bold">
                        <i class="bi bi-calendar2-week"></i> Quincena <span class="text-danger">*</span>
                    </label>
                    <select asp-for="Quincena" class="form-select form-select-lg" id="selectQuincena">
                        <option value="1">Primera (1–15)</option>
                        <option value="2">Segunda (16–fin)</option>
                    </select>
                    <span asp-validation-for="Quincena" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="FechaInicio" class="form-label fw-bold">
                        <i class="bi bi-calendar-check"></i> Fecha Inicio <span class="text-danger">*</span>
                    </label>
                    <input asp-for="FechaInicio" type="date"
                           class="form-control form-control-lg" id="inputFechaInicio" />
                    <span asp-validation-for="FechaInicio" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="FechaFin" class="form-label fw-bold">
                        <i class="bi bi-calendar-x"></i> Fecha Fin <span class="text-danger">*</span>
                    </label>
                    <input asp-for="FechaFin" type="date"
                           class="form-control form-control-lg" id="inputFechaFin" />
                    <span asp-validation-for="FechaFin" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <div class="alert alert-info py-2 small mb-0" id="previewPeriodo">
                        <i class="bi bi-info-circle"></i>
                        Las fechas se calculan automáticamente al seleccionar mes y quincena.
                    </div>
                </div>

            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-success btn-lg px-5">
                    <i class="bi bi-check-circle"></i> Crear Período
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-lg px-5">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        var meses = ['', 'Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio',
            'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];

        function actualizarFechas() {
            var anio = parseInt(document.getElementById('inputAnio').value)
                || new Date().getFullYear();
            var mes = parseInt(document.getElementById('selectMes').value);
            var quincena = parseInt(document.getElementById('selectQuincena').value);

            var fechaInicio, fechaFin;
            if (quincena === 1) {
                fechaInicio = new Date(anio, mes - 1, 1);
                fechaFin = new Date(anio, mes - 1, 15);
            } else {
                fechaInicio = new Date(anio, mes - 1, 16);
                fechaFin = new Date(anio, mes, 0); // último día del mes
            }

            var fmt = function(d) {
                return d.getFullYear() + '-' +
                    String(d.getMonth() + 1).padStart(2, '0') + '-' +
                    String(d.getDate()).padStart(2, '0');
            };

            document.getElementById('inputFechaInicio').value = fmt(fechaInicio);
            document.getElementById('inputFechaFin').value = fmt(fechaFin);

            var preview = document.getElementById('previewPeriodo');
            preview.className = 'alert alert-success py-2 small mb-0';
            preview.innerHTML =
                '<i class="bi bi-calendar2-check"></i> ' +
                'Período: <strong>Quincena ' + quincena + ' — ' +
                meses[mes] + ' ' + anio + '</strong>' +
                ' (' + fechaInicio.getDate() + '/' + mes + '/' + anio +
                ' al ' + fechaFin.getDate() + '/' + mes + '/' + anio + ')';
        }

        document.getElementById('inputAnio').addEventListener('input', actualizarFechas);
        document.getElementById('selectMes').addEventListener('change', actualizarFechas);
        document.getElementById('selectQuincena').addEventListener('change', actualizarFechas);
        actualizarFechas();
    </script>
}