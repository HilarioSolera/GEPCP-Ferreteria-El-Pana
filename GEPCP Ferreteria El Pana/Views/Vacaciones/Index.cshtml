@model List<GEPCP_Ferreteria_El_Pana.Models.Vacacion>
@{
    ViewData["Title"] = "Vacaciones - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var verTodos = (bool)(ViewBag.VerTodos ?? false);
    var totalRegistros = (int)(ViewBag.TotalRegistros ?? 0);
    var totalDias = (decimal)(ViewBag.TotalDias ?? 0m);
    var totalMonto = (decimal)(ViewBag.TotalMonto ?? 0m);
    var totalPendientes = (int)(ViewBag.TotalPendientes ?? 0);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-umbrella"></i> Vacaciones</h2>
    <a asp-action="Create" class="btn btn-success btn">
        <i class="bi bi-plus-circle"></i> Registrar Vacación
    </a>
</div>

@* KPIs *@
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-primary">@totalRegistros</div>
            <div class="text-muted small">Total Registros</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-warning">@totalPendientes</div>
            <div class="text-muted small">Pendientes de Aprobación</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-info">@totalDias.ToString("N1")</div>
            <div class="text-muted small">Total Días Registrados</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-success">₡@totalMonto.ToString("N0")</div>
            <div class="text-muted small">Total Acumulado en Pago</div>
        </div>
    </div>
</div>

@* Banner ver todos *@
@if (verTodos)
{
    <div class="alert alert-primary d-flex align-items-center gap-2 mb-4">
        <i class="bi bi-list-ul fs-5"></i>
        <span>Mostrando <strong>todos los registros</strong> de vacaciones.</span>
        <a asp-action="Index" class="btn btn-sm btn-outline-primary ms-auto">
            <i class="bi bi-x-circle"></i> Volver a búsqueda
        </a>
    </div>
}

@* Filtros *@
<form asp-action="Index" method="get" class="mb-4">
    <input type="hidden" name="verTodos" value="@verTodos.ToString().ToLower()" />
    <div class="row g-2">
        <div class="col-md-4">
            <div class="input-group shadow-sm">
                <span class="input-group-text bg-white">
                    <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" name="busqueda" value="@ViewBag.Busqueda"
                       class="form-control border-start-0"
                       placeholder="Buscar por nombre o cédula..." />
                <button type="submit" class="btn btn-outline-secondary">
                    <i class="bi bi-search"></i> Buscar
                </button>
            </div>
        </div>
        <div class="col-md-3">
            <select name="estado" class="form-select shadow-sm"
                    onchange="this.form.submit()">
                <option value="">— Todos los estados —</option>
                <option value="Pendiente" selected="@(ViewBag.Estado == "Pendiente" ? "selected" : null)">Pendiente</option>
                <option value="Aprobada" selected="@(ViewBag.Estado == "Aprobada" ? "selected" : null)">Aprobada</option>
                <option value="Rechazada" selected="@(ViewBag.Estado == "Rechazada" ? "selected" : null)">Rechazada</option>
                <option value="Cancelada" selected="@(ViewBag.Estado == "Cancelada" ? "selected" : null)">Cancelada</option>
            </select>
        </div>
        <div class="col-md-1">
            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-funnel"></i>
            </button>
        </div>
        <div class="col-md-1">
            @if (!string.IsNullOrEmpty(ViewBag.Busqueda as string) ||
                             !string.IsNullOrEmpty(ViewBag.Estado as string))
            {
                <a asp-action="Index" asp-route-verTodos="@verTodos"
                       class="btn btn-outline-secondary w-100">
                    <i class="bi bi-x-circle"></i>
                </a>
            }
        </div>
        <div class="col-md-3">
            @if (!verTodos)
            {
                <a asp-action="Index" asp-route-verTodos="true"
                       class="btn btn-outline-secondary w-100">
                    <i class="bi bi-list-ul"></i> Ver todos
                </a>
            }
        </div>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info text-center py-4">
        <i class="bi bi-inbox fs-3 d-block mb-2"></i>
        <span>No hay registros de vacaciones. Usá los filtros o registrá uno nuevo.</span>
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle mb-0">
            <thead style="background-color:#FF7A00;color:white;">
                <tr>
                    <th>Empleado</th>
                    <th>Período</th>
                    <th class="text-center">Días</th>
                    <th class="text-center">Estado</th>
                    <th>Registrado por</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var v in Model)
                {
                    var badgeEstado = v.Estado switch
                    {
                        GEPCP_Ferreteria_El_Pana.Models.EstadoVacacion.Aprobada => "bg-success",
                        GEPCP_Ferreteria_El_Pana.Models.EstadoVacacion.Rechazada => "bg-danger",
                        GEPCP_Ferreteria_El_Pana.Models.EstadoVacacion.Cancelada => "bg-secondary",
                        _ => "bg-warning text-dark"
                    };
                    var filaStyle = v.Estado == GEPCP_Ferreteria_El_Pana.Models.EstadoVacacion.Cancelada
                        ? "background-color:#f1f3f5;"
                        : string.Empty;

                    <tr style="@filaStyle">
                        <td>
                            <strong>@v.Empleado.PrimerApellido @v.Empleado.Nombre</strong>
                            <div class="small text-muted">@v.Empleado.Puesto</div>
                        </td>
                        <td>
                            <div class="small">@v.FechaInicio.ToString("dd/MM/yyyy")</div>
                            <div class="small text-muted">al @v.FechaFin.ToString("dd/MM/yyyy")</div>
                        </td>
                        <td class="text-center fw-bold">@v.DiasHabiles.ToString("N1")</td>
                        <td class="text-center">
                            <span class="badge @badgeEstado">@v.Estado</span>
                        </td>
                        <td>
                            <div class="small">@v.RegistradoPor</div>
                            <div class="small text-muted">@v.FechaRegistro.ToString("dd/MM/yyyy")</div>
                        </td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">
                                @if (v.Estado != GEPCP_Ferreteria_El_Pana.Models.EstadoVacacion.Cancelada)
                                {
                                    <a asp-action="Edit" asp-route-id="@v.VacacionId"
                                              class="btn btn-sm btn-warning" title="Editar">
                                               <i class="bi bi-pencil"></i>
                                           </a>
                                       }
                                       @if (v.Estado == GEPCP_Ferreteria_El_Pana.Models.EstadoVacacion.Aprobada && DateTime.Today < v.FechaInicio.Date)
                                       {
                                           <button type="button" class="btn btn-sm btn-secondary btnCancelarVacacion"
                                                   data-id="@v.VacacionId"
                                                   data-empleado="@v.Empleado.PrimerApellido @v.Empleado.Nombre"
                                                   title="Cancelar vacación aprobada">
                                               <i class="bi bi-x-circle"></i>
                                           </button>
                                       }
                                       @if (v.Estado != GEPCP_Ferreteria_El_Pana.Models.EstadoVacacion.Aprobada)
                                       {
                                           <button type="button" class="btn btn-sm btn-danger btnEliminarVacacion"
                                                   data-id="@v.VacacionId"
                                                   data-empleado="@v.Empleado.PrimerApellido @v.Empleado.Nombre"
                                                   title="Eliminar">
                                               <i class="bi bi-trash"></i>
                                           </button>
                                       }
                                @if (v.Estado != GEPCP_Ferreteria_El_Pana.Models.EstadoVacacion.Cancelada)
                                {
                                    <a asp-action="DescargarBoleta" asp-route-id="@v.VacacionId"
                                       class="btn btn-sm btn-outline-danger long-action" data-loading-message="Generando PDF..." title="Descargar PDF boleta">
                                        <i class="bi bi-file-earmark-pdf"></i>
                                    </a>
                                    @if (!string.IsNullOrEmpty(v.Empleado.CorreoElectronico))
                                    {
                                        <form asp-action="EnviarPorEmail" method="post" class="d-inline form-loading" data-loading-message="Enviando correo...">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@v.VacacionId" />
                                            <button type="submit" class="btn btn-sm btn-outline-success" title="Enviar correo">
                                                <i class="bi bi-envelope"></i>
                                            </button>
                                        </form>
                                    }
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
         </div>
         <div class="text-muted small mt-2 text-end">
             @Model.Count registro(s)
         </div>
    }

    <!-- Modal Eliminar/Cancelar Vacación -->
    <div class="modal fade" id="confirmAccionVacacionModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background-color: #ffffff; border: 2px solid #FF7A00;">
                <div class="modal-header" style="background-color: #FF7A00; border-bottom: 2px solid #FF7A00;">
                    <h5 class="modal-title text-white fw-bold" id="modalAccionVacacionTitulo">
                        <i class="bi bi-exclamation-triangle"></i> Acción Vacación
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" style="padding: 24px;">
                    <div style="background-color: #FFF5EB; border-left: 4px solid #FF7A00; padding: 16px; margin-bottom: 16px; border-radius: 6px;">
                        <div style="color: #333; font-weight: 600;" id="modalAccionVacacionMensaje">
                            <i class="bi bi-exclamation-triangle-fill" style="color: #FF7A00; margin-right: 8px;"></i>
                            Mensaje
                        </div>
                    </div>

                    <div style="background-color: #F8F8F8; border: 1px solid #E0E0E0; border-radius: 6px; padding: 12px;">
                        <p style="color: #888; font-size: 0.85rem; margin-bottom: 0;">
                            <i class="bi bi-info-circle" style="color: #FF7A00; margin-right: 6px;"></i>
                            Asegúrese de que esta es la acción correcta.
                        </p>
                    </div>
                </div>
                <div class="modal-footer" style="border-top: 1px solid #E0E0E0; padding: 12px 16px;">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle"></i> Cancelar
                    </button>
                    <button type="button" class="btn text-white fw-bold" style="background-color: #FF7A00; border-color: #FF7A00;" id="btnConfirmarAccionVacacion">
                        <i class="bi bi-check-circle"></i> Confirmar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Formularios ocultos -->
    <form method="post" asp-action="Cancelar" style="display:none;" id="formCancelarVacacion">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" id="inputIdVacacion" />
    </form>
    <form method="post" asp-action="Delete" style="display:none;" id="formEliminarVacacion">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" id="inputIdVacacion2" />
    </form>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const btnsCancelar = document.querySelectorAll('.btnCancelarVacacion');
            const btnsEliminar = document.querySelectorAll('.btnEliminarVacacion');
            const formCancelar = document.getElementById('formCancelarVacacion');
            const formEliminar = document.getElementById('formEliminarVacacion');
            let accionActual = null;

            const modal = new bootstrap.Modal(document.getElementById('confirmAccionVacacionModal'), {
                backdrop: 'static',
                keyboard: false
            });

            btnsCancelar.forEach(function(btn) {
                btn.addEventListener('click', function() {
                    accionActual = 'cancelar';
                    document.getElementById('modalAccionVacacionTitulo').textContent = 'Cancelar Vacación';
                    document.getElementById('modalAccionVacacionMensaje').innerHTML = 
                        '<i class="bi bi-exclamation-triangle-fill" style="color: #FF7A00; margin-right: 8px;"></i>' +
                        '¿Cancelar la vacación aprobada de ' + this.dataset.empleado + '?';
                    document.getElementById('inputIdVacacion').value = this.dataset.id;
                    modal.show();
                });
            });

            btnsEliminar.forEach(function(btn) {
                btn.addEventListener('click', function() {
                    accionActual = 'eliminar';
                    document.getElementById('modalAccionVacacionTitulo').textContent = 'Eliminar Vacación';
                    document.getElementById('modalAccionVacacionMensaje').innerHTML = 
                        '<i class="bi bi-exclamation-triangle-fill" style="color: #FF7A00; margin-right: 8px;"></i>' +
                        '¿Eliminar la vacación de ' + this.dataset.empleado + '?';
                    document.getElementById('inputIdVacacion2').value = this.dataset.id;
                    modal.show();
                });
            });

            const btnConfirmar = document.getElementById('btnConfirmarAccionVacacion');
            if (btnConfirmar) {
                btnConfirmar.addEventListener('click', function() {
                    modal.hide();
                    Loading.show('Procesando acción...');
                    setTimeout(function() {
                        if (accionActual === 'cancelar') {
                            formCancelar.submit();
                        } else if (accionActual === 'eliminar') {
                            formEliminar.submit();
                        }
                    }, 100);
                });
            }
        });
    </script>