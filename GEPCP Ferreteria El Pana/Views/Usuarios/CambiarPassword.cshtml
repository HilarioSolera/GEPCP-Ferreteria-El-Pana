@model GEPCP_Ferreteria_El_Pana.Models.CambiarPasswordViewModel
@{
    ViewData["Title"] = "Cambiar Contraseña - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-key"></i> Cambiar Contraseña</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div class="card shadow-sm border-0" style="max-width: 500px;">
    <div class="card-header py-3" style="background-color: #FF7A00;">
        <h5 class="mb-0 text-white">
            <i class="bi bi-person-circle"></i> Usuario: <strong>@Model.NombreUsuario</strong>
        </h5>
    </div>
    <div class="card-body p-4">
        <form asp-action="CambiarPassword" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="UsuarioId" />
            <input type="hidden" asp-for="NombreUsuario" />

            <div class="mb-3">
                <label asp-for="PasswordActual" class="form-label fw-bold">
                    <i class="bi bi-lock"></i> Contraseña Actual <span class="text-danger">*</span>
                </label>
                <input asp-for="PasswordActual" type="password"
                       class="form-control form-control-lg"
                       placeholder="••••••••"
                       autocomplete="current-password" />
                <span asp-validation-for="PasswordActual" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PasswordNueva" class="form-label fw-bold">
                    <i class="bi bi-lock-fill"></i> Nueva Contraseña <span class="text-danger">*</span>
                </label>
                <input asp-for="PasswordNueva" type="password"
                       class="form-control form-control-lg"
                       placeholder="Mínimo 8 caracteres"
                       autocomplete="new-password"
                       id="inputPasswordNueva" />
                <div class="form-text text-muted" id="passwordHint"></div>
                <span asp-validation-for="PasswordNueva" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmarPassword" class="form-label fw-bold">
                    <i class="bi bi-lock-fill"></i> Confirmar Nueva Contraseña <span class="text-danger">*</span>
                </label>
                <input asp-for="ConfirmarPassword" type="password"
                       class="form-control form-control-lg"
                       placeholder="Repetí la nueva contraseña"
                       autocomplete="new-password" />
                <span asp-validation-for="ConfirmarPassword" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning btn-lg px-5">
                    <i class="bi bi-check-circle"></i> Actualizar Contraseña
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-lg px-5">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.getElementById('inputPasswordNueva').addEventListener('input', function () {
            var pwd   = this.value;
            var hint  = document.getElementById('passwordHint');
            var score = 0;

            if (pwd.length >= 8)                        score++;
            if (/[A-Z]/.test(pwd))                      score++;
            if (/[a-z]/.test(pwd))                      score++;
            if (/[0-9]/.test(pwd))                      score++;
            if (/[!@@#$%^&*\(\)\-_=\+]/.test(pwd))     score++;

            var labels = ['Muy débil', 'Débil', 'Regular', 'Buena', 'Fuerte'];
            var colors = ['text-danger', 'text-danger', 'text-warning', 'text-info', 'text-success'];

            if (pwd.length === 0) { hint.textContent = ''; return; }

            var idx = Math.max(0, score - 1);
            hint.className = 'form-text ' + colors[idx];
            hint.innerHTML = '<i class="bi bi-shield"></i> Fortaleza: <strong>' + labels[idx] + '</strong>';
        });
    </script>
}