@model List<GEPCP_Ferreteria_El_Pana.Models.Comision>
@{
    ViewData["Title"] = "Comisiones - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-graph-up-arrow"></i> Comisiones</h2>
    <a href="/Comisiones/Create" class="btn btn-success btn-lg">
        <i class="bi bi-plus-circle"></i> Nueva Comisión
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* Resumen total *@
@if (Model != null && Model.Any())
{
    <div class="alert alert-info mb-4">
        <i class="bi bi-calculator"></i>
        Total comisiones registradas: <strong>@Model.Count</strong> —
        Monto total: <strong>₡@Model.Sum(c => c.Monto).ToString("N0")</strong>
    </div>
}

<table class="table table-hover table-striped align-middle" id="tablaComisiones">
    <thead class="table-dark">
        <tr>
            <th>Empleado</th>
            <th>Fecha</th>
            <th>Monto</th>
            <th>Descripción</th>
            <th class="text-center">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @if (Model == null || !Model.Any())
        {
            <tr>
                <td colspan="5" class="text-center text-muted py-4">
                    <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                    No hay comisiones registradas.
                </td>
            </tr>
        }
        else
        {
            @foreach (var c in Model)
            {
                <tr>
                    <td>
                        <strong>@c.Empleado.PrimerApellido @c.Empleado.Nombre</strong>
                        <br /><small class="text-muted">@c.Empleado.Puesto</small>
                    </td>
                    <td>@c.Fecha.ToString("dd/MM/yyyy")</td>
                    <td class="fw-bold text-success">₡@c.Monto.ToString("N0")</td>
                    <td>@c.Descripcion</td>
                    <td class="text-center">
                        <a href="/Comisiones/Edit/@c.ComisionId" class="btn btn-sm btn-primary me-1">
                            <i class="bi bi-pencil"></i> Editar
                        </a>
                        <form asp-action="Delete" method="post" class="d-inline"
                              onsubmit="return confirm('¿Eliminar esta comisión?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@c.ComisionId" />
                            <button type="submit" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i> Eliminar
                            </button>
                        </form>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>