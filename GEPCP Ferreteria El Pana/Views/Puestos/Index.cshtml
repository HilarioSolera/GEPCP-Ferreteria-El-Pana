@model List<GEPCP_Ferreteria_El_Pana.Models.Puesto>
@{
    ViewData["Title"] = "Puestos - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-briefcase"></i> Gestión de Puestos</h2>
    <a asp-action="Create" class="btn btn-success btn-lg">
        <i class="bi bi-plus-circle"></i> Nuevo Puesto
    </a>
</div>

@* KPIs *@
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-primary">@ViewBag.TotalPuestos</div>
            <div class="text-muted small">Total Puestos</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-success">@ViewBag.TotalActivos</div>
            <div class="text-muted small">Puestos Activos</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-warning">
                ₡@ViewBag.SalarioPromedio.ToString("N0")
            </div>
            <div class="text-muted small">Salario Promedio</div>
        </div>
    </div>
</div>

@* Barra de búsqueda *@
<form asp-action="Index" method="get" class="mb-4">
    <div class="input-group shadow-sm">
        <span class="input-group-text bg-white">
            <i class="bi bi-search text-muted"></i>
        </span>
        <input type="text" name="busqueda" value="@ViewBag.Busqueda"
               class="form-control border-start-0"
               placeholder="Buscar puesto por nombre..." />
        <button type="submit" class="btn btn-primary px-4">Buscar</button>
        @if (!string.IsNullOrEmpty(ViewBag.Busqueda as string))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-x-circle"></i> Limpiar
            </a>
        }
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info text-center py-4">
        <i class="bi bi-inbox fs-3 d-block mb-2"></i>
        @if (!string.IsNullOrEmpty(ViewBag.Busqueda as string))
        {
            <span>No se encontraron puestos para "<strong>@ViewBag.Busqueda</strong>".</span>
        }
        else
        {
            <span>No hay puestos registrados aún.</span>
        }
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle mb-0">
            <thead style="background-color: #FF7A00; color: white;">
                <tr>
                    <th>Nombre del Puesto</th>
                    <th class="text-end">Salario Base</th>
                    <th class="text-center">Empleados</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr class="@(!p.Activo ? "table-light text-muted" : "")">
                        <td>
                            <strong>@p.Nombre</strong>
                        </td>
                        <td class="text-end fw-bold">
                            ₡@p.SalarioBase.ToString("N0")
                        </td>
                        <td class="text-center">
                            @{
                                var totalEmp = ViewBag.EmpleadosPorPuesto != null &&
                                ((Dictionary<string, int>)ViewBag.EmpleadosPorPuesto).ContainsKey(p.Nombre)
                                ? ((Dictionary<string, int>)ViewBag.EmpleadosPorPuesto)[p.Nombre]
                                : 0;
                            }
                            <span class="badge @(totalEmp > 0 ? "bg-info" : "bg-light text-muted")">
                                @totalEmp
                            </span>
                        </td>
                        <td class="text-center">
                            @if (p.Activo)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactivo</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">

                                <a asp-action="Edit" asp-route-id="@p.PuestoId"
                                   class="btn btn-sm btn-warning" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                @if (p.Activo)
                                {
                                    <form asp-action="Desactivar" method="post" class="d-inline"
                                          onsubmit="return confirm('¿Desactivar el puesto @p.Nombre?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@p.PuestoId" />
                                        <button type="submit" class="btn btn-sm btn-secondary"
                                                title="Desactivar">
                                            <i class="bi bi-pause-circle"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="Activar" method="post" class="d-inline"
                                          onsubmit="return confirm('¿Activar el puesto @p.Nombre?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@p.PuestoId" />
                                        <button type="submit" class="btn btn-sm btn-success"
                                                title="Activar">
                                            <i class="bi bi-play-circle"></i>
                                        </button>
                                    </form>
                                }

                                <form asp-action="Delete" method="post" class="d-inline"
                                      onsubmit="return confirm('¿Eliminar permanentemente el puesto @p.Nombre? Esta acción no se puede deshacer.')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@p.PuestoId" />
                                    <button type="submit" class="btn btn-sm btn-danger"
                                            title="Eliminar">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>

                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="text-muted small mt-2 text-end">
        Total: <strong>@Model.Count</strong> puesto(s) —
        Activos: <strong>@Model.Count(p => p.Activo)</strong> /
        Inactivos: <strong>@Model.Count(p => !p.Activo)</strong>
    </div>
}