@model List<GEPCP_Ferreteria_El_Pana.Models.CreditoFerreteria>
@{
    ViewData["Title"] = "Créditos Ferretería - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var verTodos = (bool)(ViewBag.VerTodos ?? false);
    var totalCreditos = (int)(ViewBag.TotalCreditos ?? 0);
    var totalActivos = (int)(ViewBag.TotalActivos ?? 0);
    var totalSaldo = (decimal)(ViewBag.TotalSaldo ?? 0m);
    var totalCuotasQuinc = (decimal)(ViewBag.TotalCuotasQuinc ?? 0m);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-cart-check"></i> Créditos Ferretería</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Nuevo Crédito
    </a>
</div>

@* KPIs *@
<div class="row g-2 mb-3">
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-2">
            <div class="fs-4 fw-bold" style="color:#111;">@totalCreditos</div>
            <div class="text-muted" style="font-size:0.72rem;">Total Créditos</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-2"
             style="border-left:3px solid #1a4a1a !important;">
            <div class="fw-bold" style="color:#1a4a1a;font-size:0.92rem;">@totalActivos</div>
            <div class="text-muted" style="font-size:0.72rem;">Activos</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-2"
             style="border-left:3px solid #FF7A00 !important;">
            <div class="fw-bold" style="color:#FF7A00;font-size:0.92rem;">
                ₡@totalSaldo.ToString("N0")
            </div>
            <div class="text-muted" style="font-size:0.72rem;">Saldo Pendiente</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-2">
            <div class="fw-bold" style="font-size:0.92rem;color:#111;">
                ₡@totalCuotasQuinc.ToString("N0")
            </div>
            <div class="text-muted" style="font-size:0.72rem;">Cuotas Quincenales</div>
        </div>
    </div>
</div>

@* Filtros *@
<form asp-action="Index" method="get" class="mb-3">
    <div class="row g-2">
        <div class="col-md-5">
            <div class="input-group shadow-sm">
                <span class="input-group-text bg-white">
                    <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" name="busqueda" value="@ViewBag.Busqueda"
                       class="form-control border-start-0"
                       placeholder="Nombre, cédula o descripción..." />
                <button type="submit" class="btn btn-outline-secondary">
                    <i class="bi bi-search"></i> Buscar
                </button>
            </div>
        </div>
        <div class="col-md-2">
            <select name="estado" class="form-select shadow-sm"
                    onchange="this.form.submit()">
                <option value=""
                        selected="@(string.IsNullOrEmpty(ViewBag.EstadoFiltro as string)
                                                                                ? "selected" : null)">
                    Todos
                </option>
                <option value="Activo"
                        selected="@(ViewBag.EstadoFiltro == "Activo" ? "selected" : null)">
                    Activos
                </option>
                <option value="Cerrado"
                        selected="@(ViewBag.EstadoFiltro == "Cerrado" ? "selected" : null)">
                    Cerrados
                </option>
            </select>
        </div>
        <div class="col-md-1">
            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-funnel"></i>
            </button>
        </div>
        <div class="col-md-1">
            @if (!string.IsNullOrEmpty(ViewBag.Busqueda as string) ||
                             !string.IsNullOrEmpty(ViewBag.EstadoFiltro as string))
            {
                <a asp-action="Index" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-x-circle"></i>
                </a>
            }
        </div>
        <div class="col-md-3">
            @if (!verTodos)
            {
                <a asp-action="Index" asp-route-verTodos="true"
                       class="btn btn-outline-secondary w-100">
                    <i class="bi bi-list-ul"></i> Ver todos
                </a>
            }
            else
            {
                <a asp-action="Index" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-x-circle"></i> Volver a búsqueda
                </a>
            }
        </div>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info text-center py-4">
        <i class="bi bi-inbox fs-3 d-block mb-2"></i>
        No se encontraron créditos. Usá los filtros o registrá uno nuevo.
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle mb-0" style="font-size:0.85rem;">
            <thead style="background:#FF7A00;color:white;">
                <tr>
                    <th style="width:36px;"></th>
                    <th>Empleado</th>
                    <th>Descripción</th>
                    <th class="text-end">Monto Original</th>
                    <th class="text-end">Saldo Actual</th>
                    <th class="text-end">Pagado</th>
                    <th class="text-end">Faltante</th>
                    <th class="text-end">Cuota Quinc.</th>
                    <th>Fecha</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    var pagado = Math.Round(c.MontoTotal - c.Saldo, 2);
                    var faltante = c.Activo ? c.Saldo : 0;
                    var pct = c.MontoTotal > 0
                        ? (int)Math.Min(100, Math.Round((pagado / c.MontoTotal) * 100))
                        : 0;
                    var tieneAbonos = c.AbonosCreditoFerreteria.Any();

                    <tr class="@(!c.Activo ? "table-light" : "")">

                        <td class="text-center">
                            @if (tieneAbonos)
                            {
                                <button class="btn btn-sm btn-outline-secondary py-0 px-1"
                                        type="button"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#hist-@c.CreditoFerreteriaId"
                                        title="Ver historial">
                                    <i class="bi bi-chevron-down" style="font-size:0.7rem;"></i>
                                </button>
                            }
                        </td>

                        <td>
                            <div class="fw-bold">
                                @c.Empleado.PrimerApellido @c.Empleado.Nombre
                            </div>
                            <div class="text-muted small">@c.Empleado.Cedula</div>
                        </td>

                        <td>
                            <span class="text-truncate d-inline-block"
                                  style="max-width:160px;" title="@c.Descripcion">
                                @c.Descripcion
                            </span>
                        </td>

                        <td class="text-end">₡@c.MontoTotal.ToString("N0")</td>

                        <td class="text-end fw-bold"
                            style="color:@(c.Activo ? "#c55000" : "#1a4a1a")">
                            ₡@c.Saldo.ToString("N0")
                            @if (c.Activo && c.MontoTotal > 0)
                            {
                                <div class="progress mt-1" style="height:3px;">
                                    <div class="progress-bar"
                                         style="width:@pct%;background:#FF7A00;"></div>
                                </div>
                            }
                        </td>

                        <td class="text-end" style="color:#1a4a1a;">
                            ₡@pagado.ToString("N0")
                            <div class="text-muted" style="font-size:0.7rem;">@pct%</div>
                        </td>

                        <td class="text-end">
                            @if (c.Activo)
                            {
                                <span style="color:#c55000;font-weight:600;">
                                    ₡@faltante.ToString("N0")
                                </span>
                                <div class="text-muted" style="font-size:0.68rem;">
                                    ~@((c.CuotaQuincenal > 0
                                        ? (int)Math.Ceiling((double)(faltante / c.CuotaQuincenal))
                                        : 0)) cuota(s)
                                </div>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>

                        <td class="text-end">₡@c.CuotaQuincenal.ToString("N0")</td>
                        <td style="font-size:0.8rem;">@c.FechaCredito.ToString("dd/MM/yyyy")</td>

                        <td class="text-center">
                            <span class="badge @(c.Activo ? "bg-success" : "bg-secondary")">
                                @(c.Activo ? "Activo" : "Saldado")
                            </span>
                        </td>

                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center flex-wrap">

                                <a asp-action="DescargarPDF"
                                       asp-route-id="@c.CreditoFerreteriaId"
                                       class="btn btn-sm btn-outline-danger long-action"
                                       data-loading-message="Generando PDF..."
                                       title="@(c.Activo ? "Estado actual PDF" : "Finiquito PDF")">
                                    <i class="bi bi-file-earmark-pdf"></i>
                                </a>

                                @if (!string.IsNullOrEmpty(c.Empleado.CorreoElectronico))
                                {
                                    <form asp-action="EnviarPorEmail" method="post" class="d-inline form-loading" data-loading-message="Enviando correo...">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@c.CreditoFerreteriaId" />
                                        <button type="submit" class="btn btn-sm btn-outline-success" title="Enviar correo">
                                            <i class="bi bi-envelope"></i>
                                        </button>
                                    </form>
                                }

                                @if (c.Activo)
                                {
                                    <button type="button"
                                            class="btn btn-sm btn-primary"
                                            title="Registrar Abono"
                                            data-bs-toggle="modal"
                                            data-bs-target="#modalAbono"
                                            data-id="@c.CreditoFerreteriaId"
                                            data-saldo="@c.Saldo"
                                            data-cuota="@c.CuotaQuincenal"
                                            data-nombre="@c.Empleado.PrimerApellido @c.Empleado.Nombre"
                                            data-desc="@c.Descripcion">
                                        <i class="bi bi-cash-stack"></i>
                                    </button>
                                    <button type="button"
                                            class="btn btn-sm btn-outline-warning"
                                            title="Aumentar monto"
                                            data-bs-toggle="modal"
                                            data-bs-target="#modalAumento"
                                            data-id="@c.CreditoFerreteriaId"
                                            data-saldo="@c.Saldo"
                                            data-cuota="@c.CuotaQuincenal"
                                            data-nombre="@c.Empleado.PrimerApellido @c.Empleado.Nombre"
                                            data-desc="@c.Descripcion">
                                        <i class="bi bi-plus-circle"></i>
                                    </button>
                                        <button type="button" class="btn btn-sm btn-secondary btnCerrarCredito"
                                                data-id="@c.CreditoFerreteriaId"
                                                data-empleado="@c.Empleado.PrimerApellido"
                                                title="Cerrar manualmente">
                                            <i class="bi bi-x-circle"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-sm btn-warning btnRreabrirCredito"
                                                data-id="@c.CreditoFerreteriaId"
                                                data-empleado="@c.Empleado.PrimerApellido"
                                                title="Reabrir">
                                            <i class="bi bi-arrow-counterclockwise"></i>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-danger btnEliminarCredito"
                                                data-id="@c.CreditoFerreteriaId"
                                                data-empleado="@c.Empleado.PrimerApellido"
                                                title="Eliminar">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                }
                            </div>
                        </td>
                    </tr>

                    @if (tieneAbonos)
                    {
                        <tr class="collapse" id="hist-@c.CreditoFerreteriaId">
                            <td colspan="11" class="p-0">
                                <div class="px-4 py-3"
                                     style="background:#f8f8f8;border-top:1px solid #eee;">

                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <div style="font-size:0.7rem;font-weight:700;
                                            text-transform:uppercase;letter-spacing:0.8px;
                                            color:#666;">
                                            <i class="bi bi-clock-history"></i>
                                            Historial — @c.AbonosCreditoFerreteria.Count() abono(s)
                                        </div>
                                        <div style="font-size:0.72rem;color:#888;">
                                            Original: <strong>₡@c.MontoTotal.ToString("N0")</strong>
                                            — Pagado:
                                            <strong style="color:#1a4a1a;">
                                                ₡@pagado.ToString("N0")
                                            </strong>
                                            — Saldo:
                                            <strong style="color:#c55000;">
                                                ₡@c.Saldo.ToString("N0")
                                            </strong>
                                            @if (c.Activo)
                                            {
                                                <span style="color:#c55000;">
                                                    — Faltante: <strong>₡@faltante.ToString("N0")</strong>
                                                </span>
                                            }
                                        </div>
                                    </div>

                                    <table class="table table-sm mb-0"
                                           style="font-size:0.8rem;border-radius:6px;overflow:hidden;">
                                        <thead style="background:#333;color:#fff;">
                                            <tr>
                                                <th style="padding:5px 10px;">#</th>
                                                <th style="padding:5px 10px;">Fecha</th>
                                                <th style="padding:5px 10px;text-align:right;">Monto Abono</th>
                                                <th style="padding:5px 10px;text-align:right;">Saldo Anterior</th>
                                                <th style="padding:5px 10px;text-align:right;">Saldo Después</th>
                                                <th style="padding:5px 10px;text-align:right;">Faltante</th>
                                                <th style="padding:5px 10px;">Observaciones</th>
                                                <th style="padding:5px 10px;text-align:center;">Acciones</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @{
                                                var abonos = c.AbonosCreditoFerreteria
                                                    .OrderBy(a => a.FechaAbono).ToList();
                                                var saldoCalc = c.MontoTotal;
                                                int numA = 1;
                                            }
                                            @foreach (var a in abonos)
                                            {
                                                var saldoAnt = saldoCalc;
                                                saldoCalc = Math.Round(saldoCalc - a.Monto, 2);
                                                if (saldoCalc < 0) saldoCalc = 0;
                                                var esFinal = saldoCalc == 0;

                                                <tr style="background:@(numA % 2 == 0 ? "#f5f5f5" : "#fff")">
                                                    <td style="padding:5px 10px;color:#888;">@numA</td>
                                                    <td style="padding:5px 10px;">
                                                        @a.FechaAbono.ToString("dd/MM/yyyy HH:mm")
                                                    </td>
                                                    <td style="padding:5px 10px;text-align:right;font-weight:700;color:#1a4a1a;">
                                                        ₡@a.Monto.ToString("N0")
                                                    </td>
                                                    <td style="padding:5px 10px;text-align:right;color:#888;">
                                                        ₡@saldoAnt.ToString("N0")
                                                    </td>
                                                    <td style="padding:5px 10px;text-align:right;
                                                        color:@(esFinal ? "#1a4a1a" : "#c55000");
                                                        font-weight:600;">
                                                        ₡@saldoCalc.ToString("N0")
                                                        @if (esFinal)
                                                        {
                                                            <span style="font-size:0.65rem;">✓</span>
                                                        }
                                                    </td>
                                                    <td style="padding:5px 10px;text-align:right;
                                                        font-size:0.75rem;
                                                        color:@(esFinal ? "#1a4a1a" : "#888");">
                                                        @if (esFinal)
                                                        {
                                                            <strong style="color:#1a4a1a;">Saldado ✓</strong>
                                                        }
                                                        else
                                                        {
                                                            <span>₡@saldoCalc.ToString("N0")</span>
                                                        }
                                                    </td>
                                                    <td style="padding:5px 10px;color:#555;font-size:0.75rem;max-width:160px;">
                                                        @(a.Observaciones ?? "—")
                                                    </td>
                                                    <td style="padding:5px 10px;text-align:center;">
                                                        <button type="button"
                                                                class="btn btn-sm btn-outline-warning"
                                                                style="padding:1px 6px;font-size:0.7rem;"
                                                                data-bs-toggle="modal"
                                                                data-bs-target="#modalCorregir"
                                                                data-abono-id="@a.AbonoCreditoFerreteriaId"
                                                                data-monto="@a.Monto"
                                                                data-fecha="@a.FechaAbono.ToString("dd/MM/yyyy HH:mm")"
                                                                data-nombre="@c.Empleado.PrimerApellido @c.Empleado.Nombre"
                                                                title="Corregir">
                                                            <i class="bi bi-pencil"></i>
                                                        </button>
                                                        <form asp-action="EliminarAbono"
                                                              method="post" class="d-inline"
                                                              onsubmit="return confirm('¿Eliminar abono de ₡@a.Monto.ToString("N0")? El saldo se recalculará.')">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="abonoId"
                                                                   value="@a.AbonoCreditoFerreteriaId" />
                                                            <button type="submit"
                                                                    class="btn btn-sm btn-outline-danger"
                                                                    style="padding:1px 6px;font-size:0.7rem;"
                                                                    title="Eliminar abono">
                                                                <i class="bi bi-trash"></i>
                                                            </button>
                                                        </form>
                                                    </td>
                                                </tr>
                                                numA++;
                                            }
                                        </tbody>
                                        <tfoot>
                                            <tr style="background:#222;color:#fff;font-weight:700;">
                                                <td colspan="2" style="padding:5px 10px;">
                                                    Total (@abonos.Count abono(s))
                                                </td>
                                                <td style="padding:5px 10px;text-align:right;">
                                                    ₡@abonos.Sum(a => a.Monto).ToString("N0")
                                                </td>
                                                <td colspan="2" style="padding:5px 10px;text-align:right;">
                                                    Saldo: ₡@c.Saldo.ToString("N0")
                                                </td>
                                                <td style="padding:5px 10px;text-align:right;">
                                                    @if (c.Activo)
                                                    {
                                                        <span style="color:#FFB74D;">
                                                            Falta: ₡@faltante.ToString("N0")
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span style="color:#A5D6A7;">✓ Saldado</span>
                                                    }
                                                </td>
                                                <td colspan="2"></td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
    <div class="text-muted small mt-2 text-end">
        @Model.Count crédito(s) —
        Activos: @Model.Count(c => c.Activo) /
        Saldados: @Model.Count(c => !c.Activo)
    </div>
}

@* -- Modal Abono -- *@
<div class="modal fade" id="modalAbono" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header text-white" style="background:#FF7A00;">
                <h5 class="modal-title">
                    <i class="bi bi-cash-stack"></i> Registrar Abono
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="RegistrarAbono" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <input type="hidden" name="creditoId" id="abonoCreditoId" />
                    <div class="alert alert-info py-2 mb-3 small">
                        <i class="bi bi-person-circle"></i>
                        <strong id="abonoNombre"></strong><br />
                        <i class="bi bi-tag"></i>
                        <span id="abonoDesc" class="text-muted"></span><br />
                        <small>
                            Saldo actual:
                            <strong id="abonoSaldoTexto" class="text-warning"></strong>
                            — Cuota quincenal:
                            <strong id="abonoCuotaTexto"></strong>
                        </small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">
                            Monto del Abono (₡) <span class="text-danger">*</span>
                        </label>
                        <input type="number" name="monto" id="abonoMonto"
                               class="form-control"
                               step="0.01" min="0.01"
                               placeholder="Ingresá el monto" />
                        <div class="form-text text-muted" id="abonoHint"></div>
                    </div>
                    <div class="mb-1">
                        <label class="form-label fw-bold">
                            Observaciones
                            <span class="text-muted fw-normal">(opcional)</span>
                        </label>
                        <input type="text" name="observaciones"
                               class="form-control" maxlength="150"
                               placeholder="Ej: Pago quincenal, pago extra..." />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="submit" class="btn btn-primary px-4"
                            onclick="return validarAbono()">
                        <i class="bi bi-check-circle"></i> Registrar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@* -- Modal Corregir Abono -- *@
<div class="modal fade" id="modalCorregir" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header text-white" style="background:#333;">
                <h5 class="modal-title">
                    <i class="bi bi-pencil-square"></i> Corregir Abono
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="CorregirAbono" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <input type="hidden" name="abonoId" id="corregirAbonoId" />
                    <div class="alert alert-warning py-2 mb-3">
                        <i class="bi bi-exclamation-triangle"></i>
                        <strong id="corregirNombre"></strong><br />
                        <small>
                            Abono del <strong id="corregirFecha"></strong> —
                            Monto actual: <strong id="corregirMontoActual"></strong>
                        </small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">
                            Monto Corregido (₡) <span class="text-danger">*</span>
                        </label>
                        <input type="number" name="montoNuevo" id="corregirMontoNuevo"
                               class="form-control"
                               step="0.01" min="0.01" />
                        <div class="form-text text-muted">
                            El saldo del crédito se recalculará automáticamente.
                        </div>
                    </div>
                    <div class="mb-1">
                        <label class="form-label fw-bold">
                            Motivo
                            <span class="text-muted fw-normal">(opcional)</span>
                        </label>
                        <input type="text" name="observaciones"
                               class="form-control" maxlength="150"
                               placeholder="Ej: Error de digitación..." />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="submit" class="btn btn-warning px-4">
                        <i class="bi bi-check-circle"></i> Guardar Corrección
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@* -- Modal Aumentar Monto -- *@
<div class="modal fade" id="modalAumento" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header text-white" style="background:#6c757d;">
                <h5 class="modal-title">
                    <i class="bi bi-plus-circle"></i> Aumentar Monto del Crédito
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="AumentarMonto" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <input type="hidden" name="creditoId" id="aumentoCreditoId" />
                    <div class="alert alert-warning py-2 mb-3 small">
                        <strong id="aumentoNombre"></strong><br />
                        <span id="aumentoDesc" class="text-muted"></span><br />
                        <small>Saldo actual: <strong id="aumentoSaldoTexto"></strong></small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Monto adicional (₡) <span class="text-danger">*</span></label>
                        <input type="number" name="montoExtra" id="aumentoMonto" class="form-control" step="0.01" min="0.01" placeholder="Ingresá el monto adicional" />
                        <div class="form-text text-muted" id="aumentoHint"></div>
                    </div>
                    <div class="mb-1">
                        <label class="form-label fw-bold">Observaciones <span class="text-muted fw-normal">(opcional)</span></label>
                        <input type="text" name="observaciones" class="form-control" maxlength="150" placeholder="Ej: Ampliación aprobada" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-warning px-4" onclick="return validarAumentoCredito()">
                        <i class="bi bi-check-circle"></i> Guardar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('modalAbono')
            .addEventListener('show.bs.modal', function(e) {
                var btn = e.relatedTarget;
                var saldo = parseFloat(btn.getAttribute('data-saldo'));
                var cuota = parseFloat(btn.getAttribute('data-cuota'));

                document.getElementById('abonoCreditoId').value = btn.getAttribute('data-id');
                document.getElementById('abonoMonto').value = '';
                document.getElementById('abonoMonto').max = saldo;
                document.getElementById('abonoNombre').textContent = btn.getAttribute('data-nombre');
                document.getElementById('abonoDesc').textContent = btn.getAttribute('data-desc');
                document.getElementById('abonoSaldoTexto').textContent =
                    '₡' + saldo.toLocaleString('es-CR', { minimumFractionDigits: 2 });
                document.getElementById('abonoCuotaTexto').textContent =
                    '₡' + cuota.toLocaleString('es-CR', { minimumFractionDigits: 2 });
                document.getElementById('abonoHint').textContent =
                    'Máximo: ₡' + saldo.toLocaleString('es-CR', { minimumFractionDigits: 2 });
                document.getElementById('abonoHint').className = 'form-text text-muted';
            });

        function validarAbono() {
            var monto = parseFloat(document.getElementById('abonoMonto').value);
            var max = parseFloat(document.getElementById('abonoMonto').max);
            var hint = document.getElementById('abonoHint');
            if (isNaN(monto) || monto <= 0) {
                hint.textContent = '⚠ El monto debe ser mayor a cero.';
                hint.className = 'form-text text-danger';
                return false;
            }
            if (monto > max) {
                hint.textContent = `⚠ No puede superar el saldo (₡${max.toLocaleString('es-CR')}).`;
                hint.className = 'form-text text-danger';
                return false;
            }
            return true;
        }

        document.getElementById('modalAumento')
            .addEventListener('show.bs.modal', function(e) {
                var btn = e.relatedTarget;
                var saldo = parseFloat(btn.getAttribute('data-saldo'));

                document.getElementById('aumentoCreditoId').value = btn.getAttribute('data-id');
                document.getElementById('aumentoMonto').value = '';
                document.getElementById('aumentoNombre').textContent = btn.getAttribute('data-nombre');
                document.getElementById('aumentoDesc').textContent = btn.getAttribute('data-desc');
                document.getElementById('aumentoSaldoTexto').textContent =
                    '₡' + saldo.toLocaleString('es-CR', { minimumFractionDigits: 2 });
                document.getElementById('aumentoHint').textContent = 'Se recalculará la cuota automáticamente.';
                document.getElementById('aumentoHint').className = 'form-text text-muted';
            });

        function validarAumentoCredito() {
            var monto = parseFloat(document.getElementById('aumentoMonto').value);
            var hint = document.getElementById('aumentoHint');
            if (isNaN(monto) || monto <= 0) {
                hint.textContent = '⚠ El monto adicional debe ser mayor a cero.';
                hint.className = 'form-text text-danger';
                return false;
            }
            return true;
        }

        document.getElementById('modalCorregir')
            .addEventListener('show.bs.modal', function(e) {
                var btn = e.relatedTarget;
                var monto = parseFloat(btn.getAttribute('data-monto'));

                document.getElementById('corregirAbonoId').value = btn.getAttribute('data-abono-id');
                document.getElementById('corregirMontoNuevo').value = monto.toFixed(2);
                document.getElementById('corregirNombre').textContent = btn.getAttribute('data-nombre');
                document.getElementById('corregirFecha').textContent = btn.getAttribute('data-fecha');
                document.getElementById('corregirMontoActual').textContent =
                    '₡' + monto.toLocaleString('es-CR', { minimumFractionDigits: 2 });
            });

        // Modales de crédito
        document.addEventListener('DOMContentLoaded', function() {
            const btnsCerrar = document.querySelectorAll('.btnCerrarCredito');
            const btnsReabrir = document.querySelectorAll('.btnRreabrirCredito');
            const btnsEliminar = document.querySelectorAll('.btnEliminarCredito');

            let accionActual = null;
            let idActual = null;

            function abrirModal(accion, id, empleado) {
                accionActual = accion;
                idActual = id;
                let titulo = '';
                let mensaje = '';
                let botonId = '';

                if (accion === 'cerrar') {
                    titulo = 'Cerrar Crédito';
                    mensaje = `¿Cerrar el crédito de ${empleado}?`;
                    botonId = 'btnConfirmarAccionCredito';
                } else if (accion === 'reabrir') {
                    titulo = 'Reabrir Crédito';
                    mensaje = `¿Reabrir el crédito de ${empleado}?`;
                    botonId = 'btnConfirmarAccionCredito';
                } else if (accion === 'eliminar') {
                    titulo = 'Eliminar Crédito';
                    mensaje = `¿Eliminar permanentemente el crédito de ${empleado}? Esta acción no se puede deshacer.`;
                    botonId = 'btnConfirmarAccionCredito';
                }

                document.getElementById('modalAccionCreditoTitulo').textContent = titulo;
                document.getElementById('modalAccionCreditoMensaje').textContent = mensaje;

                const modal = new bootstrap.Modal(document.getElementById('confirmAccionCreditoModal'), {
                    backdrop: 'static',
                    keyboard: false
                });
                modal.show();
            }

            btnsCerrar.forEach(function(btn) {
                btn.addEventListener('click', function() {
                    abrirModal('cerrar', this.dataset.id, this.dataset.empleado);
                });
            });

            btnsReabrir.forEach(function(btn) {
                btn.addEventListener('click', function() {
                    abrirModal('reabrir', this.dataset.id, this.dataset.empleado);
                });
            });

            btnsEliminar.forEach(function(btn) {
                btn.addEventListener('click', function() {
                    abrirModal('eliminar', this.dataset.id, this.dataset.empleado);
                });
            });

            const btnConfirmar = document.getElementById('btnConfirmarAccionCredito');
            if (btnConfirmar) {
                btnConfirmar.addEventListener('click', function() {
                    const forms = document.querySelectorAll('form[data-accion-credito]');
                    let formularioAEnviar = null;

                    forms.forEach(function(form) {
                        const inputId = form.querySelector('input[type="hidden"][name="id"]');
                        if (inputId && inputId.value === idActual) {
                            const accion = form.getAttribute('data-accion-credito');
                            if (accion === accionActual) {
                                formularioAEnviar = form;
                            }
                        }
                    });

                    if (formularioAEnviar) {
                        const modal = bootstrap.Modal.getInstance(document.getElementById('confirmAccionCreditoModal'));
                        modal.hide();
                        Loading.show('Procesando acción...');
                        setTimeout(function() {
                            formularioAEnviar.submit();
                        }, 100);
                    }
                });
            }
        });
    </script>

    <!-- Modal Acción Crédito -->
    <div class="modal fade" id="confirmAccionCreditoModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background-color: #ffffff; border: 2px solid #FF7A00;">
                <div class="modal-header" style="background-color: #FF7A00; border-bottom: 2px solid #FF7A00;">
                    <h5 class="modal-title text-white fw-bold" id="modalAccionCreditoTitulo">
                        <i class="bi bi-exclamation-triangle"></i> Acción Crédito
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" style="padding: 24px;">
                    <div style="background-color: #FFF5EB; border-left: 4px solid #FF7A00; padding: 16px; margin-bottom: 16px; border-radius: 6px;">
                        <div style="color: #333; font-weight: 600;" id="modalAccionCreditoMensaje">
                            <i class="bi bi-exclamation-triangle-fill" style="color: #FF7A00; margin-right: 8px;"></i>
                            Mensaje
                        </div>
                    </div>

                    <div style="background-color: #F8F8F8; border: 1px solid #E0E0E0; border-radius: 6px; padding: 12px;">
                        <p style="color: #888; font-size: 0.85rem; margin-bottom: 0;">
                            <i class="bi bi-info-circle" style="color: #FF7A00; margin-right: 6px;"></i>
                            Asegúrese de que esta es la acción correcta.
                        </p>
                    </div>
                </div>
                <div class="modal-footer" style="border-top: 1px solid #E0E0E0; padding: 12px 16px;">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle"></i> Cancelar
                    </button>
                    <button type="button" class="btn text-white fw-bold" style="background-color: #FF7A00; border-color: #FF7A00;" id="btnConfirmarAccionCredito">
                        <i class="bi bi-check-circle"></i> Confirmar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Formularios ocultos para acciones de crédito -->
    @foreach (var c in Model)
    {
        <form method="post" asp-action="Cerrar" style="display:none;" data-accion-credito="cerrar">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@c.CreditoFerreteriaId" />
        </form>
        <form method="post" asp-action="Reabrir" style="display:none;" data-accion-credito="reabrir">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@c.CreditoFerreteriaId" />
        </form>
        <form method="post" asp-action="Eliminar" style="display:none;" data-accion-credito="eliminar">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@c.CreditoFerreteriaId" />
        </form>
    }
}
