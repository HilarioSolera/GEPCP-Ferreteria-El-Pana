<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — GEPCP Ferretería El Pana</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="~/css/gepcp-theme.css" rel="stylesheet" />
</head>
<body class="bg-light">

    @if (Context.Session.GetString("Usuario") != null)
    {
        var usuario = Context.Session.GetString("Usuario");
        var rol = Context.Session.GetString("Rol");
        var ctrl = ViewContext.RouteData.Values["controller"]?.ToString()?.ToLower() ?? "";

        <nav class="navbar navbar-expand-lg navbar-dark shadow-sm" style="background-color: #FF7A00;">
            <div class="container-fluid px-4">

                <a class="navbar-brand fw-bold d-flex align-items-center gap-2"
                       asp-controller="Home" asp-action="Dashboard">
                    <i class="bi bi-tools fs-5"></i>
                    <span>GEPCP — Ferretería El Pana</span>
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">

                        @* Dashboard *@
                        <li class="nav-item">
                            <a class="nav-link @(ctrl == "home" ? "active fw-bold" : "")"
                                   asp-controller="Home" asp-action="Dashboard">
                                <i class="bi bi-speedometer2"></i> Dashboard
                            </a>
                        </li>

                        @* Empleados *@
                        <li class="nav-item">
                            <a class="nav-link @(ctrl == "empleados" ? "active fw-bold" : "")"
                                   asp-controller="Empleados" asp-action="Index">
                                <i class="bi bi-people"></i> Empleados
                            </a>
                        </li>

                        @* Planilla *@
                        <li class="nav-item">
                            <a class="nav-link @(ctrl == "planilla" ? "active fw-bold" : "")"
                                   asp-controller="Planilla" asp-action="Index">
                                <i class="bi bi-file-earmark-text"></i> Planilla
                            </a>
                        </li>

                        @* Períodos *@
                        <li class="nav-item">
                            <a class="nav-link @(ctrl == "periodospago" ? "active fw-bold" : "")"
                                   asp-controller="PeriodosPago" asp-action="Index">
                                <i class="bi bi-calendar2-range"></i> Períodos
                            </a>
                        </li>

                        @* Horas Extras *@
                        <li class="nav-item">
                            <a class="nav-link @(ctrl == "horasextras" ? "active fw-bold" : "")"
                                   asp-controller="HorasExtras" asp-action="Index">
                                <i class="bi bi-clock-history"></i> Hrs. Extras
                            </a>
                        </li>

                        @* Comisiones *@
                        <li class="nav-item">
                            <a class="nav-link @(ctrl == "comisiones" ? "active fw-bold" : "")"
                                   asp-controller="Comisiones" asp-action="Index">
                                <i class="bi bi-graph-up"></i> Comisiones
                            </a>
                        </li>

                        @* Préstamos *@
                        <li class="nav-item">
                            <a class="nav-link @(ctrl == "prestamos" ? "active fw-bold" : "")"
                                   asp-controller="Prestamos" asp-action="Index">
                                <i class="bi bi-cash-coin"></i> Préstamos
                            </a>
                        </li>

                        @* Incapacidades *@
                        <li class="nav-item">
                            <a class="nav-link @(ctrl == "incapacidades" ? "active fw-bold" : "")"
                                   asp-controller="Incapacidades" asp-action="Index">
                                <i class="bi bi-hospital"></i> Incapacidades
                            </a>
                        </li>

                        @* Aguinaldo *@
                        <li class="nav-item">
                            <a class="nav-link @(ctrl == "aguinaldo" ? "active fw-bold" : "")"
                                   asp-controller="Aguinaldo" asp-action="Index">
                                <i class="bi bi-gift"></i> Aguinaldo
                            </a>
                        </li>

                        @* Solo RRHH *@
                        @if (rol == "RRHH")
                        {
                            <li class="nav-item">
                                <a class="nav-link @(ctrl == "creditoferreteria" ? "active fw-bold" : "")"
                                       asp-controller="CreditoFerreteria" asp-action="Index">
                                    <i class="bi bi-cart-check"></i> Créditos
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(ctrl == "puestos" ? "active fw-bold" : "")"
                                       asp-controller="Puestos" asp-action="Index">
                                    <i class="bi bi-briefcase"></i> Puestos
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(ctrl == "usuarios" ? "active fw-bold" : "")"
                                       asp-controller="Usuarios" asp-action="Index">
                                    <i class="bi bi-person-gear"></i> Usuarios
                                </a>
                            </li>
                        }

                    </ul>

                    @* Usuario y cerrar sesión *@
                    <div class="d-flex align-items-center gap-2">
                        <div class="d-flex flex-column align-items-end me-1">
                            <span class="text-white fw-bold small">
                                <i class="bi bi-person-circle"></i> @usuario
                            </span>
                            <span class="badge bg-dark">@rol</span>
                        </div>
                        <form asp-controller="Account" asp-action="Logout"
                              method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-light btn-sm">
                                <i class="bi bi-box-arrow-right"></i> Salir
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </nav>
    }

    @* Contenido principal *@
    <div class="container-fluid px-4 mt-4">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show shadow-sm">
                <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show shadow-sm">
                <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()

    </div>

    <footer class="text-center text-muted small py-4 mt-5 border-top">
        GEPCP &copy; @DateTime.Now.Year — Ferretería El Pana SRL |
        Sistema de Gestión de RR.HH.
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>