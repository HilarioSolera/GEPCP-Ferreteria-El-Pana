@model List<GEPCP_Ferreteria_El_Pana.Models.Puesto>
@{
    ViewData["Title"] = "Puestos - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-briefcase"></i> Gestión de Puestos</h2>
    <a asp-action="Create" class="btn btn-success btn">
        <i class="bi bi-plus-circle"></i> Nuevo Puesto
    </a>
</div>

@* KPIs *@
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-primary">@ViewBag.TotalPuestos</div>
            <div class="text-muted small">Total Puestos</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-success">@ViewBag.TotalActivos</div>
            <div class="text-muted small">Puestos Activos</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-warning">
                ₡@ViewBag.SalarioPromedio.ToString("N0")
            </div>
            <div class="text-muted small">Salario Promedio</div>
        </div>
    </div>
</div>

@* Barra de búsqueda *@
<form asp-action="Index" method="get" class="mb-4">
    <div class="input-group shadow-sm">
        <span class="input-group-text bg-white">
            <i class="bi bi-search text-muted"></i>
        </span>
        <input type="text" name="busqueda" value="@ViewBag.Busqueda"
               class="form-control border-start-0"
               placeholder="Buscar puesto por nombre..." />
        <button type="submit" class="btn btn-primary px-4">Buscar</button>
        @if (!string.IsNullOrEmpty(ViewBag.Busqueda as string))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-x-circle"></i> Limpiar
            </a>
        }
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info text-center py-4">
        <i class="bi bi-inbox fs-3 d-block mb-2"></i>
        @if (!string.IsNullOrEmpty(ViewBag.Busqueda as string))
        {
            <span>No se encontraron puestos para "<strong>@ViewBag.Busqueda</strong>".</span>
        }
        else
        {
            <span>No hay puestos registrados aún.</span>
        }
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle mb-0">
            <thead style="background-color: #FF7A00; color: white;">
                <tr>
                    <th>Departamento</th>
                    <th>Nombre del Puesto</th>
                    <th class="text-center">Código</th>
                    <th class="text-end">Salario Base</th>
                    <th class="text-center">Empleados</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr class="@(!p.Activo ? "table-light text-muted" : "")">
                        <td>@p.Departamento</td>
                        <td>
                            <strong>@p.Nombre</strong>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-primary">@p.Codigo</span>
                        </td>
                        <td class="text-end fw-bold">
                            ₡@p.SalarioBase.ToString("N0")
                        </td>
                        <td class="text-center">
                            @{
                                var totalEmp = ViewBag.EmpleadosPorPuesto != null &&
                                ((Dictionary<string, int>)ViewBag.EmpleadosPorPuesto).ContainsKey(p.Nombre)
                                ? ((Dictionary<string, int>)ViewBag.EmpleadosPorPuesto)[p.Nombre]
                                : 0;
                            }
                            <span class="badge @(totalEmp > 0 ? "bg-info" : "bg-light text-muted")">
                                @totalEmp
                            </span>
                        </td>
                        <td class="text-center">
                            @if (p.Activo)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactivo</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">

                                <a asp-action="Edit" asp-route-id="@p.PuestoId"
                                   class="btn btn-sm btn-warning" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                @if (p.Activo)
                                {
                                    <button type="button" class="btn btn-sm btn-secondary btnDesactivarPuesto"
                                            data-id="@p.PuestoId"
                                            data-nombre="@p.Nombre"
                                            title="Desactivar">
                                        <i class="bi bi-pause-circle"></i>
                                    </button>
                                }
                                else
                                {
                                    <form asp-action="Activar" method="post" class="d-inline"
                                          onsubmit="return confirm('¿Activar el puesto @p.Nombre?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@p.PuestoId" />
                                        <button type="submit" class="btn btn-sm btn-success"
                                                title="Activar">
                                            <i class="bi bi-play-circle"></i>
                                        </button>
                                    </form>
                                }

                                <button type="button" class="btn btn-sm btn-danger btnEliminarPuesto"
                                        data-id="@p.PuestoId"
                                        data-nombre="@p.Nombre"
                                        title="Eliminar">
                                    <i class="bi bi-trash"></i>
                                </button>

                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="text-muted small mt-2 text-end">
             Total: <strong>@Model.Count</strong> puesto(s) —
             Activos: <strong>@Model.Count(p => p.Activo)</strong> /
             Inactivos: <strong>@Model.Count(p => !p.Activo)</strong>
         </div>
        }

        <!-- Modal Eliminar Puesto -->
        <div class="modal fade" id="confirmEliminarPuestoModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content" style="background-color: #ffffff; border: 2px solid #FF7A00;">
                    <div class="modal-header" style="background-color: #FF7A00; border-bottom: 2px solid #FF7A00;">
                        <h5 class="modal-title text-white fw-bold">
                            <i class="bi bi-exclamation-triangle"></i> Eliminar Puesto
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body" style="padding: 24px;">
                        <div style="background-color: #FFF5EB; border-left: 4px solid #FF7A00; padding: 16px; margin-bottom: 16px; border-radius: 6px;">
                            <div style="color: #333; font-weight: 600;">
                                <i class="bi bi-exclamation-triangle-fill" style="color: #FF7A00; margin-right: 8px;"></i>
                                ¿Eliminar permanentemente el puesto <span id="modalPuestoNombre"></span>?
                            </div>
                        </div>

                        <p style="color: #555; margin-bottom: 12px; font-size: 0.95rem;">
                            Esta acción eliminará el registro y no se puede deshacer.
                        </p>

                        <div style="background-color: #F8F8F8; border: 1px solid #E0E0E0; border-radius: 6px; padding: 12px;">
                            <p style="color: #888; font-size: 0.85rem; margin-bottom: 0;">
                                <i class="bi bi-info-circle" style="color: #FF7A00; margin-right: 6px;"></i>
                                Asegúrese de que esta es la acción correcta.
                            </p>
                        </div>
                    </div>
                    <div class="modal-footer" style="border-top: 1px solid #E0E0E0; padding: 12px 16px;">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                            <i class="bi bi-x-circle"></i> Cancelar
                        </button>
                        <button type="button" class="btn text-white fw-bold" style="background-color: #FF7A00; border-color: #FF7A00;" id="btnConfirmarEliminarPuesto">
                            <i class="bi bi-check-circle"></i> Sí, Eliminar
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Formulario oculto para eliminar puesto -->
        <form id="formEliminarPuesto" method="post" asp-action="Delete" style="display:none;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="inputIdPuesto" />
        </form>

        <script>
            document.addEventListener('DOMContentLoaded', function() {
                const botonesEliminar = document.querySelectorAll('.btnEliminarPuesto');
                const modalEliminar = new bootstrap.Modal(document.getElementById('confirmEliminarPuestoModal'), {
                    backdrop: 'static',
                    keyboard: false
                });
                const btnConfirmar = document.getElementById('btnConfirmarEliminarPuesto');
                const formEliminar = document.getElementById('formEliminarPuesto');
                const inputId = document.getElementById('inputIdPuesto');
                const modalNombre = document.getElementById('modalPuestoNombre');
                let idActual = null;

                botonesEliminar.forEach(function(btn) {
                    btn.addEventListener('click', function() {
                        idActual = this.dataset.id;
                        const nombre = this.dataset.nombre;
                        modalNombre.textContent = nombre;
                        inputId.value = idActual;
                        modalEliminar.show();
                    });
                });

                btnConfirmar.addEventListener('click', function() {
                    modalEliminar.hide();
                    Loading.show('Eliminando puesto...');
                    setTimeout(function() {
                        formEliminar.submit();
                    }, 100);
                });
            });
        </script>

        <!-- Modal Desactivar Puesto -->
        <div class="modal fade" id="confirmDesactivarPuestoModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content" style="background-color: #ffffff; border: 2px solid #FF7A00;">
                    <div class="modal-header" style="background-color: #FF7A00; border-bottom: 2px solid #FF7A00;">
                        <h5 class="modal-title text-white fw-bold">
                            <i class="bi bi-exclamation-triangle"></i> Desactivar Puesto
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body" style="padding: 24px;">
                        <div style="background-color: #FFF5EB; border-left: 4px solid #FF7A00; padding: 16px; margin-bottom: 16px; border-radius: 6px;">
                            <div style="color: #333; font-weight: 600;">
                                <i class="bi bi-exclamation-triangle-fill" style="color: #FF7A00; margin-right: 8px;"></i>
                                ¿Desactivar el puesto <span id="modalPuestoNombre"></span>?
                            </div>
                        </div>

                        <div style="background-color: #F8F8F8; border: 1px solid #E0E0E0; border-radius: 6px; padding: 12px;">
                            <p style="color: #888; font-size: 0.85rem; margin-bottom: 0;">
                                <i class="bi bi-info-circle" style="color: #FF7A00; margin-right: 6px;"></i>
                                Los empleados asignados a este puesto deberán ser reasignados.
                            </p>
                        </div>
                    </div>
                    <div class="modal-footer" style="border-top: 1px solid #E0E0E0; padding: 12px 16px;">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                            <i class="bi bi-x-circle"></i> Cancelar
                        </button>
                        <button type="button" class="btn text-white fw-bold" style="background-color: #FF7A00; border-color: #FF7A00;" id="btnConfirmarDesactivarPuesto">
                            <i class="bi bi-check-circle"></i> Sí, Desactivar
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Formulario oculto -->
        <form method="post" asp-action="Desactivar" style="display:none;" id="formDesactivarPuesto">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="inputIdPuesto" />
        </form>

        <script>
            document.addEventListener('DOMContentLoaded', function() {
                const botonesDesactivar = document.querySelectorAll('.btnDesactivarPuesto');
                const modalDesactivar = new bootstrap.Modal(document.getElementById('confirmDesactivarPuestoModal'), {
                    backdrop: 'static',
                    keyboard: false
                });
                const btnConfirmar = document.getElementById('btnConfirmarDesactivarPuesto');
                const formDesactivar = document.getElementById('formDesactivarPuesto');
                const inputId = document.getElementById('inputIdPuesto');

                botonesDesactivar.forEach(function(btn) {
                    btn.addEventListener('click', function() {
                        document.getElementById('modalPuestoNombre').textContent = this.dataset.nombre;
                        inputId.value = this.dataset.id;
                        modalDesactivar.show();
                    });
                });

                btnConfirmar.addEventListener('click', function() {
                    modalDesactivar.hide();
                    Loading.show('Desactivando puesto...');
                    setTimeout(function() {
                        formDesactivar.submit();
                    }, 100);
                });
            });
        </script>