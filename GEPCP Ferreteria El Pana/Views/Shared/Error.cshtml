@model ErrorViewModel
@{
    ViewData["Title"] = "Error — GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex flex-column align-items-center justify-content-center py-5">

    <div class="card shadow-sm border-0 text-center" style="max-width: 600px; width: 100%;">

        <div class="card-header py-4" style="background-color: #FF7A00;">
            <i class="bi bi-exclamation-triangle-fill text-white" style="font-size: 3rem;"></i>
            <h3 class="text-white fw-bold mb-0 mt-2">Ocurrió un error</h3>
        </div>

        <div class="card-body p-5">

            <p class="text-muted fs-5 mb-4">
                No se pudo procesar tu solicitud. Si el problema persiste,
                contactá al administrador del sistema.
            </p>

            @if (Model?.ShowRequestId == true)
            {
                <div class="alert alert-secondary text-start small">
                    <i class="bi bi-info-circle"></i>
                    <strong>ID de solicitud:</strong>
                    <code>@Model.RequestId</code>
                    <div class="text-muted mt-1">
                        Proporcioná este código al soporte técnico para identificar el problema.
                    </div>
                </div>
            }

            <div class="d-flex gap-3 justify-content-center mt-4">
                <a asp-controller="Home" asp-action="Dashboard"
                   class="btn btn-lg px-5" style="background-color: #FF7A00; color: white;">
                    <i class="bi bi-speedometer2"></i> Ir al Dashboard
                </a>
                <a href="javascript:history.back()"
                   class="btn btn-outline-secondary btn-lg px-5">
                    <i class="bi bi-arrow-left"></i> Volver
                </a>
            </div>

        </div>

        <div class="card-footer text-muted small py-2">
            GEPCP &copy; @DateTime.Now.Year — Ferretería El Pana SRL
        </div>

    </div>

</div>