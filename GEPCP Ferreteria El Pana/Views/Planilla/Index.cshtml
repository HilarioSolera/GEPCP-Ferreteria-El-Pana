@model List<GEPCP_Ferreteria_El_Pana.Models.PlanillaEmpleado>

@{
    ViewData["Title"] = "Planilla - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var rol = Context.Session.GetString("Rol");
    var periodos = ViewBag.Periodos as List<GEPCP_Ferreteria_El_Pana.Models.PeriodoPago>;
    var periodo = ViewBag.Periodo as GEPCP_Ferreteria_El_Pana.Models.PeriodoPago;
    var periodoCerrado = periodo?.Estado == GEPCP_Ferreteria_El_Pana.Models.EstadoPeriodo.Cerrado;
    int? periodoId = ViewBag.PeriodoId;
    string ordenActual = ViewBag.Orden as string ?? "departamento";

    var totalEmpleados = (int)(ViewBag.TotalEmpleados ?? 0);
    var totalDevengado = (decimal)(ViewBag.TotalDevengado ?? 0m);
    var totalDeducciones = (decimal)(ViewBag.TotalDeducciones ?? 0m);
    var totalNeto = (decimal)(ViewBag.TotalNeto ?? 0m);
}

@* Selector de período *@
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-2 align-items-end">
            <div class="col-md-6">
                <label class="form-label fw-bold">
                    <i class="bi bi-calendar-range"></i> Seleccionar Período
                </label>
                <select name="periodoId" class="form-select"
                        onchange="this.form.submit()">
                    <option value="">-- Seleccioná un período --</option>
                    @if (periodos != null)
                    {
                        @foreach (var p in periodos)
                        {
                            <option value="@p.PeriodoPagoId"
                                    selected="@(p.PeriodoPagoId == periodoId ? "selected" : null)">
                                @p.Descripcion
                                @if (p.Estado == GEPCP_Ferreteria_El_Pana.Models.EstadoPeriodo.Cerrado)
                                {
                                    <text> — Cerrado</text>
                                }
                                else if (p.Estado == GEPCP_Ferreteria_El_Pana.Models.EstadoPeriodo.Abierto)
                                {
                                    <text> — Abierto</text>
                                }
                            </option>
                        }
                    }
                </select>
            </div>
            @if (periodoId.HasValue && Model.Any())
            {
                <div class="col-md-4">
                    <label class="form-label fw-bold">
                        <i class="bi bi-sort-down"></i> Ordenar Por
                    </label>
                    <select name="orden" class="form-select" onchange="this.form.submit()">
                        <option value="departamento" selected="@(ordenActual == "departamento")">Departamento + Apellido</option>
                        <option value="alfabetico" selected="@(ordenActual == "alfabetico")">Alfabético (Apellido)</option>
                        <option value="salario" selected="@(ordenActual == "salario")">Salario Bruto (Mayor → Menor)</option>
                        <option value="neto" selected="@(ordenActual == "neto")">Neto a Pagar (Mayor → Menor)</option>
                        <option value="puesto" selected="@(ordenActual == "puesto")">Puesto + Apellido</option>
                        <option value="antiguedad" selected="@(ordenActual == "antiguedad")">Antigüedad (Mayor → Menor)</option>
                    </select>
                </div>
            }
        </form>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">
        <i class="bi bi-file-earmark-text"></i>
        Planilla @(periodo?.TipoPeriodo.ToString() ?? "")
    </h2>

    @if (rol == "RRHH" && periodo != null)
    {
        <div class="d-flex gap-2">
            @if (!periodoCerrado)
            {
                <form asp-action="Calcular" method="post" onsubmit="return confirm('¿Recalcular la planilla?')">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="periodoId" value="@periodo.PeriodoPagoId" />
                    <button type="submit" class="btn btn-dark btn-sm">
                        <i class="bi bi-calculator"></i> Calcular Planilla
                    </button>
                </form>

                @if (Model.Any())
                {
                    <form asp-action="CerrarPeriodo" method="post" onsubmit="return confirm('¿Cerrar el período? Esta acción es irreversible.')">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="periodoId" value="@periodo.PeriodoPagoId" />
                        <button type="submit" class="btn btn-danger btn-sm">
                            <i class="bi bi-lock"></i> Cerrar Período
                        </button>
                    </form>
                }
            }
            @if (periodoCerrado)
            {
                <form asp-action="ReabrirPeriodo" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="periodoId" value="@periodo.PeriodoPagoId" />
                    <button type="submit" class="btn btn-warning btn-sm">
                        <i class="bi bi-unlock"></i> Reabrir Período
                    </button>
                </form>
            }
        </div>
    }
</div>

<!-- KPIs -->
@if (Model.Any())
{
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body py-3">
                    <h3 class="mb-0">@totalEmpleados</h3>
                    <small class="text-muted">EMPLEADOS</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm border-success">
                <div class="card-body py-3">
                    <h5 class="mb-0 text-success">₡@totalDevengado.ToString("N0")</h5>
                    <small class="text-muted">DEVENGADO</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm border-danger">
                <div class="card-body py-3">
                    <h5 class="mb-0 text-danger">₡@totalDeducciones.ToString("N0")</h5>
                    <small class="text-muted">DEDUCCIONES</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm border-warning">
                <div class="card-body py-3">
                    <h5 class="mb-0 text-warning">₡@totalNeto.ToString("N0")</h5>
                    <small class="text-muted">NETO A PAGAR</small>
                </div>
            </div>
        </div>
    </div>

    @* Indicador de ordenamiento actual *@
    <div class="alert alert-info py-2 px-3 d-flex align-items-center mb-3" style="font-size: 0.85rem;">
        <i class="bi bi-info-circle me-2"></i>
        <span>
            <strong>Ordenado por:</strong>
            @switch (ordenActual)
            {
                case "alfabetico":
                    <text>Alfabético (Apellido → Nombre)</text>
                    break;
                case "salario":
                    <text>Salario Bruto Mensual (Mayor → Menor)</text>
                    break;
                case "neto":
                    <text>Neto a Pagar (Mayor → Menor)</text>
                    break;
                case "puesto":
                    <text>Puesto + Apellido</text>
                    break;
                case "antiguedad":
                    <text>Antigüedad (Empleados más antiguos primero)</text>
                    break;
                default:
                    <text>Departamento + Apellido</text>
                    break;
            }
        </span>
    </div>

    <div class="d-flex gap-2 mb-3">
        <a asp-action="ExportarExcel" asp-route-periodoId="@periodo!.PeriodoPagoId" class="btn btn-dark">
            <i class="bi bi-file-earmark-excel"></i> Excel
        </a>
        <a asp-action="ExportarPDF" asp-route-periodoId="@periodo!.PeriodoPagoId" class="btn btn-dark">
            <i class="bi bi-file-earmark-pdf"></i> PDF General
        </a>
        <form asp-action="EnviarTodosPorEmail" method="post" class="d-inline"
              onsubmit="return confirm('¿Enviar el comprobante de pago por correo a todos los empleados?')">
            @Html.AntiForgeryToken()
            <input type="hidden" name="periodoId" value="@periodo.PeriodoPagoId" />
            <button type="submit" class="btn btn-dark">
                <i class="bi bi-envelope-fill"></i> Enviar Boletas a Todos
            </button>
        </form>
    </div>
}

<!-- Tabla Única con Columna de Renta -->
@if (Model.Any())
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size: 0.82rem;">
                    <thead class="table-dark">
                        <tr>
                            <th>Empleado</th>
                            <th class="text-end fw-bold" style="background:#e8f4fd;">Salario Bruto Mensual</th>
                            <th>Departamento</th>
                            <th class="text-end">Sal. Ord.</th>
                            <th class="text-end">H. Extra</th>
                            <th class="text-end">Comisión</th>
                            <th class="text-end">Feriados</th>
                            <th class="text-end fw-bold">Total Dev.</th>
                            <th class="text-end">CCSS</th>
                            <th class="text-end">Renta (ISR)</th>   <!-- NUEVA COLUMNA -->
                            <th class="text-end">Préstamos</th>
                            <th class="text-end">Crédito</th>
                            <th class="text-end">Incap.</th>
                            <th class="text-end">Vac.</th>
                            <th class="text-end">H.N/L</th>
                            <th class="text-end">Otras D.</th>
                            <th class="text-end fw-bold">Total Ded.</th>
                            <th class="text-end fw-bold" style="background:#f8f9fa; color:#000;">Neto</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            IEnumerable<GEPCP_Ferreteria_El_Pana.Models.PlanillaEmpleado> planillasOrdenadas = ordenActual switch
                            {
                                "alfabetico" => Model.OrderBy(x => x.Empleado.PrimerApellido).ThenBy(x => x.Empleado.Nombre),
                                "salario" => Model.OrderByDescending(x => x.TotalDevengado * (periodo!.TipoPeriodo switch
                                {
                                    GEPCP_Ferreteria_El_Pana.Models.TipoPeriodo.Semanal => 52m / 12m,
                                    GEPCP_Ferreteria_El_Pana.Models.TipoPeriodo.Mensual => 1m,
                                    _ => 2m
                                })).ThenBy(x => x.Empleado.PrimerApellido),
                                "neto" => Model.OrderByDescending(x => x.NetoAPagar).ThenBy(x => x.Empleado.PrimerApellido),
                                "puesto" => Model.OrderBy(x => x.Empleado.Puesto).ThenBy(x => x.Empleado.PrimerApellido),
                                "antiguedad" => Model.OrderBy(x => x.Empleado.FechaIngreso).ThenBy(x => x.Empleado.PrimerApellido),
                                _ => Model.OrderBy(x => x.Empleado.Departamento).ThenBy(x => x.Empleado.PrimerApellido) // departamento por defecto
                            };
                        }
                        @foreach (var p in planillasOrdenadas)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold">@p.Empleado.PrimerApellido @p.Empleado.Nombre</div>
                                    <small class="text-muted">@p.Empleado.Puesto</small>
                                    @if (p.Empleado.FormaPago == GEPCP_Ferreteria_El_Pana.Models.FormaPago.Efectivo)
                                    {
                                        <span class="badge bg-secondary">Efectivo</span>
                                    }
                                </td>
                                @{
                                    var factorMes = periodo!.TipoPeriodo switch
                                    {
                                        GEPCP_Ferreteria_El_Pana.Models.TipoPeriodo.Semanal => 52m / 12m,
                                        GEPCP_Ferreteria_El_Pana.Models.TipoPeriodo.Mensual => 1m,
                                        _ => 2m
                                    };
                                    var brutoMensual = p.TotalDevengado * factorMes;
                                }
                                <td class="text-end fw-bold" style="background:#e8f4fd; font-size:0.95rem;">₡@brutoMensual.ToString("N0")</td>
                                <td><strong>@p.Empleado.Departamento</strong></td>

                                <!-- Devengados -->
                                <td class="text-end">@p.SalarioOrdinario.ToString("N0")</td>
                                <td class="text-end">@(p.MontoHorasExtras > 0 ? p.MontoHorasExtras.ToString("N0") : "—")</td>
                                <td class="text-end">@(p.AumentoAplicado > 0 ? p.AumentoAplicado.ToString("N0") : "—")</td>
                                <td class="text-end">@(p.MontoFeriados > 0 ? p.MontoFeriados.ToString("N0") : "—")</td>
                                <td class="text-end fw-bold">@p.TotalDevengado.ToString("N0")</td>

                                <!-- Deducciones -->
                                <td class="text-end">@p.DeduccionCCSS.ToString("N0")</td>
                                <td class="text-end text-danger">@(p.DeduccionRenta > 0 ? p.DeduccionRenta.ToString("N0") : "—")</td> <!-- NUEVA -->
                                <td class="text-end">@(p.DeduccionPrestamos > 0 ? p.DeduccionPrestamos.ToString("N0") : "—")</td>
                                <td class="text-end">@(p.DeduccionCreditoFerreteria > 0 ? p.DeduccionCreditoFerreteria.ToString("N0") : "—")</td>
                                <td class="text-end">@(p.DeduccionIncapacidad > 0 ? p.DeduccionIncapacidad.ToString("N0") : "—")</td>
                                <td class="text-end">@(p.DeduccionVacaciones > 0 ? p.DeduccionVacaciones.ToString("N0") : "—")</td>
                                <td class="text-end">@(p.DeduccionHorasNoLaboradas > 0 ? p.DeduccionHorasNoLaboradas.ToString("N0") : "—")</td>
                                <td class="text-end" title="@p.DescripcionOtrasDeducciones">
                                    @(p.OtrasDeducciones > 0 ? p.OtrasDeducciones.ToString("N0") : "—")
                                </td>
                                <td class="text-end fw-bold">@p.TotalDeducciones.ToString("N0")</td>

                                <!-- Neto -->
                                <td class="text-end fw-bold" style="background:#f8f9fa; font-size:1rem;">₡@p.NetoAPagar.ToString("N0")</td>

                                <!-- Acciones -->
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        @if (rol == "RRHH" && !periodoCerrado)
                                        {
                                            <a asp-action="Editar" asp-route-id="@p.PlanillaEmpleadoId" class="btn btn-outline-secondary" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        }
                                        <a asp-action="DescargarPDF" asp-route-id="@p.PlanillaEmpleadoId" class="btn btn-outline-secondary" title="PDF">
                                            <i class="bi bi-file-earmark-pdf"></i>
                                        </a>
                                        @if (!string.IsNullOrEmpty(p.Empleado.CorreoElectronico))
                                        {
                                            <form asp-action="EnviarPorEmail" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@p.PlanillaEmpleadoId" />
                                                <button type="submit" class="btn btn-outline-secondary" title="Enviar correo">
                                                    <i class="bi bi-envelope"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Total General -->
    <div class="card mt-4 shadow-sm border-0" style="background:#f8f9fa;">
        <div class="card-body">
            <div class="d-flex flex-wrap justify-content-between align-items-center">
                <div>
                    <strong>Total General</strong> — @Model.Count() empleados
                </div>
                <div class="d-flex gap-4">
                    <div>
                        <small class="text-muted">Devengado</small><br>
                        <strong>₡@Model.Sum(p => p.TotalDevengado).ToString("N0")</strong>
                    </div>
                    <div>−</div>
                    <div>
                        <small class="text-muted">Deducciones</small><br>
                        <strong>₡@Model.Sum(p => p.TotalDeducciones).ToString("N0")</strong>
                    </div>
                    <div>=</div>
                    <div>
                        <small class="text-muted">Neto a Pagar</small><br>
                        <strong style="font-size:1.25rem;">₡@Model.Sum(p => p.NetoAPagar).ToString("N0")</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
}