@model GEPCP_Ferreteria_El_Pana.Models.EmpleadoViewModel
@{
    ViewData["Title"] = "Eliminar Empleado - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">
        <i class="bi bi-trash text-danger"></i> Eliminar Empleado
    </h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div class="card shadow-sm border-danger" style="max-width: 600px;">
    <div class="card-header bg-danger text-white py-3">
        <h5 class="mb-0">
            <i class="bi bi-exclamation-triangle-fill"></i> ¿Confirmás la eliminación?
        </h5>
    </div>
    <div class="card-body p-4">

        <div class="alert alert-warning">
            <i class="bi bi-exclamation-circle-fill"></i>
            Esta acción es <strong>permanente</strong> y no se puede deshacer.
            Si el empleado tiene historial, considerá <strong>desactivarlo</strong> en su lugar.
        </div>

        <table class="table table-borderless mb-0">
            <tbody>
                <tr>
                    <td class="fw-bold text-muted" style="width:40%">Cédula</td>
                    <td><code>@Model.Cedula</code></td>
                </tr>
                <tr>
                    <td class="fw-bold text-muted">Nombre Completo</td>
                    <td><strong>@Model.PrimerApellido @Model.SegundoApellido @Model.Nombre</strong></td>
                </tr>
                <tr>
                    <td class="fw-bold text-muted">Departamento</td>
                    <td>@Model.Departamento</td>
                </tr>
                <tr>
                    <td class="fw-bold text-muted">Puesto</td>
                    <td>@Model.Puesto</td>
                </tr>
                <tr>
                    <td class="fw-bold text-muted">Jornada</td>
                    <td>@(Model.TipoJornada == GEPCP_Ferreteria_El_Pana.Models.TipoJornada.Completa ? "Completa" : "Media Jornada")</td>
                </tr>
                <tr>
                    <td class="fw-bold text-muted">Salario Base</td>
                    <td>₡@Model.SalarioBase.ToString("N2")</td>
                </tr>
                <tr>
                    <td class="fw-bold text-muted">Fecha de Ingreso</td>
                    <td>@Model.FechaIngreso.ToString("dd/MM/yyyy")</td>
                </tr>
                <tr>
                    <td class="fw-bold text-muted">Estado</td>
                    <td>
                        <span class="badge @(Model.Estado == "Activo" ? "bg-success" : "bg-secondary")">
                            @Model.Estado
                        </span>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="card-footer bg-transparent d-flex gap-2 py-3">
        <form asp-action="Delete" asp-route-id="@Model.EmpleadoId" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger btn-lg px-4">
                <i class="bi bi-trash"></i> Sí, eliminar permanentemente
            </button>
        </form>

        @if (Model.Estado == "Activo")
        {
            <form asp-action="Desactivar" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.EmpleadoId" />
                <button type="submit" class="btn btn-warning btn-lg px-4">
                    <i class="bi bi-pause-circle"></i> Mejor desactivarlo
                </button>
            </form>
        }

        <a asp-action="Index" class="btn btn-secondary btn-lg px-4 ms-auto">
            Cancelar
        </a>
    </div>
</div>