@model List<GEPCP_Ferreteria_El_Pana.Models.HistorialSalario>
@{
    ViewData["Title"] = "Historial de Salarios";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-clock-history"></i> Historial de Salarios</h2>
</div>

<form asp-action="Index" method="get" class="mb-4">
    <div class="input-group shadow-sm">
        <span class="input-group-text bg-white">
            <i class="bi bi-search text-muted"></i>
        </span>
        <input type="text" name="busqueda" value="@ViewBag.Busqueda"
               class="form-control border-start-0"
               placeholder="Buscar por nombre o cédula..." />
        <button type="submit" class="btn btn-primary px-4">Buscar</button>
        @if (!string.IsNullOrEmpty(ViewBag.Busqueda as string))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-x-circle"></i> Limpiar
            </a>
        }
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info text-center py-4">
        <i class="bi bi-inbox fs-3 d-block mb-2"></i>
        No hay cambios de salario registrados aún.
        <div class="small text-muted mt-1">
            Los cambios se registran automáticamente al editar el salario de un empleado.
        </div>
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle mb-0">
            <thead style="background-color: #FF7A00; color: white;">
                <tr>
                    <th>Empleado</th>
                    <th class="text-end">Salario Anterior</th>
                    <th class="text-end">Salario Nuevo</th>
                    <th class="text-end">Diferencia</th>
                    <th>Fecha</th>
                    <th>Modificado por</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var h in Model)
                {
                    var diferencia = h.SalarioNuevo - h.SalarioAnterior;
                    <tr>
                        <td>
                            <strong>@h.Empleado.PrimerApellido @h.Empleado.Nombre</strong>
                            <div class="small text-muted">@h.Empleado.Cedula</div>
                        </td>
                        <td class="text-end text-muted">₡@h.SalarioAnterior.ToString("N0")</td>
                        <td class="text-end fw-bold">₡@h.SalarioNuevo.ToString("N0")</td>
                        <td class="text-end fw-bold @(diferencia >= 0 ? "text-success" : "text-danger")">
                            @(diferencia >= 0 ? "+" : "")₡@diferencia.ToString("N0")
                        </td>
                        <td>@h.FechaCambio.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <span class="badge bg-secondary">@(h.ModificadoPor ?? "—")</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="text-muted small mt-2 text-end">
        Total: <strong>@Model.Count</strong> cambio(s) registrado(s)
    </div>
}