@model List<GEPCP_Ferreteria_El_Pana.Models.Prestamo>
@{
    ViewData["Title"] = "Préstamos - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-cash-coin"></i> Préstamos a Empleados</h2>
    <a asp-action="Create" class="btn btn-success btn-lg">
        <i class="bi bi-plus-circle"></i> Nuevo Préstamo
    </a>
</div>

@* Resumen KPIs *@
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-primary">@ViewBag.TotalPrestamos</div>
            <div class="text-muted small">Total Préstamos</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-success">@ViewBag.TotalActivos</div>
            <div class="text-muted small">Préstamos Activos</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-warning">₡@ViewBag.TotalSaldo.ToString("N0")</div>
            <div class="text-muted small">Saldo Total Pendiente</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-info">₡@ViewBag.TotalCuotas.ToString("N0")</div>
            <div class="text-muted small">Cuotas Mensuales</div>
        </div>
    </div>
</div>

@* Filtros *@
<form asp-action="Index" method="get" class="mb-4">
    <div class="row g-2">
        <div class="col-md-7">
            <div class="input-group shadow-sm">
                <span class="input-group-text bg-white">
                    <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" name="busqueda" value="@ViewBag.Busqueda"
                       class="form-control border-start-0"
                       placeholder="Buscar por nombre, apellido o cédula del empleado..." />
            </div>
        </div>
        <div class="col-md-2">
            @* DESPUÉS - correcto *@
            @{
                var filtroActual = ViewBag.EstadoFiltro as string ?? "";
            }
            <select name="estado" class="form-select shadow-sm">
                <option value="" selected="@(filtroActual == "" ? "selected" : null)">Todos los estados</option>
                <option value="Activo" selected="@(filtroActual == "Activo" ? "selected" : null)">Activo</option>
                <option value="Cerrado" selected="@(filtroActual == "Cerrado" ? "selected" : null)">Cerrado</option>
            </select>
        </div>
        <div class="col-md-1">
            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-funnel"></i>
            </button>
        </div>
        <div class="col-md-2">
            @if (!string.IsNullOrEmpty(ViewBag.Busqueda as string) || !string.IsNullOrEmpty(ViewBag.EstadoFiltro as string))
            {
                <a asp-action="Index" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-x-circle"></i> Limpiar
                </a>
            }
        </div>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info text-center py-4">
        <i class="bi bi-inbox fs-3 d-block mb-2"></i>
        No se encontraron préstamos con los filtros aplicados.
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle mb-0">
            <thead style="background-color: #FF7A00; color: white;">
                <tr>
                    <th>Empleado</th>
                    <th class="text-end">Monto Original</th>
                    <th class="text-end">Saldo Actual</th>
                    <th class="text-end">Cuota Mensual</th>
                    <th class="text-center">Cuotas</th>
                    <th>Fecha</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    var porcentajePagado = p.Cuotas > 0
                        ? (int)(((p.CuotaMensual * p.Cuotas - p.Monto) / (p.CuotaMensual * p.Cuotas)) * 100)
                        : 0;
                    porcentajePagado = Math.Max(0, Math.Min(100, porcentajePagado));

                    <tr class="@(!p.Activo ? "table-light text-muted" : "")">
                        <td>
                            <strong>@p.Empleado.PrimerApellido @p.Empleado.Nombre</strong>
                            <div class="small text-muted">@p.Empleado.Cedula</div>
                        </td>
                        <td class="text-end">₡@((p.CuotaMensual * p.Cuotas).ToString("N0"))</td>
                        <td class="text-end fw-bold @(p.Activo ? "text-warning" : "text-success")">
                            ₡@p.Monto.ToString("N0")
                            @if (p.Activo)
                            {
                                <div class="progress mt-1" style="height: 4px;">
                                    <div class="progress-bar bg-warning"
                                         style="width: @porcentajePagado%"></div>
                                </div>
                            }
                        </td>
                        <td class="text-end">₡@p.CuotaMensual.ToString("N0")</td>
                        <td class="text-center">@p.Cuotas</td>
                        <td>@p.FechaPrestamo.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">
                            @if (p.Activo)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Cerrado</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">

                                @if (p.Activo)
                                {
                                    @* Botón Registrar Abono *@
                                    <button type="button"
                                            class="btn btn-sm btn-primary"
                                            title="Registrar Abono"
                                            data-bs-toggle="modal"
                                            data-bs-target="#modalAbono"
                                            data-id="@p.PrestamoId"
                                            data-saldo="@p.Monto"
                                            data-nombre="@p.Empleado.PrimerApellido @p.Empleado.Nombre">
                                        <i class="bi bi-cash-stack"></i>
                                    </button>

                                    @* Cerrar manual *@
                                    <form asp-action="Cerrar" method="post" class="d-inline"
                                          onsubmit="return confirm('¿Cerrar manualmente el préstamo de @p.Empleado.PrimerApellido @p.Empleado.Nombre? El saldo restante quedará como condonado.')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@p.PrestamoId" />
                                        <button type="submit" class="btn btn-sm btn-secondary" title="Cerrar préstamo">
                                            <i class="bi bi-x-circle"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    @* Reabrir *@
                                    <form asp-action="Reabrir" method="post" class="d-inline"
                                          onsubmit="return confirm('¿Reabrir el préstamo de @p.Empleado.PrimerApellido @p.Empleado.Nombre?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@p.PrestamoId" />
                                        <button type="submit" class="btn btn-sm btn-warning" title="Reabrir préstamo">
                                            <i class="bi bi-arrow-counterclockwise"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="text-muted small mt-2 text-end">
        Total: <strong>@Model.Count</strong> préstamo(s) —
        Activos: <strong>@Model.Count(p => p.Activo)</strong> /
        Cerrados: <strong>@Model.Count(p => !p.Activo)</strong>
    </div>
}

@* Modal Registrar Abono *@
<div class="modal fade" id="modalAbono" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header text-white" style="background-color: #FF7A00;">
                <h5 class="modal-title">
                    <i class="bi bi-cash-stack"></i> Registrar Abono
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="RegistrarAbono" method="post" id="formAbono">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <input type="hidden" name="prestamoId" id="abonoPrestamoId" />

                    <div class="alert alert-info py-2">
                        <i class="bi bi-person-circle"></i>
                        Empleado: <strong id="abonoNombre"></strong><br />
                        Saldo actual: <strong id="abonoSaldoTexto" class="text-warning"></strong>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">
                            Monto del Abono (₡) <span class="text-danger">*</span>
                        </label>
                        <input type="number" name="monto" id="abonoMonto"
                               class="form-control form-control-lg"
                               step="0.01" min="0.01"
                               placeholder="Ingresá el monto a abonar" />
                        <div class="form-text text-muted" id="abonoHint"></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary px-4"
                            onclick="return validarAbono()">
                        <i class="bi bi-check-circle"></i> Registrar Abono
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Cargar datos en el modal de abono
    const modalAbono = document.getElementById('modalAbono');
    modalAbono.addEventListener('show.bs.modal', function (e) {
        const btn     = e.relatedTarget;
        const id      = btn.getAttribute('data-id');
        const saldo   = parseFloat(btn.getAttribute('data-saldo'));
        const nombre  = btn.getAttribute('data-nombre');

        document.getElementById('abonoPrestamoId').value = id;
        document.getElementById('abonoMonto').value      = '';
        document.getElementById('abonoMonto').max        = saldo;
        document.getElementById('abonoNombre').textContent = nombre;
        document.getElementById('abonoSaldoTexto').textContent =
            '₡' + saldo.toLocaleString('es-CR', { minimumFractionDigits: 2 });
        document.getElementById('abonoHint').textContent =
            'Máximo permitido: ₡' + saldo.toLocaleString('es-CR', { minimumFractionDigits: 2 });
    });

    // Validación cliente del abono
    function validarAbono() {
        const monto  = parseFloat(document.getElementById('abonoMonto').value);
        const max    = parseFloat(document.getElementById('abonoMonto').max);
        const hint   = document.getElementById('abonoHint');

        if (isNaN(monto) || monto <= 0) {
            hint.textContent = '⚠ El monto debe ser mayor a cero.';
            hint.className   = 'form-text text-danger';
            return false;
        }
        if (monto > max) {
            hint.textContent = `⚠ El abono no puede superar el saldo actual (₡${max.toLocaleString('es-CR')}).`;
            hint.className   = 'form-text text-danger';
            return false;
        }
        return true;
    }
</script>
}