<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GEPCP Ferretería El Pana</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/gepcp-theme.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
</head>
<body>
    <!-- NAVBAR LIMPIO - SIN LOGO (solo texto) -->
    <nav class="navbar navbar-expand-lg navbar-dark" style="background-color: #FF7A00;">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="/" style="font-size: 1.45rem;">
                Sistema de Recursos Humanos -  Ferretería El Pana
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link menu-link" href="/Home/Dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link menu-link" href="/Empleados"><i class="bi bi-people"></i> Empleados</a></li>
                    <li class="nav-item"><a class="nav-link menu-link" href="/Prestamos"><i class="bi bi-credit-card"></i> Préstamos</a></li>
                    <li class="nav-item"><a class="nav-link menu-link" href="/Comisiones"><i class="bi bi-graph-up"></i> Comisiones</a></li>
                    <li class="nav-item"><a class="nav-link menu-link" href="/Planilla"><i class="bi bi-file-earmark-text"></i> Planilla</a></li>
                </ul>
                <span class="navbar-text text-light me-3">
                    <i class="bi bi-person-circle"></i> @ViewBag.Usuario (@ViewBag.Rol)
                </span>
                <a href="/Account/Logout" class="btn btn-outline-light btn-sm">Cerrar Sesión</a>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>