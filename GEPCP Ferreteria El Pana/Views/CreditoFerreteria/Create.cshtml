@model GEPCP_Ferreteria_El_Pana.Models.CreditoFerreteria
@{
    ViewData["Title"] = "Nuevo Crédito - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-plus-circle"></i> Nuevo Crédito Ferretería</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div class="card shadow-sm border-0" style="max-width: 700px;">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">

                <div class="col-12">
                    <label asp-for="EmpleadoId" class="form-label fw-bold">
                        <i class="bi bi-person"></i> Empleado <span class="text-danger">*</span>
                    </label>
                    <select asp-for="EmpleadoId" asp-items="ViewBag.Empleados"
                            class="form-select form-select-lg">
                        <option value="">— Seleccione un empleado —</option>
                    </select>
                    <span asp-validation-for="EmpleadoId" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="MontoTotal" class="form-label fw-bold">
                        <i class="bi bi-currency-dollar"></i> Monto Total (₡) <span class="text-danger">*</span>
                    </label>
                    <input asp-for="MontoTotal" type="number" step="0.01"
                           min="1" max="9999999.99"
                           class="form-control form-control-lg"
                           id="inputMonto"
                           placeholder="Ej: 50000.00" />
                    <span asp-validation-for="MontoTotal" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="CuotaQuincenal" class="form-label fw-bold">
                        <i class="bi bi-calendar2-week"></i> Cuota Quincenal (₡) <span class="text-danger">*</span>
                    </label>
                    <input asp-for="CuotaQuincenal" type="number" step="0.01"
                           min="1" max="9999999.99"
                           class="form-control form-control-lg"
                           id="inputCuota"
                           placeholder="Se calcula automáticamente" />
                    <div class="form-text text-muted" id="cuotaHint"></div>
                    <span asp-validation-for="CuotaQuincenal" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="FechaCredito" class="form-label fw-bold">
                        <i class="bi bi-calendar"></i> Fecha del Crédito <span class="text-danger">*</span>
                    </label>
                    <input asp-for="FechaCredito" type="date"
                           class="form-control form-control-lg"
                           max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="FechaCredito" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-bold text-muted">
                        <i class="bi bi-calculator"></i> Quincenas estimadas
                    </label>
                    <div class="form-control form-control-lg bg-light text-center fw-bold text-primary"
                         id="quincenasRef">
                        —
                    </div>
                    <div class="form-text text-muted">Monto ÷ Cuota quincenal</div>
                </div>

                <div class="col-12">
                    <label asp-for="Descripcion" class="form-label fw-bold">
                        <i class="bi bi-chat-text"></i> Descripción <span class="text-danger">*</span>
                    </label>
                    <input asp-for="Descripcion" class="form-control form-control-lg"
                           maxlength="200"
                           placeholder="Ej: Compra materiales construcción - Factura #1234" />
                    <div class="form-text text-muted">Máximo 200 caracteres.</div>
                    <span asp-validation-for="Descripcion" class="text-danger small"></span>
                </div>

            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-success btn-lg px-5">
                    <i class="bi bi-check-circle"></i> Registrar Crédito
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-lg px-5">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function calcularQuincenas() {
            var monto  = parseFloat(document.getElementById('inputMonto').value) || 0;
            var cuota  = parseFloat(document.getElementById('inputCuota').value) || 0;
            var ref    = document.getElementById('quincenasRef');
            var hint   = document.getElementById('cuotaHint');

            if (monto > 0 && cuota > 0) {
                var quincenas = Math.ceil(monto / cuota);
                ref.textContent = quincenas + ' quincena(s)';
                hint.innerHTML =
                    '<i class="bi bi-info-circle text-success"></i> ' +
                    'Se pagará en aproximadamente <strong>' + quincenas + ' quincenas</strong>.';
                hint.className = 'form-text text-success';
            } else {
                ref.textContent = '—';
                hint.textContent = '';
            }
        }

        // Sugerir cuota = monto / 4 quincenas por defecto
        document.getElementById('inputMonto').addEventListener('input', function () {
            var monto = parseFloat(this.value) || 0;
            if (monto > 0) {
                var cuotaSug = (monto / 4).toFixed(2);
                document.getElementById('inputCuota').value = cuotaSug;
            }
            calcularQuincenas();
        });

        document.getElementById('inputCuota').addEventListener('input', calcularQuincenas);
    </script>
}