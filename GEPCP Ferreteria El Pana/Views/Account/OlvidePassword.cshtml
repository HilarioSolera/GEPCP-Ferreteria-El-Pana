@{
    ViewData["Title"] = "Olvidé mi contraseña";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="login-page">
    <div class="container" style="position:relative;z-index:2;">
        <div class="row justify-content-center">
            <div class="col-md-4">
                <div class="login-card card">
                    <div class="card-header">
                        <h4><i class="bi bi-key"></i> Recuperar acceso</h4>
                        <p>Ingresá tu nombre de usuario</p>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(TempData["Error"] as string))
                        {
                            <div class="alert alert-danger">@TempData["Error"]</div>
                        }
                        <form asp-action="OlvidePassword" method="post">
                            @Html.AntiForgeryToken()
                            <div asp-validation-summary="All" class="text-danger small mb-2"></div>
                            <div class="mb-3">
                                <label class="form-label">
                                    <i class="bi bi-person"></i> Usuario
                                </label>
                                <input type="text" name="usuario" class="form-control"
                                       placeholder="Tu nombre de usuario" autofocus />
                            </div>
                            <button type="submit" class="btn-login btn w-100">
                                <i class="bi bi-send"></i> Enviar código
                            </button>
                        </form>
                        <div class="text-center mt-3">
                            <a asp-action="Login"
                                   style="color:rgba(255,255,255,0.7);font-size:0.85rem;">
                                ← Volver al inicio de sesión
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>