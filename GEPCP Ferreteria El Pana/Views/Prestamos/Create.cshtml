@model GEPCP_Ferreteria_El_Pana.Models.PrestamoViewModel
@{
    ViewData["Title"] = "Nuevo Préstamo - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-plus-circle"></i> Nuevo Préstamo</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div class="card shadow-sm border-0" style="max-width: 700px;">
    <div class="card-body p-4">
        <form asp-action="Create" method="post" id="formPrestamo">
            @Html.AntiForgeryToken()
            <div class="row g-3">

                <div class="col-12">
                    <label asp-for="EmpleadoId" class="form-label fw-bold">
                        <i class="bi bi-person"></i> Empleado <span class="text-danger">*</span>
                    </label>
                    <select asp-for="EmpleadoId" class="form-select form-select-lg"
                            asp-items="ViewBag.Empleados">
                        <option value="">-- Seleccione un empleado --</option>
                    </select>
                    <span asp-validation-for="EmpleadoId" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="MontoPrincipal" class="form-label fw-bold">
                        <i class="bi bi-currency-dollar"></i> Monto del Préstamo (₡) <span class="text-danger">*</span>
                    </label>
                    <input asp-for="MontoPrincipal" type="number" step="0.01"
                           min="1" max="9999999.99"
                           class="form-control form-control-lg"
                           id="inputMonto"
                           placeholder="Ej: 500000.00" />
                    <span asp-validation-for="MontoPrincipal" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="FechaPrestamo" class="form-label fw-bold">
                        <i class="bi bi-calendar"></i> Fecha del Préstamo <span class="text-danger">*</span>
                    </label>
                    <input asp-for="FechaPrestamo" type="date"
                           class="form-control form-control-lg"
                           max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="FechaPrestamo" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="CuotasTotal" class="form-label fw-bold">
                        <i class="bi bi-calendar-range"></i> Número de Cuotas <span class="text-danger">*</span>
                    </label>
                    <input asp-for="CuotasTotal" type="number"
                           min="1" max="120"
                           class="form-control form-control-lg"
                           id="inputCuotas"
                           placeholder="Ej: 12" />
                    <span asp-validation-for="CuotasTotal" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="CuotaMensual" class="form-label fw-bold">
                        <i class="bi bi-cash"></i> Cuota Mensual (₡) <span class="text-danger">*</span>
                    </label>
                    <input asp-for="CuotaMensual" type="number" step="0.01"
                           min="1" max="9999999.99"
                           class="form-control form-control-lg"
                           id="inputCuotaMensual"
                           placeholder="Se calcula automáticamente" />
                    <div class="form-text text-muted" id="cuotaHint"></div>
                    <span asp-validation-for="CuotaMensual" class="text-danger small"></span>
                </div>

            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-success btn-lg px-5">
                    <i class="bi bi-check-circle"></i> Registrar Préstamo
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-lg px-5">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Auto-calcular cuota mensual
        function calcularCuota() {
            const monto  = parseFloat(document.getElementById('inputMonto').value);
            const cuotas = parseInt(document.getElementById('inputCuotas').value);
            const hint   = document.getElementById('cuotaHint');

            if (monto > 0 && cuotas > 0) {
                const cuota = (monto / cuotas).toFixed(2);
                document.getElementById('inputCuotaMensual').value = cuota;
                hint.innerHTML = `<i class="bi bi-calculator"></i> Cuota calculada: <strong>₡${Number(cuota).toLocaleString('es-CR', { minimumFractionDigits: 2 })}</strong>. Podés ajustarla.`;
                hint.className = 'form-text text-success';
            }
        }

        document.getElementById('inputMonto').addEventListener('input', calcularCuota);
        document.getElementById('inputCuotas').addEventListener('input', calcularCuota);
    </script>
}