@model GEPCP_Ferreteria_El_Pana.Models.Puesto
@{
    ViewData["Title"] = "Editar Puesto - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-pencil"></i> Editar Puesto</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="PuestoId" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger mb-3">
                    <ul class="mb-0">
                        @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@e.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }

            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Nombre" class="form-label fw-bold">
                        <i class="bi bi-briefcase"></i> Nombre del Puesto <span class="text-danger">*</span>
                    </label>
                    <input asp-for="Nombre" class="form-control"
                           maxlength="100" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="SalarioBase" class="form-label fw-bold">
                        <i class="bi bi-currency-dollar"></i> Salario Base (₡) <span class="text-danger">*</span>
                    </label>
                    <input asp-for="SalarioBase" type="number" step="0.01" min="0" max="9999999.99"
                           class="form-control" />
                    <div class="form-text text-muted">
                        Cambiar este valor <strong>no afecta</strong> los salarios de empleados ya asignados.
                    </div>
                    <span asp-validation-for="SalarioBase" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <div class="form-check form-switch mt-3">
                        <input asp-for="Activo" class="form-check-input" type="checkbox" />
                        <label asp-for="Activo" class="form-check-label fw-bold">Puesto activo</label>
                        <div class="form-text text-muted">
                            Desactivar este puesto evitará que aparezca al crear nuevos empleados.
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-4 d-flex gap-3">
                <button type="submit" class="btn btn-warning btn px-5">
                    <i class="bi bi-check-circle"></i> Guardar Cambios
                </button>
                <a asp-action="Index" class="btn btn-secondary btn px-5">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}