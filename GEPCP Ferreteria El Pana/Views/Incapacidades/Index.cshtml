@model List<GEPCP_Ferreteria_El_Pana.Models.Incapacidad>
@{
    ViewData["Title"] = "Incapacidades - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Corrección del error de null reference
    bool verTodos = ViewBag.VerTodos != null && (bool)ViewBag.VerTodos;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-hospital"></i> Control de Incapacidades</h2>
    <a asp-action="Create" class="btn btn-success btn">
        <i class="bi bi-plus-circle"></i> Nueva Incapacidad
    </a>
</div>

<!-- KPIs -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-primary">@(ViewBag.TotalRegistros ?? 0)</div>
            <div class="text-muted small">Total Registros</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-info">@(ViewBag.TotalDias ?? 0)</div>
            <div class="text-muted small">Total Días</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-warning">₡@(ViewBag.TotalMonto?.ToString("N0") ?? "0")</div>
            <div class="text-muted small">Monto Total</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-danger">₡@(ViewBag.TotalPatrono?.ToString("N0") ?? "0")</div>
            <div class="text-muted small">Costo Patrono</div>
        </div>
    </div>
</div>

<!-- Filtros -->
<form asp-action="Index" method="get" class="mb-4">
    <div class="row g-2">
        <div class="col-md-5">
            <div class="input-group shadow-sm">
                <span class="input-group-text bg-white">
                    <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" name="busqueda" value="@ViewBag.Busqueda"
                       class="form-control border-start-0"
                       placeholder="Nombre, cédula, tipo o tiquete..." />
            </div>
        </div>
        <div class="col-md-3">
            <select name="entidad" class="form-select shadow-sm">
                <option value="">Todas las entidades</option>
                <option value="CCSS" selected="@(ViewBag.EntidadFiltro == "CCSS")">CCSS</option>
                <option value="INS" selected="@(ViewBag.EntidadFiltro == "INS")">INS</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-funnel"></i> Filtrar
            </button>
        </div>
        <div class="col-md-2">
            @if (!verTodos)
            {
                <a asp-action="Index" asp-route-verTodos="true" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-list-ul"></i> Ver todos
                </a>
            }
            else
            {
                <a asp-action="Index" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-x-circle"></i> Volver
                </a>
            }
        </div>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info text-center py-5">
        <i class="bi bi-inbox fs-1 d-block mb-3"></i>
        No se encontraron incapacidades.<br>
        <small>Usa los filtros o presiona "Ver todos"</small>
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle mb-0">
            <thead style="background-color: #FF7A00; color: white;">
                <tr>
                    <th>Empleado</th>
                    <th>Entidad</th>
                    <th>Tipo</th>
                    <th>Período</th>
                    <th class="text-center">Días</th>
                    <th>Tiquete</th>
                    <th class="text-center">% Pago</th>
                    <th>Responsable</th>
                    <th class="text-end">Monto Total</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var i in Model)
                {
                    <tr>
                        <td>
                            <strong>@i.Empleado.PrimerApellido @i.Empleado.Nombre</strong>
                            <div class="small text-muted">@i.Empleado.Cedula</div>
                        </td>
                        <td>
                            <span class="badge @(i.Entidad == GEPCP_Ferreteria_El_Pana.Models.EntidadIncapacidad.CCSS ? "bg-primary" : "bg-warning text-dark")">
                                @i.Entidad
                            </span>
                        </td>
                        <td>@i.TipoIncapacidad</td>
                        <td>
                            <small>@i.FechaInicio.ToString("dd/MM/yyyy")</small><br>
                            <small class="text-muted">al @i.FechaFin.ToString("dd/MM/yyyy")</small>
                        </td>
                        <td class="text-center fw-bold">@i.TotalDias</td>
                        <td>@(string.IsNullOrEmpty(i.TiqueteCCSS) ? "—" : i.TiqueteCCSS)</td>
                        <td class="text-center">@i.PorcentajePago%</td>
                        <td>@i.ResponsablePago</td>
                        <td class="text-end fw-bold text-danger">₡@i.MontoTotal.ToString("N0")</td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">
                                <a asp-action="DescargarPDF" asp-route-id="@i.IncapacidadId"
                                       class="btn btn-sm btn-outline-danger" title="PDF">
                                    <i class="bi bi-file-earmark-pdf"></i>
                                </a>
                                @if (!string.IsNullOrEmpty(i.Empleado.CorreoElectronico))
                                {
                                    <form asp-action="EnviarPorEmail" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@i.IncapacidadId" />
                                        <button type="submit" class="btn btn-sm btn-outline-success" title="Enviar correo">
                                            <i class="bi bi-envelope"></i>
                                        </button>
                                    </form>
                                }
                                <a asp-action="Edit" asp-route-id="@i.IncapacidadId"
                                       class="btn btn-sm btn-warning" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="Delete" method="post" class="d-inline"
                                      onsubmit="return confirm('¿Eliminar esta incapacidad de @i.Empleado.PrimerApellido?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@i.IncapacidadId" />
                                    <button type="submit" class="btn btn-sm btn-danger" title="Eliminar">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}