@model GEPCP_Ferreteria_El_Pana.Models.Feriado
@{
    ViewData["Title"] = "Editar Feriado - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-pencil"></i> Editar Feriado</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div class="card shadow-sm border-0" style="max-width: 500px;">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="FeriadoId" />
            <div class="row g-3">

                <div class="col-12">
                    <label asp-for="Fecha" class="form-label fw-bold">
                        <i class="bi bi-calendar-event"></i> Fecha <span class="text-danger">*</span>
                    </label>
                    <input asp-for="Fecha" type="date"
                           class="form-control form-control-lg" />
                    <span asp-validation-for="Fecha" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Nombre" class="form-label fw-bold">
                        <i class="bi bi-tag"></i> Nombre <span class="text-danger">*</span>
                    </label>
                    <input asp-for="Nombre" class="form-control form-control-lg"
                           maxlength="100" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Tipo" class="form-label fw-bold">
                        <i class="bi bi-flag"></i> Tipo <span class="text-danger">*</span>
                    </label>
                    <select asp-for="Tipo" class="form-select form-select-lg">
                        <option value="1">Obligatorio</option>
                        <option value="2">No Obligatorio</option>
                    </select>
                    <span asp-validation-for="Tipo" class="text-danger small"></span>
                </div>

            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-warning btn-lg px-5">
                    <i class="bi bi-check-circle"></i> Guardar Cambios
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-lg px-5">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}