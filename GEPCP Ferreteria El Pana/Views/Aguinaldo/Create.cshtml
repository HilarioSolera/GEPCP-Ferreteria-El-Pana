@model GEPCP_Ferreteria_El_Pana.Models.Aguinaldo
@{
    ViewData["Title"] = "Nuevo Aguinaldo - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-gift"></i> Nuevo Aguinaldo</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger mb-3">
                    <ul class="mb-0">
                        @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@e.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }

            <div class="row g-3">
                <!-- Buscador -->
                <div class="col-12">
                    <label class="form-label fw-bold">
                        <i class="bi bi-person-search"></i> Empleado <span class="text-danger">*</span>
                    </label>
                    <input type="hidden" asp-for="EmpleadoId" id="EmpleadoId" />

                    <div class="input-group mb-1">
                        <span class="input-group-text bg-white">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        <input type="text" id="buscarEmpleado" class="form-control"
                               placeholder="Buscar por nombre, apellido o cédula..." autocomplete="off" />
                        <button type="button" class="btn btn-outline-secondary" id="btnTodos">
                            <i class="bi bi-list-ul"></i> Todos
                        </button>
                    </div>

                    <div id="empleadoSeleccionado" class="d-none alert alert-success py-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <i class="bi bi-person-check-fill"></i>
                                <strong id="empNombre"></strong><br>
                                <span class="text-muted" id="empCedula"></span> —
                                <span id="empPuesto"></span>
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-danger" id="btnLimpiar">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                    </div>

                    <div id="resultados" class="border rounded shadow-sm"
                         style="display:none; max-height:300px; overflow-y:auto; background:#fff; position:relative; z-index:100;">
                    </div>
                    <span asp-validation-for="EmpleadoId" class="text-danger small"></span>
                </div>

                <!-- Campos -->
                <div class="col-md-3">
                    <label asp-for="Anio" class="form-label fw-bold">Año</label>
                    <input asp-for="Anio" type="number" min="2020" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="FechaInicio" class="form-label fw-bold">Inicio Período</label>
                    <input asp-for="FechaInicio" type="date" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="FechaFin" class="form-label fw-bold">Fin Período</label>
                    <input asp-for="FechaFin" type="date" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="FechaPago" class="form-label fw-bold">Fecha de Pago</label>
                    <input asp-for="FechaPago" type="date" class="form-control" />
                </div>

                <div class="col-12">
                    <label asp-for="MontoTotal" class="form-label fw-bold">Monto Total (₡)</label>
                    <input asp-for="MontoTotal" type="number" step="0.01" min="0.01"
                           class="form-control" placeholder="Ej: 345678.90" />
                </div>

                <div class="col-12">
                    <label asp-for="Observaciones" class="form-label fw-bold">Observaciones</label>
                    <textarea asp-for="Observaciones" class="form-control" rows="3" maxlength="300"></textarea>
                </div>
            </div>

            <div class="mt-4 d-flex gap-3">
                <button type="submit" class="btn btn-success btn px-5" id="btnGuardar" disabled>
                    <i class="bi bi-check-circle"></i> Registrar Aguinaldo
                </button>
                <a asp-action="Index" class="btn btn-secondary btn px-5">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        var empData = null;
        window._empResults = [];

        async function buscar(termino, todos = false) {
            var url = todos ? '/Aguinaldo/TodosLosEmpleados' : '/Aguinaldo/BuscarEmpleados?termino=' + encodeURIComponent(termino);
            var res = await fetch(url);
            var data = await res.json();
            var div = document.getElementById('resultados');

            if (!data.length) {
                div.innerHTML = '<div class="p-3 text-muted text-center">Sin resultados.</div>';
                div.style.display = 'block';
                return;
            }

            window._empResults = data;
            div.innerHTML = data.map((e, i) => `
                        <div class="p-3 border-bottom emp-item" data-index="${i}" style="cursor:pointer">
                            <div class="fw-bold">${e.nombre}</div>
                            <div class="small text-muted">${e.cedula} — ${e.puesto}</div>
                        </div>
                    `).join('');

            div.querySelectorAll('.emp-item').forEach(el => {
                el.addEventListener('click', () => seleccionar(parseInt(el.getAttribute('data-index'))));
            });
            div.style.display = 'block';
        }

        function seleccionar(index) {
            var e = window._empResults[index];
            empData = e;
            document.getElementById('EmpleadoId').value = e.id;
            document.getElementById('empNombre').textContent = e.nombre;
            document.getElementById('empCedula').textContent = e.cedula;
            document.getElementById('empPuesto').textContent = e.puesto;

            document.getElementById('empleadoSeleccionado').classList.remove('d-none');
            document.getElementById('resultados').style.display = 'none';
            document.getElementById('buscarEmpleado').value = '';
            document.getElementById('btnGuardar').disabled = false;
        }

        // Eventos
        var timer;
        document.getElementById('buscarEmpleado').addEventListener('input', function() {
            clearTimeout(timer);
            var val = this.value.trim();
            if (val.length < 2) {
                document.getElementById('resultados').style.display = 'none';
                return;
            }
            timer = setTimeout(() => buscar(val), 300);
        });

        document.getElementById('btnTodos').addEventListener('click', () => buscar('', true));

        document.getElementById('btnLimpiar').addEventListener('click', function() {
            empData = null;
            document.getElementById('EmpleadoId').value = '';
            document.getElementById('empleadoSeleccionado').classList.add('d-none');
            document.getElementById('btnGuardar').disabled = true;
        });

        document.addEventListener('click', function(e) {
            if (!e.target.closest('#resultados') &&
                !e.target.closest('#buscarEmpleado') &&
                !e.target.closest('#btnTodos')) {
                document.getElementById('resultados').style.display = 'none';
            }
        });
    </script>
}