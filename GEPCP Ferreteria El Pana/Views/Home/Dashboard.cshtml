@{
    ViewData["Title"] = "Dashboard Ejecutivo";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var rol = ViewBag.Rol as string ?? "";
    var periodoActivo = ViewBag.PeriodoActivo as GEPCP_Ferreteria_El_Pana.Models.PeriodoPago;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0">
            <i class="bi bi-speedometer2"></i> Dashboard Ejecutivo
        </h2>
        <small class="text-muted">
            Bienvenido, <strong>@ViewBag.Usuario</strong> —
            Rol: <span class="badge bg-secondary">@ViewBag.Rol</span>
        </small>
    </div>
    <span class="text-muted small">
        @DateTime.Now.ToString("dddd, dd MMMM yyyy")
    </span>
</div>

@* ── BANNER PERÍODO ACTIVO ────────────────────────────────────────── *@
@if (periodoActivo != null)
{
    <div class="alert border-0 shadow-sm mb-4 py-3"
         style="background-color: #FFF3E0; border-left: 4px solid #FF7A00 !important;">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <i class="bi bi-calendar2-check" style="color:#FF7A00;"></i>
                <strong style="color:#FF7A00;">Período Activo:</strong>
                @periodoActivo.Descripcion —
                <span class="text-muted small">
                    @periodoActivo.FechaInicio.ToString("dd/MM/yyyy")
                    al @periodoActivo.FechaFin.ToString("dd/MM/yyyy")
                </span>
            </div>
            <a asp-controller="Planilla" asp-action="Index"
                   class="btn btn-sm btn-outline-warning">
                <i class="bi bi-file-earmark-text"></i> Ver Planilla
            </a>
        </div>
    </div>
}
else
{
    <div class="alert alert-warning shadow-sm mb-4 py-2 small">
        <i class="bi bi-exclamation-triangle"></i>
        No hay ningún período de pago abierto.
        <a asp-controller="PeriodosPago" asp-action="Create"
           class="alert-link ms-1">Crear período</a>
    </div>
}

@* ── KPIs FILA 1: EMPLEADOS Y PLANILLA ───────────────────────────── *@
<div class="row g-4 mb-4">

    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-success bg-opacity-10 p-3">
                    <i class="bi bi-people-fill fs-3 text-success"></i>
                </div>
                <div>
                    <div class="text-muted small">Empleados Activos</div>
                    <div class="fs-3 fw-bold text-success">
                        @ViewBag.TotalEmpleadosActivos
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0">
                <a asp-controller="Empleados" asp-action="Index"
                       class="small text-decoration-none text-success">
                    Ver empleados <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                    <i class="bi bi-file-earmark-text fs-3 text-primary"></i>
                </div>
                <div>
                    <div class="text-muted small">
                        Neto Período
                        @if (periodoActivo != null)
                        {
                            <span class="badge bg-success ms-1" style="font-size:0.65rem;">Activo</span>
                        }
                    </div>
                    <div class="fs-3 fw-bold text-primary">
                        ₡@ViewBag.NetoPeriodoActivo.ToString("N0")
                    </div>
                    <div class="text-muted" style="font-size:0.75rem;">
                        @ViewBag.EmpleadosEnPlanilla empleados calculados
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0">
                <a asp-controller="Planilla" asp-action="Index"
                       class="small text-decoration-none text-primary">
                    Ver planilla <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                    <i class="bi bi-cash-coin fs-3 text-warning"></i>
                </div>
                <div>
                    <div class="text-muted small">Saldo Préstamos</div>
                    <div class="fs-3 fw-bold text-warning">
                        ₡@ViewBag.TotalSaldoPrestamos.ToString("N0")
                    </div>
                    <div class="text-muted" style="font-size:0.75rem;">
                        @ViewBag.TotalPrestamosActivos préstamo(s) activo(s)
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0">
                <a asp-controller="Prestamos" asp-action="Index"
                       class="small text-decoration-none text-warning">
                    Ver préstamos <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-danger bg-opacity-10 p-3">
                    <i class="bi bi-cart-check fs-3 text-danger"></i>
                </div>
                <div>
                    <div class="text-muted small">Saldo Créditos Ferretería</div>
                    <div class="fs-3 fw-bold text-danger">
                        ₡@ViewBag.TotalCreditosActivos.ToString("N0")
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0">
                <a asp-controller="CreditoFerreteria" asp-action="Index"
                       class="small text-decoration-none text-danger">
                    Ver créditos <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>

</div>

@* ── KPIs FILA 2: HORAS EXTRAS, INCAPACIDADES, COMISIONES ────────── *@
<div class="row g-4 mb-5">

    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-info bg-opacity-10 p-3">
                    <i class="bi bi-clock-history fs-3 text-info"></i>
                </div>
                <div>
                    <div class="text-muted small">
                        Horas Extras
                        @if (periodoActivo != null)
                        {
                            <span class="text-muted" style="font-size:0.7rem;">
                                (período activo)
                            </span>
                        }
                    </div>
                    <div class="fs-3 fw-bold text-info">
                        ₡@ViewBag.TotalHorasExtrasPeriodo.ToString("N0")
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0">
                <a asp-controller="HorasExtras" asp-action="Index"
                       class="small text-decoration-none text-info">
                    Ver horas extras <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-danger bg-opacity-10 p-3">
                    <i class="bi bi-hospital fs-3 text-danger"></i>
                </div>
                <div>
                    <div class="text-muted small">Incapacidades Activas</div>
                    <div class="fs-3 fw-bold text-danger">
                        @ViewBag.TotalIncapacidadesActivas
                    </div>
                    <div class="text-muted" style="font-size:0.75rem;">
                        Costo patrono: ₡@ViewBag.TotalMontoIncapacidades.ToString("N0")
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0">
                <a asp-controller="Incapacidades" asp-action="Index"
                       class="small text-decoration-none text-danger">
                    Ver incapacidades <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-success bg-opacity-10 p-3">
                    <i class="bi bi-graph-up fs-3 text-success"></i>
                </div>
                <div>
                    <div class="text-muted small">Comisiones Registradas</div>
                    <div class="fs-3 fw-bold text-success">
                        ₡@ViewBag.TotalComisiones.ToString("N0")
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0">
                <a asp-controller="Comisiones" asp-action="Index"
                       class="small text-decoration-none text-success">
                    Ver comisiones <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>

    @if (rol == "RRHH")
    {
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle p-3"
                         style="background-color: rgba(255,122,0,0.10);">
                        <i class="bi bi-briefcase fs-3" style="color:#FF7A00;"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Puestos Activos</div>
                        <div class="fs-3 fw-bold" style="color:#FF7A00;">
                            @ViewBag.TotalPuestosActivos
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0 pt-0">
                    <a asp-controller="Puestos" asp-action="Index"
                           class="small text-decoration-none" style="color:#FF7A00;">
                        Ver puestos <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    }

</div>

@* ── ACCESOS RÁPIDOS ──────────────────────────────────────────────── *@
<h5 class="mb-3 text-muted">
    <i class="bi bi-lightning-charge"></i> Accesos Rápidos
</h5>
<div class="row g-3">

    @if (rol == "RRHH")
    {
        <div class="col-md-2">
            <a asp-controller="Empleados" asp-action="Create"
                   class="btn btn-outline-success w-100 py-3">
                <i class="bi bi-person-plus fs-4 d-block mb-1"></i>
                Nuevo Empleado
            </a>
        </div>
        <div class="col-md-2">
            <a asp-controller="Prestamos" asp-action="Create"
                   class="btn btn-outline-warning w-100 py-3">
                <i class="bi bi-cash-coin fs-4 d-block mb-1"></i>
                Nuevo Préstamo
            </a>
        </div>
        <div class="col-md-2">
            <a asp-controller="HorasExtras" asp-action="Create"
                   class="btn btn-outline-info w-100 py-3">
                <i class="bi bi-clock-history fs-4 d-block mb-1"></i>
                Horas Extras
            </a>
        </div>
        <div class="col-md-2">
            <a asp-controller="Incapacidades" asp-action="Create"
                   class="btn btn-outline-danger w-100 py-3">
                <i class="bi bi-hospital fs-4 d-block mb-1"></i>
                Nueva Incapacidad
            </a>
        </div>
        <div class="col-md-2">
            <a asp-controller="Comisiones" asp-action="Create"
                   class="btn btn-outline-secondary w-100 py-3">
                <i class="bi bi-graph-up-arrow fs-4 d-block mb-1"></i>
                Nueva Comisión
            </a>
        </div>
    }

    <div class="col-md-2">
        <a asp-controller="Planilla" asp-action="Index"
               class="btn w-100 py-3 text-white"
               style="background-color:#FF7A00;">
            <i class="bi bi-file-earmark-text fs-4 d-block mb-1"></i>
            Ver Planilla
        </a>
    </div>

</div>