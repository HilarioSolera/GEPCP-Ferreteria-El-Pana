@model List<GEPCP_Ferreteria_El_Pana.Models.CreditoFerreteria>
@{
    ViewData["Title"] = "Créditos Ferretería - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-cart-check"></i> Créditos Ferretería</h2>
    <a asp-action="Create" class="btn btn-success btn-lg">
        <i class="bi bi-plus-circle"></i> Nuevo Crédito
    </a>
</div>

@* KPIs *@
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-primary">@ViewBag.TotalCreditos</div>
            <div class="text-muted small">Total Créditos</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-success">@ViewBag.TotalActivos</div>
            <div class="text-muted small">Créditos Activos</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-warning">₡@ViewBag.TotalSaldo.ToString("N0")</div>
            <div class="text-muted small">Saldo Total Pendiente</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-info">₡@ViewBag.TotalCuotasQuinc.ToString("N0")</div>
            <div class="text-muted small">Cuotas Quincenales</div>
        </div>
    </div>
</div>

@* Filtros *@
<form asp-action="Index" method="get" class="mb-4">
    <div class="row g-2">
        <div class="col-md-7">
            <div class="input-group shadow-sm">
                <span class="input-group-text bg-white">
                    <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" name="busqueda" value="@ViewBag.Busqueda"
                       class="form-control border-start-0"
                       placeholder="Buscar por nombre, cédula o descripción..." />
            </div>
        </div>
        <div class="col-md-2">
            @{
                var filtroActual = ViewBag.EstadoFiltro as string ?? "";
            }
            <select name="estado" class="form-select shadow-sm">
                <option value="" selected="@(filtroActual == "" ? "selected" : null)">Todos</option>
                <option value="Activo" selected="@(filtroActual == "Activo" ? "selected" : null)">Activo</option>
                <option value="Cerrado" selected="@(filtroActual == "Cerrado" ? "selected" : null)">Cerrado</option>
            </select>
        </div>
        <div class="col-md-1">
            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-funnel"></i>
            </button>
        </div>
        <div class="col-md-2">
            @if (!string.IsNullOrEmpty(ViewBag.Busqueda as string) ||
                             !string.IsNullOrEmpty(ViewBag.EstadoFiltro as string))
            {
                <a asp-action="Index" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-x-circle"></i> Limpiar
                </a>
            }
        </div>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info text-center py-4">
        <i class="bi bi-inbox fs-3 d-block mb-2"></i>
        No se encontraron créditos con los filtros aplicados.
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle mb-0">
            <thead style="background-color: #FF7A00; color: white;">
                <tr>
                    <th>Empleado</th>
                    <th>Descripción</th>
                    <th class="text-end">Monto Original</th>
                    <th class="text-end">Saldo Actual</th>
                    <th class="text-end">Cuota Quincenal</th>
                    <th>Fecha</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    var pct = c.MontoTotal > 0
                        ? (int)(((c.MontoTotal - c.Saldo) / c.MontoTotal) * 100)
                        : 0;
                    pct = Math.Max(0, Math.Min(100, pct));

                    <tr class="@(!c.Activo ? "table-light text-muted" : "")">
                        <td>
                            <strong>@c.Empleado.PrimerApellido @c.Empleado.Nombre</strong>
                            <div class="small text-muted">@c.Empleado.Cedula</div>
                        </td>
                        <td>
                            <span class="text-truncate d-inline-block" style="max-width:200px;"
                                  title="@c.Descripcion">
                                @c.Descripcion
                            </span>
                        </td>
                        <td class="text-end">₡@c.MontoTotal.ToString("N0")</td>
                        <td class="text-end fw-bold @(c.Activo ? "text-warning" : "text-success")">
                            ₡@c.Saldo.ToString("N0")
                            @if (c.Activo)
                            {
                                <div class="progress mt-1" style="height:4px;">
                                    <div class="progress-bar bg-warning" style="width:@pct%"></div>
                                </div>
                            }
                        </td>
                        <td class="text-end">₡@c.CuotaQuincenal.ToString("N0")</td>
                        <td>@c.FechaCredito.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">
                            @if (c.Activo)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Cerrado</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">
                                @if (c.Activo)
                                {
                                    <button type="button"
                                            class="btn btn-sm btn-primary"
                                            title="Registrar Abono"
                                            data-bs-toggle="modal"
                                            data-bs-target="#modalAbono"
                                            data-id="@c.CreditoFerreteriaId"
                                            data-saldo="@c.Saldo"
                                            data-nombre="@c.Empleado.PrimerApellido @c.Empleado.Nombre"
                                            data-desc="@c.Descripcion">
                                        <i class="bi bi-cash-stack"></i>
                                    </button>

                                    <form asp-action="Cerrar" method="post" class="d-inline"
                                          onsubmit="return confirm('¿Cerrar el crédito de @c.Empleado.PrimerApellido @c.Empleado.Nombre?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@c.CreditoFerreteriaId" />
                                        <button type="submit" class="btn btn-sm btn-secondary"
                                                title="Cerrar crédito">
                                            <i class="bi bi-x-circle"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="Reabrir" method="post" class="d-inline"
                                          onsubmit="return confirm('¿Reabrir el crédito de @c.Empleado.PrimerApellido @c.Empleado.Nombre?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@c.CreditoFerreteriaId" />
                                        <button type="submit" class="btn btn-sm btn-warning"
                                                title="Reabrir crédito">
                                            <i class="bi bi-arrow-counterclockwise"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="text-muted small mt-2 text-end">
        Total: <strong>@Model.Count</strong> crédito(s) —
        Activos: <strong>@Model.Count(c => c.Activo)</strong> /
        Cerrados: <strong>@Model.Count(c => !c.Activo)</strong>
    </div>
}

@* Modal Abono *@
<div class="modal fade" id="modalAbono" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header text-white" style="background-color: #FF7A00;">
                <h5 class="modal-title">
                    <i class="bi bi-cash-stack"></i> Registrar Abono
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="RegistrarAbono" method="post" id="formAbono">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <input type="hidden" name="creditoId" id="abonoCreditoId" />

                    <div class="alert alert-info py-2 small">
                        <i class="bi bi-person-circle"></i>
                        <strong id="abonoNombre"></strong><br />
                        <i class="bi bi-tag"></i> <span id="abonoDesc" class="text-muted"></span><br />
                        Saldo actual: <strong id="abonoSaldoTexto" class="text-warning"></strong>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">
                            Monto del Abono (₡) <span class="text-danger">*</span>
                        </label>
                        <input type="number" name="monto" id="abonoMonto"
                               class="form-control form-control-lg"
                               step="0.01" min="0.01"
                               placeholder="Ingresá el monto a abonar" />
                        <div class="form-text text-muted" id="abonoHint"></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="submit" class="btn btn-primary px-4"
                            onclick="return validarAbono()">
                        <i class="bi bi-check-circle"></i> Registrar Abono
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var modalAbono = document.getElementById('modalAbono');
        modalAbono.addEventListener('show.bs.modal', function (e) {
            var btn   = e.relatedTarget;
            var id    = btn.getAttribute('data-id');
            var saldo = parseFloat(btn.getAttribute('data-saldo'));
            var nom   = btn.getAttribute('data-nombre');
            var desc  = btn.getAttribute('data-desc');

            document.getElementById('abonoCreditoId').value  = id;
            document.getElementById('abonoMonto').value      = '';
            document.getElementById('abonoMonto').max        = saldo;
            document.getElementById('abonoNombre').textContent = nom;
            document.getElementById('abonoDesc').textContent   = desc;
            document.getElementById('abonoSaldoTexto').textContent =
                '&#8353;' + saldo.toLocaleString('es-CR', {minimumFractionDigits: 2});
            document.getElementById('abonoHint').textContent =
                'Máximo permitido: ₡' + saldo.toLocaleString('es-CR', {minimumFractionDigits: 2});
        });

        function validarAbono() {
            var monto = parseFloat(document.getElementById('abonoMonto').value);
            var max   = parseFloat(document.getElementById('abonoMonto').max);
            var hint  = document.getElementById('abonoHint');

            if (isNaN(monto) || monto <= 0) {
                hint.textContent = '⚠ El monto debe ser mayor a cero.';
                hint.className   = 'form-text text-danger';
                return false;
            }
            if (monto > max) {
                hint.textContent = '⚠ El abono no puede superar el saldo (₡' +
                    max.toLocaleString('es-CR') + ').';
                hint.className = 'form-text text-danger';
                return false;
            }
            return true;
        }
    </script>
}