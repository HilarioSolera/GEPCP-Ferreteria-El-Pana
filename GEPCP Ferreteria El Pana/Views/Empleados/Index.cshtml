@model IEnumerable<GEPCP_Ferreteria_El_Pana.Models.EmpleadoViewModel>

@{
    ViewData["Title"] = "Empleados - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="mb-4">Listado de Empleados</h2>

<p>
    <a asp-action="Create" class="btn btn-success btn-lg">Nuevo Empleado</a>
</p>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">
        No hay empleados registrados aún.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Cédula</th>
                    <th>Nombre Completo</th>
                    <th>Puesto</th>
                    <th>Salario Base</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Cedula</td>
                        <td>
                            @item.Nombre @item.PrimerApellido @(string.IsNullOrEmpty(item.SegundoApellido) ? "" : item.SegundoApellido)
                        </td>
                        <td>@item.Puesto</td>
                        <td>@item.SalarioBase.ToString("N0") ₡</td>
                        <td>
                            <span class="badge @(item.Estado == "Activo" ? "bg-success" : "bg-danger")">
                                @item.Estado
                            </span>
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.EmpleadoId" class="btn btn-primary btn-sm">Editar</a>
                            <a asp-action="Details" asp-route-id="@item.EmpleadoId" class="btn btn-info btn-sm">Detalles</a>
                            <!-- Si tienes Delete, agrégalo aquí con confirmación -->
                            <!-- <a asp-action="Delete" asp-route-id="@item.EmpleadoId" class="btn btn-danger btn-sm">Eliminar</a> -->
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
    <!-- Opcional: si quieres agregar DataTables o algún JS extra para la tabla -->
    <!-- <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script> -->
    <!-- <script>$(document).ready(function () { $('.table').DataTable(); });</script> -->
}