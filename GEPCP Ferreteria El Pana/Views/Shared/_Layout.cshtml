<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — GEPCP Ferretería El Pana</title>
    <link rel="icon" type="image/jpeg" href="~/css/images/logo-el-pana.jpg" />
    <link rel="shortcut icon" type="image/jpeg" href="~/css/images/logo-el-pana.jpg" />
    <link rel="apple-touch-icon" href="~/css/images/logo-el-pana.jpg" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="~/css/gepcp-theme.css?v=@DateTime.Now.Ticks" rel="stylesheet" />
    <style>
        .loading-indicator__topbar {
            height: 8px !important;
            background: linear-gradient(90deg, transparent 0%, #FFFFFF 10%, #FFFFFF 50%, #FFFFFF 90%, transparent 100%) !important;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.9), 0 0 24px rgba(0, 0, 0, 0.8) !important;
        }
        .loading-indicator__panel {
            background: linear-gradient(135deg, rgba(0, 0, 0, 0.96), rgba(24, 24, 24, 0.95)) !important;
            box-shadow: 0 16px 40px rgba(0, 0, 0, 0.55), 0 0 20px rgba(0, 0, 0, 0.45) !important;
        }
        .loading-indicator__spinner {
            width: 24px !important;
            height: 24px !important;
            border: 3px solid rgba(255,255,255,.3) !important;
            border-top-color: #FFFFFF !important;
            animation: loading-spin .6s linear infinite !important;
        }
    </style>
  </head>
  <body class="bg-light">

    @if (Context.Session.GetString("Usuario") != null)
    {
    var usuario = Context.Session.GetString("Usuario");
    var rol = Context.Session.GetString("Rol");
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString()?.ToLower() ?? "";

    <nav class="navbar navbar-expand-lg navbar-dark" style="background-color:#FF7A00;">
      <div class="container-fluid px-3">

        <a class="navbar-brand d-flex align-items-center gap-2"
               asp-controller="Home" asp-action="Dashboard">
          <img src="~/css/images/logo-el-pana.jpg" alt="Ferretería El Pana" style="width:42px;height:42px;border-radius:10px;object-fit:cover;border:2px solid rgba(255,255,255,.55);" />
          <div class="d-flex flex-column lh-1">
            <span style="font-size:1.3rem;font-weight:800;letter-spacing:-0.3px;">GEPCP</span>
            <span style="font-size:0.55rem;font-weight:600;letter-spacing:1.8px;
                            text-transform:uppercase;opacity:0.85;">
              Ferretería El Pana
            </span>
          </div>
        </a>

        <button class="navbar-toggler" type="button"
                data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav me-0" style="--nav-active-bg: rgba(255,255,255,0.22);">

            <li class="nav-item">
              <a class="nav-link @(ctrl == "home" ? "active" : "")" asp-controller="Home" asp-action="Dashboard">
                <i class="bi bi-speedometer2"></i>
                <span class="nav-label">Dashboard</span>
              </a>
            </li>

            <li class="nav-item">
              <a class="nav-link @(ctrl == "empleados" ? "active" : "")" asp-controller="Empleados" asp-action="Index">
                <i class="bi bi-people"></i>
                <span class="nav-label">Empleados</span>
              </a>
            </li>

            <li class="nav-item">
              <a class="nav-link @(ctrl == "planilla" ? "active" : "")" asp-controller="Planilla" asp-action="Index">
                <i class="bi bi-file-earmark-text"></i>
                <span class="nav-label">Planilla</span>
              </a>
            </li>

            <li class="nav-item">
              <a class="nav-link @(ctrl == "periodospago" ? "active" : "")" asp-controller="PeriodosPago" asp-action="Index">
                <i class="bi bi-calendar2-range"></i>
                <span class="nav-label">Períodos</span>
              </a>
            </li>

            <li class="nav-item">
              <a class="nav-link @(ctrl == "horasextras" ? "active" : "")" asp-controller="HorasExtras" asp-action="Index">
                <i class="bi bi-clock-history"></i>
                <span class="nav-label">Hrs. Extras</span>
              </a>
            </li>

            <li class="nav-item">
              <a class="nav-link @(ctrl == "vacaciones" ? "active" : "")" asp-controller="Vacaciones" asp-action="Index">
                <i class="bi bi-umbrella"></i>
                <span class="nav-label">Vacaciones</span>
              </a>
            </li>

            <li class="nav-item">
              <a class="nav-link @(ctrl == "comisiones" ? "active" : "")" asp-controller="Comisiones" asp-action="Index">
                <i class="bi bi-graph-up"></i>
                <span class="nav-label">Comisiones</span>
              </a>
            </li>

            <li class="nav-item">
              <a class="nav-link @(ctrl == "prestamos" ? "active" : "")" asp-controller="Prestamos" asp-action="Index">
                <i class="bi bi-cash-coin"></i>
                <span class="nav-label">Préstamos</span>
              </a>
            </li>

            <li class="nav-item">
              <a class="nav-link @(ctrl == "incapacidades" ? "active" : "")" asp-controller="Incapacidades" asp-action="Index">
                <i class="bi bi-hospital"></i>
                <span class="nav-label">Incapacidades</span>
              </a>
            </li>

            <li class="nav-item">
              <a class="nav-link @(ctrl == "aguinaldo" ? "active" : "")" asp-controller="Aguinaldo" asp-action="Index">
                <i class="bi bi-gift"></i>
                <span class="nav-label">Aguinaldo</span>
              </a>
            </li>

            <li class="nav-item">
              <a class="nav-link @(ctrl == "feriados" ? "active" : "")" asp-controller="Feriados" asp-action="Index">
                <i class="bi bi-calendar-event"></i>
                <span class="nav-label">Feriados</span>
              </a>
            </li>

            @if (rol == "RRHH" || rol == "Jefatura")
            {
            <li class="nav-item">
              <a class="nav-link @(ctrl == "creditoferreteria" ? "active" : "")" asp-controller="CreditoFerreteria" asp-action="Index">
                <i class="bi bi-cart-check"></i>
                <span class="nav-label">Créditos</span>
              </a>
            </li>

            <li class="nav-item">
              <a class="nav-link @(ctrl == "puestos" ? "active" : "")" asp-controller="Puestos" asp-action="Index">
                <i class="bi bi-briefcase"></i>
                <span class="nav-label">Puestos</span>
              </a>
            </li>

            <li class="nav-item">
              <a class="nav-link @(ctrl == "historialsalarios" ? "active" : "")" asp-controller="HistorialSalarios" asp-action="Index">
                <i class="bi bi-clock-history"></i>
                <span class="nav-label">Historial</span>
              </a>
            </li>

            <li class="nav-item">
              <a class="nav-link @(ctrl == "usuarios" ? "active" : "")" asp-controller="Usuarios" asp-action="Index">
                <i class="bi bi-person-gear"></i>
                <span class="nav-label">Usuarios</span>
              </a>
            </li>

            @if (rol == "Jefatura")
            {
            <li class="nav-item">
              <a class="nav-link @(ctrl == "auditoria" ? "active" : "")" asp-controller="Auditoria" asp-action="Index">
                <i class="bi bi-shield-check"></i>
                <span class="nav-label">Auditoría</span>
              </a>
            </li>
            }
            }

            <!-- Separador -->
            <li class="nav-item" style="margin: 0 8px; padding: 0; display: flex; align-items: center;">
              <div style="width: 2px; background: rgba(255,255,255,0.45); height: 44px; border-radius: 2px;"></div>
            </li>
            <!-- Cerrar Sistema -->
            <li class="nav-item">
              <button type="button" class="nav-link nav-cerrar" title="Cerrar sistema" id="btnCerrarPrograma">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span class="nav-label">Cerrar sistema</span>
              </button>
            </li>

            <!-- Cambiar Usuario -->
            <li class="nav-item">
              <form asp-controller="Account" asp-action="Logout" method="post" style="display: contents;">
                @Html.AntiForgeryToken()
                <button type="submit" class="nav-link nav-usuario" title="Cambiar de usuario">
                  <i class="bi bi-arrow-left-right"></i>
                  <span class="nav-label">Cambiar usuario</span>
                </button>
              </form>
            </li>

          </ul>
        </div>
      </div>
    </nav>
    }

    <div class="container-fluid px-4 mt-4">

      @if (TempData["Success"] != null)
      {
      <div class="alert alert-success alert-dismissible fade show shadow-sm">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
      }
      @if (TempData["Error"] != null)
      {
      <div class="alert alert-danger alert-dismissible fade show shadow-sm">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
      }
      @if (TempData["Warning"] != null)
      {
      <div class="alert alert-warning alert-dismissible fade show shadow-sm">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Warning"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
      }
      @if (TempData["Recomendacion"] != null)
      {
      <div class="alert alert-dismissible fade show shadow-sm" style="background-color:#d4edda;border-color:#28a745;color:#155724;">
        <i class="bi bi-lightbulb-fill"></i> @TempData["Recomendacion"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
      }

      @RenderBody()
    </div>

    <footer class="text-center text-muted small py-4 mt-5 border-top">
      GEPCP &copy; @DateTime.Now.Year — Ferretería El Pana SRL |
      Sistema de Gestión de RR.HH.
    </footer>

    <div id="loading-indicator" class="loading-indicator" aria-live="polite" aria-hidden="true">
      <div class="loading-indicator__topbar"></div>
      <div class="loading-indicator__panel">
        <img src="~/css/images/logo-el-pana.jpg" alt="Ferretería El Pana" class="loading-indicator__logo" />
        <div class="loading-indicator__content">
          <div class="loading-indicator__title">GEPCP · Procesando</div>
          <div id="loading-indicator-text" class="loading-indicator__text">Ejecutando tarea...</div>
        </div>
        <span class="loading-indicator__spinner"></span>
      </div>
    </div>

    <div class="modal fade" id="confirmCerrarSistemaModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background-color: #ffffff; border: 2px solid #FF7A00;">
                <div class="modal-header" style="background-color: #FF7A00; border-bottom: 2px solid #FF7A00;">
                    <h5 class="modal-title text-white fw-bold">
                        <i class="bi bi-x-circle"></i> Cerrar Sistema
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" id="btnCancelarCerrar"></button>
                </div>
                <div class="modal-body" style="padding: 24px;">
                    <div style="background-color: #FFF5EB; border-left: 4px solid #FF7A00; padding: 16px; margin-bottom: 16px; border-radius: 6px;">
                        <div style="color: #333; font-weight: 600; margin-bottom: 8px;">
                            <i class="bi bi-exclamation-triangle-fill" style="color: #FF7A00; margin-right: 8px;"></i>
                            ¿Está seguro que desea cerrar el sistema?
                        </div>
                    </div>
                    <p style="color: #555; margin-bottom: 12px; font-size: 0.95rem;">
                        Esta acción detendrá el servidor y cerrará la aplicación.
                    </p>
                    <div style="background-color: #F8F8F8; border: 1px solid #E0E0E0; border-radius: 6px; padding: 12px;">
                        <p style="color: #888; font-size: 0.85rem; margin-bottom: 0;">
                            <i class="bi bi-info-circle" style="color: #FF7A00; margin-right: 6px;"></i>
                            Todos los procesos serán terminados.
                        </p>
                    </div>
                </div>
                <div class="modal-footer" style="border-top: 1px solid #E0E0E0; padding: 12px 16px;">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle"></i> Cancelar
                    </button>
                    <button type="button" class="btn text-white fw-bold" style="background-color: #FF7A00; border-color: #FF7A00;" id="btnConfirmarCerrarSistema">
                        <i class="bi bi-check-circle"></i> Sí, Cerrar Ahora
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        let cierrePermitidoPorBoton = false;

        function cerrarServidorEnSegundoPlano() {
            try {
                if (navigator.sendBeacon) {
                    navigator.sendBeacon('/api/server/shutdown', '');
                    return;
                }
            } catch (e) { }

            fetch('/api/server/shutdown', {
                method: 'POST',
                keepalive: true
            }).catch(function () { });
        }

        function cerrarProgramaGlobal() {
            cierrePermitidoPorBoton = true;
            cerrarServidorEnSegundoPlano();

            setTimeout(function () {
                window.open('', '_self');
                window.close();

                if (!window.closed) {
                    window.location.replace('about:blank');
                    setTimeout(function () {
                        window.open('', '_self');
                        window.close();
                    }, 120);
                }
            }, 220);
        }

        document.addEventListener('DOMContentLoaded', function() {
            const btnCerrarPrograma = document.getElementById('btnCerrarPrograma');
            const btnConfirmarCerrarSistema = document.getElementById('btnConfirmarCerrarSistema');
            const btnCancelarCerrar = document.getElementById('btnCancelarCerrar');
            const modalCerrarSistema = new bootstrap.Modal(document.getElementById('confirmCerrarSistemaModal'), {
                backdrop: 'static',
                keyboard: false
            });

            if (btnCerrarPrograma) {
                btnCerrarPrograma.addEventListener('click', function(e) {
                    e.preventDefault();
                    modalCerrarSistema.show();
                });
            }

            if (btnConfirmarCerrarSistema) {
                btnConfirmarCerrarSistema.addEventListener('click', function() {
                    modalCerrarSistema.hide();
                    Loading.show('Cerrando sistema...');
                    setTimeout(function() {
                        cerrarProgramaGlobal();
                    }, 500);
                });
            }

            if (btnCancelarCerrar) {
                btnCancelarCerrar.addEventListener('click', function() {
                    modalCerrarSistema.hide();
                });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
  </body>
</html>