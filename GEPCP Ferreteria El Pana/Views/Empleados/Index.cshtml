@model IEnumerable<GEPCP_Ferreteria_El_Pana.Models.EmpleadoViewModel>

@{
    ViewData["Title"] = "Empleados - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2 class="mb-4">Listado de Empleados</h2>

    <p>
        <a asp-action="Create" class="btn btn-success btn-lg">Nuevo Empleado</a>
    </p>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center">
            No hay empleados registrados aún.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover table-bordered">
                <thead class="table-dark">
                    <tr>
                        <th>Cédula</th>
                        <th>Nombre Completo</th>
                        <th>Puesto</th>
                        <th>Salario Base</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Cedula</td>
                            <td>
                                @item.Nombre @item.PrimerApellido
                                @(string.IsNullOrEmpty(item.SegundoApellido) ? "" : item.SegundoApellido)
                            </td>
                            <td>@item.Puesto</td>
                            <td>@item.SalarioBase.ToString("N0") ₡</td>
                            <td>
                                <span class="badge @(item.Estado == "Activo" ? "bg-success" : "bg-danger")">
                                    @item.Estado
                                </span>
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.EmpleadoId" class="btn btn-primary btn-sm me-1">
                                    <i class="bi bi-pencil"></i> Editar
                                </a>
                                <a asp-action="Details" asp-route-id="@item.EmpleadoId" class="btn btn-info btn-sm me-1">
                                    <i class="bi bi-eye"></i> Detalles
                                </a>

                                <!-- Botón Desactivar (solo si está activo) -->
                                @if (item.Estado == "Activo")
                                {
                                    <form asp-action="Desactivar" asp-route-id="@item.EmpleadoId" method="post" style="display:inline;">
                                        <button type="submit" class="btn btn-warning btn-sm me-1" onclick="return confirm('¿Desactivar este empleado?');">
                                            <i class="bi bi-toggle-off"></i> Desactivar
                                        </button>
                                    </form>
                                }

                                <!-- Botón Eliminar con confirmación -->
                                <form asp-action="Delete" asp-route-id="@item.EmpleadoId" method="post" style="display:inline;">
                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('¿Eliminar este empleado permanentemente?');">
                                        <i class="bi bi-trash"></i> Eliminar
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

