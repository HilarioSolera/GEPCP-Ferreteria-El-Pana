@model GEPCP_Ferreteria_El_Pana.Models.Comision
@{
    ViewData["Title"] = "Nueva Comisión - GEPCP Ferretería El Pana";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-graph-up-arrow"></i> Nueva Comisión</h2>
    <a href="/Comisiones" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">

                <div class="col-md-12">
                    <label asp-for="EmpleadoId" class="form-label fw-bold">
                        <i class="bi bi-person"></i> Empleado
                    </label>
                    <select asp-for="EmpleadoId" asp-items="ViewBag.Empleados"
                            class="form-select form-select-lg">
                        <option value="">— Seleccione un empleado —</option>
                    </select>
                    <span asp-validation-for="EmpleadoId" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Monto" class="form-label fw-bold">
                        <i class="bi bi-cash"></i> Monto de la Comisión (₡)
                    </label>
                    <input asp-for="Monto" type="number" min="1" step="1"
                           class="form-control form-control-lg" placeholder="0" />
                    <span asp-validation-for="Monto" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Fecha" class="form-label fw-bold">
                        <i class="bi bi-calendar"></i> Fecha
                    </label>
                    <input asp-for="Fecha" type="date" class="form-control form-control-lg"
                           value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="Fecha" class="text-danger small"></span>
                </div>

                <div class="col-md-12">
                    <label asp-for="Descripcion" class="form-label fw-bold">
                        <i class="bi bi-chat-text"></i> Descripción
                    </label>
                    <input asp-for="Descripcion" class="form-control form-control-lg"
                           placeholder="Ej: Comisión por entregas quincena 1 julio" />
                    <span asp-validation-for="Descripcion" class="text-danger small"></span>
                </div>

            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-success btn-lg px-5">
                    <i class="bi bi-check-circle"></i> Registrar Comisión
                </button>
                <a href="/Comisiones" class="btn btn-secondary btn-lg px-5">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}